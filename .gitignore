# Cloned whisper.cpp repo — external source, not versioned here
whisper.cpp/

# Pre-built native DLLs (whisper.cpp + MinGW runtime)
native/

# Whisper models — large binary files (100 MB to 3 GB)
models/

# .NET build artifacts
src/**/bin/
src/**/obj/
archive/**/bin/
archive/**/obj/

# Deployment output — rebuildable via dotnet publish
publish/

# Legacy whisp-ui folder (may contain locked publish/ artifacts)
whisp-ui/

# Temporary audio file created during recording
**/temp.wav

# Misc local files
build-log.txt
modelfile-fastapply

# Visual Studio local state
.vs/

# Diagnostic artifacts (ad hoc scripts/logs)
.tmp/
**/.tmp-*
**/*.binlog
**/build.log
**/xamlcompiler.log
**/xaml.out
.claude/settings.local.json

# Ad hoc file-based crash logs (see HudComposition.DebugLog pattern) —
# keep the folder itself versioned so the path exists when code writes to it.
logs/*
!logs/.gitkeep

# Benchmark — run artifacts (regenerated on each launch)
benchmark/__pycache__/
benchmark/logs/*.log
benchmark/logs/*.csv
benchmark/logs/reports/last_report.json
benchmark/logs/reports/results.tsv
benchmark/logs/reports/autoresearch_report.txt

# Benchmark — entire data corpus (transcripts, JSONL logs, everything).
# Local dictation samples + personal corpus, never pushed. Kept as blanket
# ignore because the contents evolve on every run; no need to enumerate
# file types as new artifacts get added.
benchmark/data/

# Claude Code runtime state (locks, caches) — keep the tracked agent/skill defs
.claude/scheduled_tasks.lock

# Symlink to Claude auto-memory directory (created locally, never versioned)
/memory

run.log
