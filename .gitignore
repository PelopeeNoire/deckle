# Cloned whisper.cpp repo — external source, not versioned here
whisper.cpp/

# Pre-built native DLLs (whisper.cpp + MinGW runtime)
native/

# Whisper models — large binary files (100 MB to 3 GB)
models/

# .NET build artifacts
src/**/bin/
src/**/obj/
archive/**/bin/
archive/**/obj/
dev/**/bin/
dev/**/obj/

# Deployment output — rebuildable via dotnet publish
publish/

# Legacy whisp-ui folder (may contain locked publish/ artifacts)
whisp-ui/

# Temporary audio file created during recording
**/temp.wav

# Misc local files
build-log.txt
modelfile-fastapply

# Visual Studio local state
.vs/

# Diagnostic artifacts (ad hoc scripts/logs)
.tmp/
**/.tmp-*
**/*.binlog
**/build.log
**/xamlcompiler.log
**/xaml.out
.claude/settings.local.json

# Ad hoc file-based crash logs (see HudComposition.DebugLog pattern) —
# keep the folder itself versioned so the path exists when code writes to it.
logs/*
!logs/.gitkeep

# Benchmark — runtime artifacts, never versioned.
# telemetry/ : raw WhispUI capture (corpus JSONL, WAVs, latency, app log,
#              archived legacy files). Private — layout is <slug>/corpus.jsonl,
#              <slug>/audio/*.wav, latency.jsonl, app.jsonl, legacy/, exemples/.
# reports/   : bench output artifacts (last_<name>_run.{json,txt}, per-experiment
#              snapshots, autoresearch_report.txt). Regenerated each run.
# logs/      : live step-by-step log of the benchmark script itself — kept
#              so a crashed run can be resumed, not meant to persist across
#              runs.
# results.tsv: autoresearch journal at benchmark/ root, one row per experiment.
benchmark/**/__pycache__/
benchmark/telemetry/
benchmark/reports/
benchmark/logs/
benchmark/results.tsv

# Claude Code runtime state (locks, caches) — keep the tracked agent/skill defs
.claude/scheduled_tasks.lock

# Symlink to Claude auto-memory directory (created locally, never versioned)
/memory

run.log
memory.lnk
