# ─────────────────────────────────────────────────────────────────────────
#  External sources / large binaries — fetched or built locally
# ─────────────────────────────────────────────────────────────────────────

# Cloned whisper.cpp repo — external source, not versioned here.
whisper.cpp/

# Pre-built native DLLs (whisper.cpp + MinGW runtime). Runtime layout
# resolves them from %LOCALAPPDATA%\Deckle\native\ exclusively; this
# entry is defensive against stray copies under the repo root.
native/

# Whisper model weights — large binary files (100 MB to 3 GB).
models/

# ─────────────────────────────────────────────────────────────────────────
#  Build artifacts
# ─────────────────────────────────────────────────────────────────────────

# .NET build output.
src/**/bin/
src/**/obj/

# Deployment output — rebuildable via dotnet publish.
publish/

# Misc build logs.
build-log.txt
**/build.log
**/*.binlog
**/xamlcompiler.log
**/xaml.out

# ─────────────────────────────────────────────────────────────────────────
#  IDE / OS junk
# ─────────────────────────────────────────────────────────────────────────

# Visual Studio local state.
.vs/

# JetBrains, Vim swap, macOS, Windows Explorer thumbnails.
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────
#  Secrets / credentials — preventive, no such file should ever exist here
# ─────────────────────────────────────────────────────────────────────────

# Environment variable files.
*.env
.env
.env.*

# Private keys, certificates, secret stores.
*.pem
*.key
*.p12
*.pfx
secrets/
credentials*
*.credential

# Misplaced MCP config (the only one that ever leaked here was purged
# from history; this entry is preventive).
.mcp.json
mcp.json

# ─────────────────────────────────────────────────────────────────────────
#  Runtime artifacts
# ─────────────────────────────────────────────────────────────────────────

# Temporary audio file written during recording.
**/temp.wav

# Crash dumps and ad hoc diagnostic files.
.tmp/
**/.tmp-*
*.dmp
crash-*.log

# File-based crash logs (see HudComposition.DebugLog pattern). The
# folder itself stays versioned so the path exists when code writes
# to it.
logs/*
!logs/.gitkeep

# Top-level run log (live tail captured by build-run.ps1).
run.log

# ─────────────────────────────────────────────────────────────────────────
#  Benchmark — runtime artifacts, never versioned
# ─────────────────────────────────────────────────────────────────────────
#
#   telemetry/  raw Deckle capture (corpus JSONL + WAVs, latency, app log).
#               Layout: <slug>/corpus.jsonl, <slug>/audio/*.wav, …
#   reports/    per-run benchmark output (last_<name>_run.{json,txt},
#               per-experiment snapshots). Regenerated each run.
#   logs/       step-by-step log of the benchmark script itself —
#               kept so a crashed run can be resumed.
#   results.tsv journal at benchmark/ root, one row per experiment.
benchmark/**/__pycache__/
benchmark/telemetry/
benchmark/reports/
benchmark/logs/
benchmark/results.tsv

# ─────────────────────────────────────────────────────────────────────────
#  Claude Code runtime state and local-only customisation
# ─────────────────────────────────────────────────────────────────────────
# Tracked agent / skill / instruction files stay versioned — only
# runtime state and personal-only customisation are excluded.

.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/.session*

# Worktrees created via Claude Code's EnterWorktree tool. The directory
# itself is a registered git worktree (its content is not git-tracked
# in the parent), but excluding the path here prevents `git status`
# from ever surfacing it as untracked, and prevents accidental
# `git add .` pollution.
.claude/worktrees/

# Personal-workflow skills not meant for the public repo.
.claude/skills/benchmark-loop/

# Symlink to Claude auto-memory directory (created locally, never
# versioned).
/memory
memory.lnk
