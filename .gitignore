# Dépôt whisper.cpp cloné — code source externe, non versionné ici
whisper.cpp/

# Modèles Whisper — fichiers binaires lourds (100 Mo à 3 Go)
shared/*.bin

# Artefacts de compilation .NET
whisp-ui/**/bin/
whisp-ui/**/obj/
archive/**/bin/
archive/**/obj/

# Dossier de déploiement — reconstruisible avec dotnet publish
whisp-ui/publish/

# Scripts de build/publish locaux — chemins machine, pas versionnés
whisp-ui/*.ps1

# Fichier audio temporaire créé pendant l'enregistrement
**/temp.wav

# Fichiers locaux non pertinents
build-log.txt
modelfile-fastapply

# État local Visual Studio
.vs/

# Scories de diagnostic (scripts/logs ad hoc)
.tmp/
**/.tmp-*
**/*.binlog
**/build.log
**/xamlcompiler.log
**/xaml.out
.claude/settings.local.json
