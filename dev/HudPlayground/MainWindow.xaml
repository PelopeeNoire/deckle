<Window
    x:Class="HudPlayground.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WhispUI.Controls"
    Title="HudPlayground — dev">

    <!-- Native Microsoft.UI.Xaml.Controls.TitleBar auto-extended:
         WinUI 3 picks up the standard caption layout automatically
         when the root is a Grid with a matching top row reserved. We
         keep the default caption for now (no branding icon, no search
         field) — the playground is dev-only and the stock TitleBar
         gives us the theme-aware buttons and subtitle slot for free. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left rail: 4 HudChrono previews centered and stacked. -->
            <ColumnDefinition Width="360" />
            <!-- Right rail: scrollable settings-style tuning column.
                 Sliders land in Objectif 4; for now a placeholder. -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left column — preview rail. LayerFillColorDefaultBrush
             picks up the same background the HUD card uses, so the
             cards here read against a visually identical substrate to
             the shipping window. -->
        <Border Grid.Column="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16,24">
                <StackPanel x:Name="PreviewStack"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            Spacing="28">
                    <!-- Four HudChrono instances, one per state. Each
                         is wrapped in a titled section so Louis can see
                         which preview he's looking at; the HudChrono
                         itself sizes to its implicit 272×78 shipping
                         dimensions. -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Charging"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <controls:HudChrono x:Name="ChargingPreview"
                                            Width="272" Height="78" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recording"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <controls:HudChrono x:Name="RecordingPreview"
                                            Width="272" Height="78" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Transcribing"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <controls:HudChrono x:Name="TranscribingPreview"
                                            Width="272" Height="78" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Rewriting"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <controls:HudChrono x:Name="RewritingPreview"
                                            Width="272" Height="78" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right column — tunables (placeholder until Objectif 4). -->
        <Border Grid.Column="1"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24">
                <StackPanel x:Name="TuningStack" Spacing="12">
                    <TextBlock Text="Tunables"
                               Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock Text="Sliders coming in next pass (Objectif 4)."
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
