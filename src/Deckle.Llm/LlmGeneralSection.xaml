<UserControl
    x:Class="Deckle.Llm.LlmGeneralSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI">

    <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Uid="LlmGeneralHeader"
                       Grid.Column="0"
                       Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
            <HyperlinkButton x:Uid="Settings_SectionResetLink"
                             Grid.Column="1"
                             VerticalAlignment="Bottom"
                             Margin="0,0,0,2"
                             Click="ResetSection_Click" />
        </Grid>

        <controls:SettingsCard x:Uid="LlmEnableCard"
                               HeaderIcon="{ui:FontIcon Glyph=&#xE945;}">
            <ToggleSwitch x:Name="EnabledToggle"
                          Toggled="EnabledToggle_Toggled" />
        </controls:SettingsCard>

        <controls:SettingsExpander x:Uid="LlmEndpointExpander"
                                   HeaderIcon="{ui:FontIcon Glyph=&#xE968;}"
                                   IsEnabled="{x:Bind IsRewritingEnabled, Mode=OneWay}">
            <controls:SettingsExpander.Items>
                <controls:SettingsCard ContentAlignment="Vertical">
                    <TextBox x:Name="EndpointBox"
                             MinWidth="400"
                             PlaceholderText="http://localhost:11434/api/chat"
                             TextChanged="EndpointBox_TextChanged" />
                </controls:SettingsCard>
            </controls:SettingsExpander.Items>
        </controls:SettingsExpander>
    </StackPanel>
</UserControl>
