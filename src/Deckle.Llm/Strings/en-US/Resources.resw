  </data>
  <data name="GeneralStorageFolderOpenButton.ToolTipService.ToolTip" xml:space="preserve">
    <value>Open in File Explorer</value>
  </data>
  <data name="GeneralBackupExpander.Header" xml:space="preserve">
    <value>Back up and restore your settings</value>
  </data>
  <data name="GeneralBackupExpander.Description" xml:space="preserve">
    <value>Snapshot your settings to a file, or roll back to the last snapshot. Point the location at OneDrive or another cloud-synced folder to carry your settings across machines.</value>
  </data>
  <data name="GeneralBackupCreateButton.Content" xml:space="preserve">
    <value>Back up</value>
  </data>
  <data name="GeneralBackupRestoreButton.Content" xml:space="preserve">
    <value>Restore</value>
  </data>
  <data name="GeneralBackupLocationCard.Header" xml:space="preserve">
    <value>Location</value>
  </data>
  <data name="GeneralBackupChangeButton.ToolTipService.ToolTip" xml:space="preserve">
    <value>Pick a folder</value>
  </data>
  <data name="GeneralBackupInfoCard.Header" xml:space="preserve">
    <value>Backup information</value>
  </data>
  <data name="GeneralBackupFileNameLabel.Text" xml:space="preserve">
    <value>File name:</value>
  </data>
  <data name="GeneralBackupCreatedAtLabel.Text" xml:space="preserve">
    <value>Created at:</value>
  </data>
  <data name="GeneralDataFolderCard.Header" xml:space="preserve">
    <value>Data folder</value>
  </data>
  <data name="GeneralDataFolderCard.Description" xml:space="preserve">
    <value>Settings, telemetry, models, and native libraries — everything mutable lives here. Defaults to %LOCALAPPDATA%\Deckle\.</value>
  </data>
  <data name="GeneralDataFolderOpenText.Text" xml:space="preserve">
    <value>Open</value>
  </data>
  <data name="GeneralDataFolderOpenButton.ToolTipService.ToolTip" xml:space="preserve">
    <value>Open in File Explorer</value>
  </data>
  <data name="GeneralRerunSetupCard.Header" xml:space="preserve">
    <value>First-run setup</value>
  </data>
  <data name="GeneralRerunSetupCard.Description" xml:space="preserve">
    <value>Re-open the setup wizard to swap the speech model or replace the native runtime.</value>
  </data>
  <data name="GeneralRerunSetupButton.Content" xml:space="preserve">
