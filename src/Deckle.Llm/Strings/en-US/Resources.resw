  <!-- ─── Consent dialogs ────────────────────────────────────────────
       Opt-in prompts for local data capture. Each dialog follows the
       same structure: Title, Body_Intro paragraph, then three
       sub-sections (What/Where/Remind) sharing Common_Consent_*Header
       headers, and Enable/Cancel buttons reusing Common_Enable /
       Common_Cancel. The "Where" body line is the actual filesystem
       path and stays hardcoded in the C# (not copy). -->

  <!-- Section headers shared across the four consent dialogs. -->
  <data name="Common_Consent_WhatHeader" xml:space="preserve">
    <value>What gets captured</value>
  </data>
  <data name="Common_Consent_WhereHeader" xml:space="preserve">
    <value>Where it's stored</value>
  </data>
  <data name="Common_Consent_RemindHeader" xml:space="preserve">
    <value>Keep in mind</value>
  </data>

  <!-- Corpus consent — text+rewrite JSONL appended per profile. -->
  <data name="CorpusConsent_Title" xml:space="preserve">
    <value>Enable corpus logging</value>
  </data>
  <data name="CorpusConsent_Body_Intro" xml:space="preserve">
    <value>Deckle will append every transcription to a local JSONL file — one folder per rewrite profile, one corpus.jsonl inside each — so you can iterate on your rewrite prompts offline.</value>
  </data>
  <data name="CorpusConsent_Body_What" xml:space="preserve">
    <value>Raw transcription text, rewritten text, timing, model and prompt identifiers. Nothing is sent over the network.</value>
  </data>
  <data name="CorpusConsent_Body_Remind" xml:space="preserve">
    <value>Transcriptions may contain sensitive content. Review and purge the files periodically, and exclude them from any backup target you don't control.</value>
  </data>

  <!-- Application log consent — full app.jsonl mirror of every log line. -->
  <data name="ApplicationLogConsent_Title" xml:space="preserve">
    <value>Enable application log</value>
  </data>
  <data name="ApplicationLogConsent_Body_Intro" xml:space="preserve">
    <value>Deckle will mirror every in-app log line to a local JSONL file (app.jsonl) so you can diagnose a specific issue across restarts.</value>
  </data>
  <data name="ApplicationLogConsent_Body_What" xml:space="preserve">
    <value>Every log line from every subsystem — capture, VAD, Whisper, rewriting, clipboard, paste, UI — at every verbosity level. Log messages can include partial transcription text when a pipeline step logs what it just produced. Nothing is sent over the network.</value>
  </data>
  <data name="ApplicationLogConsent_Body_Remind" xml:space="preserve">
    <value>The log is chatty — expect roughly 2 MB per 30 minutes of active use. It rotates every 5000 lines (app-1.jsonl, app-2.jsonl, …) with no cap on archives, so turn it off once you have what you need and prune the archives by hand.</value>
  </data>

  <!-- Audio corpus consent — raw WAV next to the text JSONL, per profile. -->
  <data name="AudioCorpusConsent_Title" xml:space="preserve">
    <value>Enable audio corpus</value>
  </data>
  <data name="AudioCorpusConsent_Body_Intro" xml:space="preserve">
    <value>Deckle will save the raw microphone audio of every transcription as a 16 kHz mono WAV file, next to the JSONL text corpus under an audio/ subfolder per profile. Useful for replaying a past session against a different Whisper model or prompt.</value>
  </data>
  <data name="AudioCorpusConsent_Body_What" xml:space="preserve">
    <value>The exact audio passed to whisper.cpp — including any silence and background noise picked up by the microphone. One WAV per transcription. Nothing is sent over the network.</value>
  </data>
  <data name="AudioCorpusConsent_Body_Remind" xml:space="preserve">
    <value>Voice recordings are biometric-adjacent and the files can be replayed verbatim. Review and purge the folder regularly, and exclude it from any backup target you don't control.</value>
  </data>

  <!-- Microphone telemetry consent — per-recording dBFS distribution row. -->
  <data name="MicrophoneTelemetryConsent_Title" xml:space="preserve">
    <value>Enable microphone telemetry</value>
  </data>
  <data name="MicrophoneTelemetryConsent_Body_Intro" xml:space="preserve">
    <value>Deckle will log your microphone level distribution after every recording, so you can calibrate the HUD level window against the dBFS range your microphone actually produces.</value>
  </data>
  <data name="MicrophoneTelemetryConsent_Body_What" xml:space="preserve">
    <value>Only level statistics — minimum, percentiles (p10, p25, p50, p75, p90), maximum, and mean RMS — in dBFS. No audio. No transcription. No words. Nothing is sent over the network.</value>
  </data>
  <data name="MicrophoneTelemetryConsent_Body_Remind" xml:space="preserve">
    <value>One short JSON line per recording — small file. Useful when calibrating, then turn it off. The same data also appears in the LogWindow under [CAPTURE] for live inspection.</value>
  </data>

