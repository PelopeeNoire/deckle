  </data>

  <!-- ─── WhisperPage ────────────────────────────────────────────────
       Second page in the Settings nav. Per-setting Reset buttons share
       the SettingsResetButton.ToolTipService.ToolTip key (style-level
       tooltip in the Page resources). -->
  <data name="WhisperPage_Title" xml:space="preserve">
    <value>Transcription</value>
  </data>
  <data name="WhisperPage_Subtitle" xml:space="preserve">
    <value>Control how Deckle turns your voice into text. Start with the model and language — then use Speech filtering to fight hallucinations on silences and background noise.</value>
  </data>
  <data name="WhisperPage_ResetAll.ToolTipService.ToolTip" xml:space="preserve">
    <value>Reset all transcription settings to defaults</value>
  </data>
  <data name="WhisperPage_Section_ModelEngine" xml:space="preserve">
    <value>Model &amp; engine</value>
  </data>
  <data name="WhisperPage_Section_SpeechFiltering" xml:space="preserve">
    <value>Speech filtering</value>
  </data>
  <data name="WhisperPage_Section_OutputFilters" xml:space="preserve">
    <value>Output filters</value>
  </data>
  <data name="WhisperPage_Section_ContextSegmentation" xml:space="preserve">
    <value>Context and segmentation</value>
  </data>
  <data name="WhisperPage_Section_Decoding" xml:space="preserve">
    <value>Decoding</value>
  </data>
  <data name="WhisperPage_Section_ConfidenceThresholds" xml:space="preserve">
    <value>Confidence thresholds</value>
  </data>
  <data name="WhisperPage_Section_Storage" xml:space="preserve">
    <value>Storage</value>
  </data>
  <data name="WhisperPage_SpeechFiltering_Body" xml:space="preserve">
    <value>Pre-filter your audio to strip silence and background noise before transcription — the main defense against phantom text on quiet stretches.</value>
  </data>
  <data name="WhisperResetButton.ToolTipService.ToolTip" xml:space="preserve">
    <value>Reset to default</value>
  </data>
  <data name="WhisperModelCard.Header" xml:space="preserve">
    <value>Whisper model (requires restart)</value>
  </data>
  <data name="WhisperModelCard.Description" xml:space="preserve">
    <value>The AI model that converts your voice to text. Larger models produce better results but take more time and memory.</value>
  </data>
  <data name="WhisperModelSuggest.PlaceholderText" xml:space="preserve">
    <value>Pick a model</value>
  </data>
  <data name="WhisperLanguageCard.Header" xml:space="preserve">
    <value>Language</value>
  </data>
  <data name="WhisperLanguageCard.Description" xml:space="preserve">
    <value>The language you're speaking. Set it to match your language for best accuracy, or use 'auto' to let Deckle detect it.</value>
  </data>
  <data name="WhisperInitialPromptCard.Header" xml:space="preserve">
    <value>Initial prompt</value>
  </data>
  <data name="WhisperInitialPromptCard.Description" xml:space="preserve">
    <value>A hint sentence that guides how your speech is transcribed. Use it to teach proper names, set the language tone, or fix recurring mistakes.</value>
  </data>
  <data name="WhisperInitialPromptBox.PlaceholderText" xml:space="preserve">
    <value>Je parle en français, je dis parfois des mots anglais. Claude, pas cloud.</value>
  </data>
  <data name="WhisperUseGpuCard.Header" xml:space="preserve">
    <value>GPU acceleration (requires restart)</value>
  </data>
  <data name="WhisperUseGpuCard.Description" xml:space="preserve">
    <value>Run Whisper on the GPU via Vulkan for faster transcription. Turn off if you see instability or crashes. Default: on.</value>
  </data>
  <data name="WhisperVadEnabledCard.Header" xml:space="preserve">
    <value>Voice activity detection</value>
  </data>
  <data name="WhisperVadEnabledCard.Description" xml:space="preserve">
    <value>Pre-filter audio so only speech reaches the model. Reduces phantom text caused by silence or background noise. Default: on.</value>
  </data>
  <data name="WhisperVadThresholdCard.Header" xml:space="preserve">
    <value>Detection threshold</value>
  </data>
  <data name="WhisperVadThresholdCard.Description" xml:space="preserve">
    <value>How confident Deckle must be that a sound is speech. Higher values filter more noise but may miss quiet speech. Default: 0.5.</value>
  </data>
  <data name="WhisperVadMinSpeechCard.Header" xml:space="preserve">
    <value>Minimum speech duration</value>
  </data>
  <data name="WhisperVadMinSpeechCard.Description" xml:space="preserve">
    <value>Sounds shorter than this (in milliseconds) are ignored. Raise to filter out short clicks and pops. Default: 250 ms.</value>
  </data>
  <data name="WhisperVadMinSilenceCard.Header" xml:space="preserve">
    <value>Minimum silence duration</value>
  </data>
  <data name="WhisperVadMinSilenceCard.Description" xml:space="preserve">
    <value>Gaps shorter than this (in milliseconds) are kept as part of the same speech segment. Default: 500 ms.</value>
  </data>
  <data name="WhisperVadMaxSpeechCard.Header" xml:space="preserve">
    <value>Maximum segment length</value>
  </data>
  <data name="WhisperVadMaxSpeechCard.Description" xml:space="preserve">
    <value>Force-split a continuous speech segment after this many seconds. Default: 30 s.</value>
  </data>
  <data name="WhisperVadSpeechPadCard.Header" xml:space="preserve">
    <value>Speech padding</value>
  </data>
  <data name="WhisperVadSpeechPadCard.Description" xml:space="preserve">
    <value>Extra audio (in milliseconds) kept before and after each detected segment, so words aren't clipped at the edges. Default: 200 ms.</value>
  </data>
  <data name="WhisperVadOverlapCard.Header" xml:space="preserve">
    <value>Window overlap</value>
  </data>
  <data name="WhisperVadOverlapCard.Description" xml:space="preserve">
    <value>Fraction of overlap between consecutive analysis windows. Higher values catch fast transitions at a small CPU cost. Default: 0.1.</value>
  </data>
  <data name="WhisperSuppressNstCard.Header" xml:space="preserve">
    <value>Suppress non-speech tokens</value>
  </data>
  <data name="WhisperSuppressNstCard.Description" xml:space="preserve">
    <value>Remove tags like [Music] or (laughter) that Whisper sometimes adds to the transcription. Default: on.</value>
  </data>
  <data name="WhisperSuppressBlankCard.Header" xml:space="preserve">
    <value>Suppress blank segments</value>
  </data>
  <data name="WhisperSuppressBlankCard.Description" xml:space="preserve">
    <value>Drop segments that contain only whitespace or punctuation. Default: on.</value>
  </data>
  <data name="WhisperSuppressRegexCard.Header" xml:space="preserve">
    <value>Custom regex filter</value>
  </data>
  <data name="WhisperSuppressRegexCard.Description" xml:space="preserve">
    <value>A pattern to automatically remove unwanted text from the transcription. Uses regular expression syntax.</value>
  </data>
  <data name="WhisperSuppressRegexBox.PlaceholderText" xml:space="preserve">
    <value>(e.g. ^\s*\[.*\]\s*$)</value>
  </data>
  <data name="WhisperUseContextCard.Header" xml:space="preserve">
    <value>Carry previous context</value>
  </data>
  <data name="WhisperUseContextCard.Description" xml:space="preserve">
    <value>Pass each segment's result as context for the next one, improving consistency across sentences. Turn off if the transcription starts repeating itself. Default: on.</value>
  </data>
  <data name="WhisperMaxTokensCard.Header" xml:space="preserve">
    <value>Maximum tokens per segment</value>
  </data>
  <data name="WhisperMaxTokensCard.Description" xml:space="preserve">
    <value>Limit how much text can be generated for each segment. Default: -1 (auto).</value>
  </data>
  <data name="WhisperTemperatureCard.Header" xml:space="preserve">
    <value>Temperature</value>
  </data>
  <data name="WhisperTemperatureCard.Description" xml:space="preserve">
    <value>Randomness of the decoder. 0 is deterministic and safest — raise only if the model gets stuck repeating the same phrase. Default: 0.0.</value>
  </data>
  <data name="WhisperTemperatureIncrementCard.Header" xml:space="preserve">
    <value>Fallback temperature step</value>
  </data>
  <data name="WhisperTemperatureIncrementCard.Description" xml:space="preserve">
    <value>When a segment seems uncertain, the model retries with increasing randomness in steps of this size. Set to 0 to disable retries. Default: 0.2.</value>
  </data>
  <data name="WhisperTemperatureIncrementWarning.Title" xml:space="preserve">
    <value>Fallback disabled</value>
  </data>
  <data name="WhisperTemperatureIncrementWarning.Message" xml:space="preserve">
    <value>With the step set to 0, Whisper won't retry uncertain segments. Leave at 0.2 unless you have a specific reason.</value>
  </data>
  <data name="WhisperEntropyCard.Header" xml:space="preserve">
    <value>Entropy threshold</value>
  </data>
  <data name="WhisperEntropyCard.Description" xml:space="preserve">
    <value>Detects repetition loops by measuring token diversity. Low-diversity segments are retried at higher temperature. Raise to catch subtler repetitions. Default: 2.4.</value>
  </data>
  <data name="WhisperLogprobCard.Header" xml:space="preserve">
    <value>Log-probability threshold</value>
  </data>
  <data name="WhisperLogprobCard.Description" xml:space="preserve">
    <value>Average decoder confidence per segment. Low-confidence segments are retried at higher temperature. Also gates silence suppression with the no-speech check. Raise (toward 0) to be stricter. Default: -1.0.</value>
  </data>
  <data name="WhisperNoSpeechCard.Header" xml:space="preserve">
    <value>No-speech threshold</value>
  </data>
  <data name="WhisperNoSpeechCard.Description" xml:space="preserve">
    <value>Controls silence suppression. When the model flags a segment as silence and confidence is also low, the segment is dropped. Lower values suppress more aggressively. Default: 0.6.</value>
  </data>
  <data name="WhisperPathsCard.Header" xml:space="preserve">
    <value>Models folder</value>
  </data>
  <data name="WhisperPathsCard.Description" xml:space="preserve">
    <value>Where Whisper and Silero model files are stored on disk.</value>
  </data>
  <data name="WhisperModelsDirCard.Header" xml:space="preserve">
    <value>Folder path</value>
  </data>
  <data name="WhisperModelsDirCard.Description" xml:space="preserve">
    <value>Leave empty to use the default location next to the application.</value>
  </data>
  <data name="WhisperModelsDirBox.PlaceholderText" xml:space="preserve">
    <value>(auto)</value>
  </data>
  <data name="WhisperRestartDiscard.Content" xml:space="preserve">
    <value>Discard</value>
  </data>
  <data name="WhisperRestartNow.Content" xml:space="preserve">
    <value>Restart now</value>
  </data>

