  </data>

  <!-- LlmGeneralSection -->
  <data name="LlmGeneralHeader.Text" xml:space="preserve">
    <value>General</value>
  </data>
  <data name="LlmEnableCard.Header" xml:space="preserve">
    <value>Enable rewriting</value>
  </data>
  <data name="LlmEnableCard.Description" xml:space="preserve">
    <value>Master switch for all LLM rewriting. When off, transcriptions are never sent to Ollama.</value>
  </data>
  <data name="LlmEndpointExpander.Header" xml:space="preserve">
    <value>Ollama endpoint</value>
  </data>
  <data name="LlmEndpointExpander.Description" xml:space="preserve">
    <value>The URL of your local Ollama instance.</value>
  </data>

  <!-- LlmModelsSection -->
  <data name="LlmModelsHeader.Text" xml:space="preserve">
    <value>Models</value>
  </data>
  <data name="LlmModelsBody.Text" xml:space="preserve">
    <value>Models available in your local Ollama instance. Use the import button to create a model from a GGUF file with the correct chat template.</value>
  </data>
  <data name="LlmImportGgufButton.Content" xml:space="preserve">
