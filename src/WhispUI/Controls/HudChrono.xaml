<UserControl
    x:Class="WhispUI.Controls.HudChrono"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="ChronoRoot"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="0">
            <TextBlock x:Name="ClockText"
                       FontFamily="ms-appx:///Assets/Fonts/BitcountSingle.ttf#Bitcount Single"
                       FontWeight="ExtraLight"
                       FontSize="48"
                       TextLineBounds="Tight"
                       CharacterSpacing="-325"
                       Margin="24,0,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                <Run x:Name="Min1" Text="0" />
                <Run x:Name="Min2" Text="0" />
                <Run Text="." />
                <Run x:Name="Sec1" Text="0" />
                <Run x:Name="Sec2" Text="0" />
                <Run Text="." />
                <Run x:Name="Cs1"  Text="0" />
                <Run x:Name="Cs2"  Text="0" />
            </TextBlock>
        </Border>

        <Border Grid.Column="1" Padding="12,12,12,12">
            <Grid Width="32" Height="32">
                <Ellipse x:Name="StatusDot"
                         Width="4" Height="4"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Fill="{ThemeResource SystemFillColorCriticalBrush}" />
            </Grid>
        </Border>

        <!-- Composition surface: empty Border covering the whole control,
             host for ElementCompositionPreview.SetElementChildVisual. The
             stroke + shadow visuals (Transcribing / Rewriting) are attached
             here. Transparent and IsHitTestVisible=False so it doesn't
             intercept any input — purely a Composition mount point. -->
        <Border x:Name="ProcessingSurfaceHost"
                Grid.Column="0" Grid.ColumnSpan="2"
                Background="Transparent"
                IsHitTestVisible="False" />
    </Grid>
</UserControl>
