<UserControl
    x:Class="WhispUI.Controls.HudChrono"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Three elements only: the Grid root, the ChronoCard Border (opaque
         card surface with rounded corner + theme-tracked stroke) and the
         ClockText sibling on top of it. The card paints
         LayerFillColorDefaultBrush (opaque fill) and CardStrokeColorDefaultBrush
         (1 dip stroke, Win11 canonical card stroke token). BorderThickness
         starts at 0 — the stroke is toggled per state from code-behind:
         hidden for Recording, visible for Charging/Transcribing/Rewriting.
         Rounded silhouette produced by this Border alone. -->
    <Grid x:Name="ChronoRoot">
        <Border x:Name="ChronoCard"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0"
                CornerRadius="{ThemeResource OverlayCornerRadius}" />

        <TextBlock x:Name="ClockText"
                   FontFamily="ms-appx:///Assets/Fonts/BitcountSingle.ttf#Bitcount Single"
                   FontWeight="ExtraLight"
                   FontSize="48"
                   TextLineBounds="Tight"
                   CharacterSpacing="-325"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorPrimaryBrush}">
            <Run x:Name="Min1" Text="0" />
            <Run x:Name="Min2" Text="0" />
            <Run Text="." />
            <Run x:Name="Sec1" Text="0" />
            <Run x:Name="Sec2" Text="0" />
            <Run Text="." />
            <Run x:Name="Cs1"  Text="0" />
            <Run x:Name="Cs2"  Text="0" />
        </TextBlock>
    </Grid>
</UserControl>
