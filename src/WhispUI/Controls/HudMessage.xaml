<UserControl
    x:Class="WhispUI.Controls.HudMessage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Outer Grid spans the whole UserControl (which itself fills the
         window — 400x160 during Message state). ShadowHost is the
         attach point for the Composition halo+drop visual; sizing it to
         the outer Grid means the shadow can bleed into the transparent
         margin around the 272x78 card without being clipped. -->
    <Grid x:Name="OuterRoot">
        <Border x:Name="ShadowHost"
                Background="Transparent"
                IsHitTestVisible="False" />

        <!-- Card surface — fixed 272x78 across HUD states. Centered so
             the surrounding margin (during the 400x160 Full phase) is the
             halo bleed area. -->
        <Grid x:Name="MessageRoot"
              Width="272" Height="78"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="16,12,12,12">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Spacing="2">
                <TextBlock x:Name="MessageTitle"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="MessageSubtitle"
                           Style="{StaticResource BodyTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border x:Name="BadgeBackground"
                    Grid.Column="1"
                    Width="16" Height="16"
                    CornerRadius="4"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right">
                <FontIcon x:Name="BadgeGlyph"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="11"
                          Foreground="White" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
