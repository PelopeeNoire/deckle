<Page
    x:Class="WhispUI.Settings.WhisperPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>

        <!-- Slider compact pour valeurs bornées continues — pattern Settings
             Windows 11 (sensibilité souris, volume, etc.). Pas de spinner,
             pas de layout shift, valeur affichée à droite via ValueTextBlock. -->
        <Style x:Key="SettingSliderStyle"
               TargetType="Slider">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsThumbToolTipEnabled" Value="True" />
        </Style>

        <Style x:Key="SliderValueTextStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- Bouton reset per-setting. Opacity 0 par défaut, passée à 1 au
             PointerEntered de la SettingsCard parente (code-behind). -->
        <Style x:Key="ResetButtonStyle"
               BasedOn="{StaticResource SubtleButtonStyle}"
               TargetType="Button">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.ToolTip" Value="Reset to default" />
        </Style>
    </Page.Resources>

    <Grid Background="Transparent"
          Tapped="OnBackgroundTapped">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      Padding="32,24,32,24"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Background="Transparent">
                <StackPanel MaxWidth="1000"
                            HorizontalAlignment="Stretch"
                            Spacing="{StaticResource SettingsCardSpacing}">

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Transcription"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <Button Grid.Column="1"
                            VerticalAlignment="Center"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="Reset all transcription settings to defaults"
                            Click="ResetAll_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                            <TextBlock Text="Reset all" />
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Text="Control how WhispUI turns your voice into text. Start with the model and language — then use Speech filtering to fight hallucinations on silences and background noise." />

                <!-- ── Transcription ───────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Model &amp; engine" />

                <controls:SettingsCard x:Name="ModelCard"
                                       Header="Whisper model (requires restart)"
                                       Description="The AI model that converts your voice to text. Larger models produce better results but take more time and memory."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE7F4;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ComboBox x:Name="ModelCombo"
                                  MinWidth="240"
                                  SelectionChanged="ModelCombo_SelectionChanged" />
                        <Button x:Name="ModelReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="ModelReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="LanguageCard"
                                       Header="Language"
                                       Description="The language you're speaking. Set it to match your language for best accuracy, or use 'auto' to let WhispUI detect it."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xF2B7;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ComboBox x:Name="LanguageCombo"
                                  MinWidth="160"
                                  IsEditable="True"
                                  SelectionChanged="LanguageCombo_SelectionChanged"
                                  LostFocus="LanguageCombo_LostFocus">
                            <ComboBoxItem Content="auto" />
                            <ComboBoxItem Content="fr" />
                            <ComboBoxItem Content="en" />
                            <ComboBoxItem Content="es" />
                            <ComboBoxItem Content="de" />
                            <ComboBoxItem Content="it" />
                            <ComboBoxItem Content="pt" />
                            <ComboBoxItem Content="nl" />
                            <ComboBoxItem Content="ja" />
                            <ComboBoxItem Content="zh" />
                        </ComboBox>
                        <Button x:Name="LanguageReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="LanguageReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsExpander x:Name="InitialPromptCard"
                                           Header="Initial prompt"
                                           Description="A hint sentence that guides how your speech is transcribed. Use it to teach proper names, set the language tone, or fix recurring mistakes."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE932;}">
                    <Button x:Name="InitialPromptReset"
                            Style="{StaticResource ResetButtonStyle}"
                            Click="InitialPromptReset_Click">
                        <FontIcon Glyph="&#xE777;" FontSize="14" />
                    </Button>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Vertical">
                            <StackPanel Spacing="8">
                                <TextBox x:Name="InitialPromptBox"
                                         MinHeight="80"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         PlaceholderText="Je parle en français, je dis parfois des mots anglais. Claude, pas cloud."
                                         Text="{x:Bind ViewModel.InitialPrompt, Mode=TwoWay}" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <controls:SettingsCard x:Name="UseGpuCard"
                                       Header="GPU acceleration (requires restart)"
                                       Description="Run Whisper on the GPU via Vulkan for faster transcription. Turn off if you see instability or crashes. Default: on."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE950;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="UseGpuToggle"
                                      IsOn="{x:Bind ViewModel.UseGpu, Mode=TwoWay}" />
                        <Button x:Name="UseGpuReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="UseGpuReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <!-- ── Speech filtering ────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Speech filtering" />

                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="1,0,0,8"
                           Text="Pre-filter your audio to strip silence and background noise before transcription — the main defense against phantom text on quiet stretches." />

                <controls:SettingsExpander x:Name="VadEnabledCard"
                                           Header="Voice activity detection"
                                           Description="Pre-filter audio so only speech reaches the model. Reduces phantom text caused by silence or background noise. Default: on."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE720;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="VadEnabledToggle"
                                      IsOn="{x:Bind ViewModel.VadEnabled, Mode=TwoWay}" />
                        <Button x:Name="VadEnabledReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="VadEnabledReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <controls:SettingsExpander.Items>

                        <controls:SettingsCard x:Name="VadThresholdCard"
                                               Header="Detection threshold"
                                               Description="How confident WhispUI must be that a sound is speech. Higher values filter more noise but may miss quiet speech. Default: 0.5.">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Slider x:Name="VadThresholdSlider"
                                        Style="{StaticResource SettingSliderStyle}"
                                        Minimum="0"
                                        Maximum="1"
                                        StepFrequency="0.05"
                                        TickFrequency="0.1"
                                        Value="{x:Bind ViewModel.VadThreshold, Mode=TwoWay}"
                                        ValueChanged="VadThresholdSlider_ValueChanged" />
                                <TextBlock x:Name="VadThresholdValue"
                                           Style="{StaticResource SliderValueTextStyle}" />
                                <Button x:Name="VadThresholdReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadThresholdReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadMinSpeechCard"
                                               Header="Minimum speech duration"
                                               Description="Sounds shorter than this (in milliseconds) are ignored. Raise to filter out short clicks and pops. Default: 250 ms.">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <NumberBox x:Name="VadMinSpeechBox"
                                           Minimum="0"
                                           Maximum="5000"
                                           SmallChange="50"
                                           LargeChange="250"
                                           SpinButtonPlacementMode="Hidden"
                                           MinWidth="100"
                                           Value="{x:Bind ViewModel.VadMinSpeechDurationMs, Mode=TwoWay}" />
                                <Button x:Name="VadMinSpeechReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadMinSpeechReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadMinSilenceCard"
                                               Header="Minimum silence duration"
                                               Description="Gaps shorter than this (in milliseconds) are kept as part of the same speech segment. Default: 500 ms.">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <NumberBox x:Name="VadMinSilenceBox"
                                           Minimum="0"
                                           Maximum="5000"
                                           SmallChange="50"
                                           LargeChange="250"
                                           SpinButtonPlacementMode="Hidden"
                                           MinWidth="100"
                                           Value="{x:Bind ViewModel.VadMinSilenceDurationMs, Mode=TwoWay}" />
                                <Button x:Name="VadMinSilenceReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadMinSilenceReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadMaxSpeechCard"
                                               Header="Maximum segment length"
                                               Description="Force-split a continuous speech segment after this many seconds. Default: 30 s.">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <!-- Bug WinUI 3 release (net10 / trimming) :
                                     poser Minimum="5" ou Value="5" en XAML
                                     fait throw le parser à InitializeComponent
                                     ("Failed to assign to property RangeBase.
                                     Minimum/Value"). Seul Slider du fichier
                                     avec Minimum > defaultValue. Fix : on
                                     laisse en XAML uniquement Maximum et les
                                     steps ; Minimum et Value sont posés en
                                     code-behind dans le ctor via
                                     ConfigureMinValueSlider() (après
                                     InitializeComponent). -->
                                <Slider x:Name="VadMaxSpeechSlider"
                                        Style="{StaticResource SettingSliderStyle}"
                                        Maximum="60"
                                        StepFrequency="1"
                                        TickFrequency="5"
                                        Value="{x:Bind ViewModel.VadMaxSpeechDurationSec, Mode=TwoWay}"
                                        ValueChanged="VadMaxSpeechSlider_ValueChanged" />
                                <TextBlock x:Name="VadMaxSpeechValue"
                                           Style="{StaticResource SliderValueTextStyle}" />
                                <Button x:Name="VadMaxSpeechReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadMaxSpeechReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadSpeechPadCard"
                                               Header="Speech padding"
                                               Description="Extra audio (in milliseconds) kept before and after each detected segment, so words aren't clipped at the edges. Default: 200 ms.">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <NumberBox x:Name="VadSpeechPadBox"
                                           Minimum="0"
                                           Maximum="2000"
                                           SmallChange="25"
                                           LargeChange="100"
                                           SpinButtonPlacementMode="Hidden"
                                           MinWidth="100"
                                           Value="{x:Bind ViewModel.VadSpeechPadMs, Mode=TwoWay}" />
                                <Button x:Name="VadSpeechPadReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadSpeechPadReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadOverlapCard"
                                               Header="Window overlap"
                                               Description="Fraction of overlap between consecutive analysis windows. Higher values catch fast transitions at a small CPU cost. Default: 0.1.">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Slider x:Name="VadOverlapSlider"
                                        Style="{StaticResource SettingSliderStyle}"
                                        Minimum="0"
                                        Maximum="0.5"
                                        StepFrequency="0.05"
                                        TickFrequency="0.1"
                                        Value="{x:Bind ViewModel.VadSamplesOverlap, Mode=TwoWay}"
                                        ValueChanged="VadOverlapSlider_ValueChanged" />
                                <TextBlock x:Name="VadOverlapValue"
                                           Style="{StaticResource SliderValueTextStyle}" />
                                <Button x:Name="VadOverlapReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadOverlapReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- ── Output filters ──────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Output filters" />

                <controls:SettingsCard x:Name="SuppressNstCard"
                                       Header="Suppress non-speech tokens"
                                       Description="Remove tags like [Music] or (laughter) that Whisper sometimes adds to the transcription. Default: on."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE74F;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="SuppressNstToggle"
                                      IsOn="{x:Bind ViewModel.SuppressNonSpeechTokens, Mode=TwoWay}" />
                        <Button x:Name="SuppressNstReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="SuppressNstReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="SuppressBlankCard"
                                       Header="Suppress blank segments"
                                       Description="Drop segments that contain only whitespace or punctuation. Default: on."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE74F;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="SuppressBlankToggle"
                                      IsOn="{x:Bind ViewModel.SuppressBlank, Mode=TwoWay}" />
                        <Button x:Name="SuppressBlankReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="SuppressBlankReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsExpander x:Name="SuppressRegexCard"
                                           Header="Custom regex filter"
                                           Description="A pattern to automatically remove unwanted text from the transcription. Uses regular expression syntax."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE71C;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Vertical">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="SuppressRegexBox"
                                         MinWidth="400"
                                         PlaceholderText="(e.g. ^\s*\[.*\]\s*$)"
                                         Text="{x:Bind ViewModel.SuppressRegex, Mode=TwoWay}" />
                                <Button x:Name="SuppressRegexReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="SuppressRegexReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- ── Context and segmentation ────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Context and segmentation" />

                <controls:SettingsCard x:Name="UseContextCard"
                                       Header="Carry previous context"
                                       Description="Pass each segment's result as context for the next one, improving consistency across sentences. Turn off if the transcription starts repeating itself. Default: on."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE895;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="UseContextToggle"
                                      IsOn="{x:Bind ViewModel.UseContext, Mode=TwoWay}" />
                        <Button x:Name="UseContextReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="UseContextReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="MaxTokensCard"
                                       Header="Maximum tokens per segment"
                                       Description="Limit how much text can be generated for each segment. Default: -1 (auto)."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8B2;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <!-- SpinButtonPlacementMode=Hidden : pas de flyout qui pousse
                             le layout ; saisie clavier + molette. -->
                        <NumberBox x:Name="MaxTokensBox"
                                   Minimum="-1"
                                   Maximum="448"
                                   SmallChange="1"
                                   LargeChange="10"
                                   SpinButtonPlacementMode="Hidden"
                                   MinWidth="100"
                                   Value="{x:Bind ViewModel.MaxTokens, Mode=TwoWay}" />
                        <Button x:Name="MaxTokensReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="MaxTokensReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <!-- ── Decoding ────────────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Decoding" />

                <controls:SettingsCard x:Name="TemperatureCard"
                                       Header="Temperature"
                                       Description="Randomness of the decoder. 0 is deterministic and safest — raise only if the model gets stuck repeating the same phrase. Default: 0.0."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9CA;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="TemperatureSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0"
                                Maximum="1"
                                StepFrequency="0.1"
                                TickFrequency="0.1"
                                Value="{x:Bind ViewModel.Temperature, Mode=TwoWay}"
                                ValueChanged="TemperatureSlider_ValueChanged" />
                        <TextBlock x:Name="TemperatureValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="TemperatureReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="TemperatureReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="TemperatureIncrementCard"
                                       Header="Fallback temperature step"
                                       Description="When a segment seems uncertain, the model retries with increasing randomness in steps of this size. Set to 0 to disable retries. Default: 0.2."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE72C;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="TemperatureIncrementSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0"
                                Maximum="1"
                                StepFrequency="0.1"
                                TickFrequency="0.1"
                                Value="{x:Bind ViewModel.TemperatureIncrement, Mode=TwoWay}"
                                ValueChanged="TemperatureIncrementSlider_ValueChanged" />
                        <TextBlock x:Name="TemperatureIncrementValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="TemperatureIncrementReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="TemperatureIncrementReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <InfoBar x:Name="TemperatureIncrementWarning"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Fallback disabled"
                         Message="With the step set to 0, Whisper won't retry uncertain segments. Leave at 0.2 unless you have a specific reason." />

                <!-- ── Confidence thresholds ───────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Confidence thresholds" />

                <controls:SettingsCard x:Name="EntropyCard"
                                       Header="Entropy threshold"
                                       Description="Detects repetition loops by measuring token diversity. Low-diversity segments are retried at higher temperature. Raise to catch subtler repetitions. Default: 2.4."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="EntropySlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Maximum="3.5"
                                StepFrequency="0.1"
                                TickFrequency="0.5"
                                Value="{x:Bind ViewModel.EntropyThreshold, Mode=TwoWay}"
                                ValueChanged="EntropySlider_ValueChanged" />
                        <TextBlock x:Name="EntropyValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="EntropyReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="EntropyReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="LogprobCard"
                                       Header="Log-probability threshold"
                                       Description="Average decoder confidence per segment. Low-confidence segments are retried at higher temperature. Also gates silence suppression with the no-speech check. Raise (toward 0) to be stricter. Default: -1.0."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="LogprobSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                StepFrequency="0.05"
                                TickFrequency="0.1"
                                Value="{x:Bind ViewModel.LogprobThreshold, Mode=TwoWay}"
                                ValueChanged="LogprobSlider_ValueChanged" />
                        <TextBlock x:Name="LogprobValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="LogprobReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="LogprobReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="NoSpeechCard"
                                       Header="No-speech threshold"
                                       Description="Controls silence suppression. When the model flags a segment as silence and confidence is also low, the segment is dropped. Lower values suppress more aggressively. Default: 0.6."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="NoSpeechSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Maximum="0.80"
                                StepFrequency="0.05"
                                TickFrequency="0.1"
                                Value="{x:Bind ViewModel.NoSpeechThreshold, Mode=TwoWay}"
                                ValueChanged="NoSpeechSlider_ValueChanged" />
                        <TextBlock x:Name="NoSpeechValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="NoSpeechReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="NoSpeechReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <!-- ── Storage ─────────────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Storage" />

                <controls:SettingsExpander x:Name="PathsCard"
                                           Header="Models folder"
                                           Description="Where Whisper and Silero model files are stored on disk."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Vertical"
                                               Header="Folder path"
                                               Description="Leave empty to use the default location next to the application.">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="ModelsDirectoryBox"
                                         MinWidth="400"
                                         PlaceholderText="(auto)"
                                         Text="{x:Bind ViewModel.ModelsDirectory, Mode=TwoWay}" />
                                <Button x:Name="ModelsDirectoryReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="ModelsDirectoryReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

            </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer restart — pattern Windows Terminal Settings.
             56px de haut, DividerStrokeColorDefaultBrush en séparateur,
             AccentButton primaire + Button standard, 8px gap, 32px marge droite. -->
        <Grid x:Name="RestartFooter"
              Grid.Row="1"
              Height="56"
              Visibility="Collapsed"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <StackPanel Margin="0,0,32,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Content="Discard"
                        Click="RestartDiscard_Click" />
                <Button Content="Restart now"
                        Margin="8,0,0,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="RestartNow_Click" />
            </StackPanel>
        </Grid>
