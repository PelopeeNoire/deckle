<Page
    x:Class="WhispUI.Settings.LlmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:llm="using:WhispUI.Settings.Llm">

    <Grid Background="Transparent"
          Tapped="OnBackgroundTapped">
    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Background="Transparent">
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Rewriting"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <Button Grid.Column="1"
                            VerticalAlignment="Center"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="Reset all rewriting settings to defaults"
                            Click="ResetAll_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                            <TextBlock Text="Reset all" />
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Text="Clean up and restructure your transcriptions through a local language model via Ollama. Configure rewrite profiles with different models and prompts, then assign them to duration-based rules or the manual shortcut." />

                <InfoBar x:Name="OllamaStatusBar"
                         Title="Ollama is not reachable"
                         Severity="Warning"
                         IsOpen="False"
                         IsClosable="False"
                         Margin="0,0,0,8" />

                <llm:LlmGeneralSection x:Name="GeneralSection" />
                <llm:LlmShortcutSlotsSection x:Name="ShortcutSlotsSection" />
                <llm:LlmRulesSection x:Name="RulesSection" />
                <llm:LlmProfilesSection x:Name="ProfilesSection" />
                <llm:LlmModelsSection x:Name="ModelsSection" />

            </StackPanel>
        </Grid>
    </ScrollViewer>
    </Grid>
</Page>
