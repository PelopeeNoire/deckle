<Page
    x:Class="WhispUI.Settings.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="using:WhispUI.Settings.ViewModels">

    <!-- Pattern canonique Microsoft Learn (SettingsExpander sample "Settings page
         example") : StackPanel max 1000 dans un Grid, Spacing=4 entre cards,
         Margin="1,30,0,6" sur les headers de section. -->
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <!-- Titre de page — pattern Win11 Settings : le H1 vit dans la
                     Page, pas dans le chrome de la fenêtre. -->
                <TextBlock Text="General"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,8" />

                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Text="Keyboard shortcuts, recording overlay, startup behavior and appearance." />

                <!-- ── Shortcuts ───────────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Shortcuts" />

                <controls:SettingsCard Header="Transcribe"
                                       Description="Start and stop transcription. The text is copied to the clipboard."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE765;}">
                    <TextBlock Text="Win + `"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </controls:SettingsCard>

                <controls:SettingsCard Header="Primary rewrite"
                                       Description="Transcribe, then rewrite with the primary profile. Choose the profile on the Rewriting page."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE765;}">
                    <TextBlock Text="Shift + Win + `"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </controls:SettingsCard>

                <controls:SettingsCard Header="Secondary rewrite"
                                       Description="Transcribe, then rewrite with the secondary profile. Choose the profile on the Rewriting page."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE765;}">
                    <TextBlock Text="Ctrl + Win + `"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </controls:SettingsCard>

                <!-- ── Recording ───────────────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Recording" />
                    <HyperlinkButton Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Content="Reset"
                                     ToolTipService.ToolTip="Reset this section to defaults"
                                     Click="ResetRecording_Click" />
                </Grid>

                <controls:SettingsCard x:Name="AudioInputCard"
                                       Header="Microphone"
                                       Description="Audio input device used for recording. Default: system default."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE720;}">
                    <ComboBox x:Name="AudioInputCombo"
                              MinWidth="240"
                              SelectionChanged="AudioInputCombo_SelectionChanged" />
                </controls:SettingsCard>

                <controls:SettingsCard Header="Auto-paste after transcription"
                                       Description="Also tries to paste into the focused field. The paste is strict and only fires when the target can be safely confirmed — so it rarely triggers. The clipboard is always the reliable path."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE77F;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.AutoPasteEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!--
                    Voice level window — calibration of the dBFS range the
                    HUD chrono maps onto its visible response. Three sliders
                    target HudChrono.{Min,Max}Dbfs + DbfsCurveExponent, pushed
                    live via App.ApplyLevelWindow on every change. The header
                    toggle enables auto-calibration: after a few recordings
                    with "Log microphone" on, the engine snaps the floor and
                    ceiling to the user's measured percentiles.
                -->
                <controls:SettingsExpander Header="Voice level window"
                                           Description="The dBFS range the recording HUD uses to map your microphone signal onto the on-screen level. Calibrate once against your mic and forget it, or let auto-calibration update it from your measured percentiles."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE993;}">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Auto"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.LevelWindowAutoCalibration, Mode=TwoWay}"
                                      OnContent=""
                                      OffContent="" />
                    </StackPanel>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Header="Floor"
                                               Description="Below this level, the HUD reads silence. Set just under the percentile of your normal pauses (typical: -55 dBFS).">
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="LevelWindowMinSlider"
                                        Minimum="-90" Maximum="-10"
                                        Value="{x:Bind ViewModel.LevelWindowMinDbfs, Mode=TwoWay}"
                                        StepFrequency="1"
                                        Width="220"
                                        IsThumbToolTipEnabled="False"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.LevelWindowMinDbfs, Mode=OneWay}"
                                           MinWidth="36"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="dBFS"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Ceiling"
                                               Description="At or above this level, the HUD saturates. Set just below your loudest peaks (typical: -32 dBFS).">
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="LevelWindowMaxSlider"
                                        Minimum="-60" Maximum="-10"
                                        Value="{x:Bind ViewModel.LevelWindowMaxDbfs, Mode=TwoWay}"
                                        StepFrequency="1"
                                        Width="220"
                                        IsThumbToolTipEnabled="False"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.LevelWindowMaxDbfs, Mode=OneWay}"
                                           MinWidth="36"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="dBFS"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Curve"
                                               Description="Shape of the response between floor and ceiling. 1.0 = linear (recommended). Higher = compress quiet, expand loud. Lower = the opposite.">
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider x:Name="LevelWindowExponentSlider"
                                        Minimum="0.3" Maximum="3.0"
                                        Value="{x:Bind ViewModel.LevelWindowExponent, Mode=TwoWay}"
                                        StepFrequency="0.05"
                                        Width="220"
                                        IsThumbToolTipEnabled="False"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.LevelWindowExponent, Mode=OneWay}"
                                           MinWidth="36"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <controls:SettingsExpander Header="Show the overlay while recording"
                                           Description="A small floating indicator shown at the bottom of your screen while WhispUI captures and transcribes."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE7F4;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.OverlayEnabled, Mode=TwoWay}" />
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Header="Fade when your cursor is near"
                                               Description="Make the overlay transparent when you move over it, so it never blocks what's underneath."
                                               IsEnabled="{x:Bind ViewModel.OverlayEnabled, Mode=OneWay}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.OverlayFadeOnProximity, Mode=TwoWay}" />
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Screen position"
                                               Description="Where the overlay appears on your primary display. Applied on the next recording."
                                               IsEnabled="{x:Bind ViewModel.OverlayEnabled, Mode=OneWay}">
                            <ComboBox x:Name="OverlayPositionCombo"
                                      MinWidth="160"
                                      SelectionChanged="OverlayPositionCombo_SelectionChanged">
                                <ComboBoxItem Tag="TopCenter">Top</ComboBoxItem>
                                <ComboBoxItem Tag="BottomCenter">Bottom</ComboBoxItem>
                            </ComboBox>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- ── Startup ─────────────────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Startup" />
                    <HyperlinkButton Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Content="Reset"
                                     ToolTipService.ToolTip="Reset this section to defaults"
                                     Click="ResetStartup_Click" />
                </Grid>

                <controls:SettingsCard Header="Start with Windows"
                                       Description="Launch WhispUI automatically when you sign in."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE7E8;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.AutostartEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard Header="Start minimized"
                                       Description="Open straight to the system tray, without any visible window. Default: on."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE944;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard Header="Warm up Whisper at launch"
                                       Description="Run a silent transcription at startup so the first real recording is fast. Costs a few seconds of GPU at launch."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE945;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.WarmupOnLaunch, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- ── Appearance ──────────────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Appearance" />
                    <HyperlinkButton Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Content="Reset"
                                     ToolTipService.ToolTip="Reset this section to defaults"
                                     Click="ResetAppearance_Click" />
                </Grid>

                <controls:SettingsCard Header="App theme"
                                       Description="Light, dark, or follow your Windows theme."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:Name="ThemeCombo"
                              MinWidth="160"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Tag="System">System</ComboBoxItem>
                        <ComboBoxItem Tag="Light">Light</ComboBoxItem>
                        <ComboBoxItem Tag="Dark">Dark</ComboBoxItem>
                    </ComboBox>
                </controls:SettingsCard>

                <!-- ── Telemetry ───────────────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Telemetry" />
                    <HyperlinkButton Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Content="Reset"
                                     ToolTipService.ToolTip="Reset this section to defaults"
                                     Click="ResetTelemetry_Click" />
                </Grid>

                <controls:SettingsCard Header="Log microphone"
                                       Description="At the end of every recording, log the RMS distribution of your microphone (min, percentiles, max in dBFS) to the LogWindow and to microphone.jsonl. Useful when calibrating the level window."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                    <ToggleSwitch x:Name="MicrophoneTelemetryToggle"
                                  IsOn="{x:Bind ViewModel.MicrophoneTelemetry, Mode=TwoWay}"
                                  Toggled="MicrophoneTelemetryToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard Header="Latency"
                                       Description="Record per-step timings of each transcription — voice detection, Whisper, rewrite, clipboard, paste — to latency.jsonl. Timings only, no transcript text."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE916;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.TelemetryLatencyEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <controls:SettingsExpander Header="Corpus"
                                           Description="Save every transcription as a JSONL line under a per-profile subfolder (one corpus.jsonl per rewrite profile). Text only — for offline prompt tuning and analysis."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xEFA9;}">
                    <ToggleSwitch x:Name="CorpusLoggingToggle"
                                  IsOn="{x:Bind ViewModel.TelemetryCorpusEnabled, Mode=TwoWay}"
                                  Toggled="CorpusLoggingToggle_Toggled" />
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard x:Name="AudioCorpusCard"
                                               Header="Also save audio (WAV)"
                                               Description="Keep the raw 16 kHz mono audio of each recording alongside the JSONL, in an audio/ subfolder per profile. Roughly 2 MB per minute of speech."
                                               IsEnabled="{x:Bind ViewModel.TelemetryCorpusEnabled, Mode=OneWay}">
                            <ToggleSwitch x:Name="AudioCorpusToggle"
                                          IsOn="{x:Bind ViewModel.RecordAudioCorpus, Mode=TwoWay}"
                                          Toggled="AudioCorpusToggle_Toggled" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <controls:SettingsCard Header="Application log"
                                       Description="Mirror every in-app log line to app.jsonl to diagnose a specific issue across restarts. Verbose — around 2 MB per 30 min of active use. Rotates every 5000 lines (app-1.jsonl, app-2.jsonl, …)."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9A4;}">
                    <ToggleSwitch x:Name="ApplicationLogToggle"
                                  IsOn="{x:Bind ViewModel.ApplicationLogToDisk, Mode=TwoWay}"
                                  Toggled="ApplicationLogToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="TelemetryFolderCard"
                                       ContentAlignment="Vertical"
                                       Header="Storage folder"
                                       Description="Shared root for every telemetry stream enabled above. Leave empty to use the default benchmark\telemetry\ folder next to the application.">
                    <!-- Grid + "*" column lets the TextBox shrink when the
                         Settings window is narrow. A StackPanel Horizontal
                         would keep children at their natural width and
                         clip the rightmost buttons. -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TelemetryFolderBox"
                                 Grid.Column="0"
                                 Text="{x:Bind ViewModel.TelemetryStorageDirectory, Mode=TwoWay}" />
                        <Button x:Name="ChangeTelemetryFolderButton"
                                Grid.Column="1"
                                Click="ChangeCorpusFolderButton_Click"
                                ToolTipService.ToolTip="Pick a folder">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE838;" FontSize="14" />
                                <TextBlock Text="Set" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="OpenTelemetryFolderButton"
                                Grid.Column="2"
                                Click="OpenCorpusFolderButton_Click"
                                ToolTipService.ToolTip="Open in File Explorer">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Open" />
                                <FontIcon Glyph="&#xE8A7;" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </controls:SettingsCard>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
