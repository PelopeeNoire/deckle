<UserControl
    x:Class="WhispUI.Settings.Llm.LlmRulesSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:WhispUI.Settings.ViewModels">

    <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
        <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                   Text="Auto-rewrite rules" />

        <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="1,0,0,8"
                   Text="When you use the plain transcription shortcut (Alt+`), recordings longer than a threshold are automatically rewritten. Rules are listed from shortest to longest — evaluation picks the longest matching threshold first." />

        <ItemsRepeater ItemsSource="{x:Bind Rules}">
            <ItemsRepeater.Layout>
                <StackLayout Spacing="4" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="vm:RuleViewModel">
                    <controls:SettingsCard
                        Header="{x:Bind ProfileName, Mode=OneWay}"
                        Description="{x:Bind Description, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <NumberBox Minimum="0" Maximum="600"
                                       SmallChange="5" LargeChange="30"
                                       SpinButtonPlacementMode="Compact"
                                       Value="{x:Bind MinDurationSeconds, Mode=TwoWay}"
                                       MinWidth="100" />
                            <TextBlock Text="s"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox MinWidth="160"
                                      Tag="{x:Bind}"
                                      Loaded="ProfileCombo_Loaded"
                                      SelectionChanged="ProfileCombo_SelectionChanged" />
                            <Button Tag="{x:Bind}"
                                    Click="DeleteRule_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    <TextBlock Text="Remove" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </controls:SettingsCard>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <Button Content="Add rule"
                Click="AddRule_Click"
                Margin="0,4,0,0" />
    </StackPanel>
</UserControl>
