<Window
    x:Class="WhispUI.HudWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WhispUI.Controls">
    <!-- Root is transparent: each hosted UserControl draws its own card
         surface (HudChrono = 314x78, HudMessage = 272x78 centered in a
         400x160 window). The card backing therefore matches whichever
         control is active, leaving the surrounding margin transparent
         for the Composition halo+drop shadow to bleed into during the
         message Full phase. -->
    <Grid x:Name="RootGrid">
        <controls:HudChrono  x:Name="Chrono"  Visibility="Visible" />
        <controls:HudMessage x:Name="Message" Visibility="Collapsed" />
    </Grid>
</Window>
