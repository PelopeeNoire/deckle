<Window
    x:Class="WhispUI.PlaygroundWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WhispUI.Controls"
    Title="WhispUI Playground">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <!-- Pattern canonique Microsoft Learn (SettingsExpander sample
                 "Settings page example"): same spacing + section header style
                 as GeneralPage so the playground scans like a Settings page. -->
            <x:Double x:Key="SettingsCardSpacing">4</x:Double>
            <Style x:Key="SettingsSectionHeaderTextBlockStyle"
                   BasedOn="{StaticResource BodyStrongTextBlockStyle}"
                   TargetType="TextBlock">
                <Style.Setters>
                    <Setter Property="Margin" Value="1,30,0,6" />
                </Style.Setters>
            </Style>
        </Grid.Resources>

        <!-- Native TitleBar: icon + title. Matches SettingsWindow / LogWindow.
             ImageIconSource rebuilt wholesale on recording state change (in-
             place ImageSource mutation doesn't propagate visually). -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="WhispUI Playground">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Main content: 2-column split.
               Col 0: NavigationView + tuning panel for the selected concept.
               Col 1: sticky preview (target selector + play/pause + HUD).

             Sticky preview is always visible so sliders on any concept page
             can be tuned against a live brush. 440 dip accommodates the 300×
             300 naked preview host + breathing room. -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="460" />
                <ColumnDefinition Width="440" />
            </Grid.ColumnDefinitions>

            <!-- ── Left: NavigationView + concept panel ─────────────────── -->
            <NavigationView Grid.Column="0"
                            x:Name="Nav"
                            IsBackButtonVisible="Collapsed"
                            IsSettingsVisible="False"
                            PaneDisplayMode="Left"
                            IsPaneToggleButtonVisible="False"
                            SelectionChanged="OnNavSelectionChanged">
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Palette"           Tag="palette" />
                    <NavigationViewItem Content="Hue rotation"      Tag="hue" />
                    <NavigationViewItem Content="Arc rotation"      Tag="arc" />
                    <NavigationViewItem Content="Swipe"             Tag="swipe" />
                    <NavigationViewItem Content="Recording"         Tag="recording" />
                    <NavigationViewItem Content="Transcribing"      Tag="transcribing" />
                    <NavigationViewItem Content="Rewriting"         Tag="rewriting" />
                    <NavigationViewItem Content="Audio mapping"     Tag="audio" />
                    <NavigationViewItem Content="Simulated RMS"     Tag="rms" />
                    <NavigationViewItem Content="Parked"            Tag="parked" />
                </NavigationView.MenuItems>

                <!-- Each concept panel is built once in code-behind and swapped
                     into this presenter on nav selection (no Page files — the
                     panels are pure StackPanels of Slider/NumberBox rows). -->
                <ScrollViewer x:Name="ConceptScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="32,24,32,24">
                    <ContentPresenter x:Name="ConceptHost"
                                      HorizontalAlignment="Stretch" />
                </ScrollViewer>
            </NavigationView>

            <!-- ── Right: sticky preview ────────────────────────────────── -->
            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Target selector: 7 preview targets (4 HUD states + 3
                         naked diagnostic masks). Centered so the chrono
                         visual below reads on-axis. Scroll-enabled
                         horizontally because 7 items overflow 440 dip at
                         standard DPI. -->
                    <ScrollViewer Grid.Row="0"
                                  HorizontalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="16,24,16,8">
                        <SelectorBar x:Name="TargetSelector"
                                     HorizontalAlignment="Center"
                                     SelectionChanged="OnTargetSelectionChanged">
                            <SelectorBarItem x:Name="TabCharging"     Text="Charging" />
                            <SelectorBarItem x:Name="TabRecording"    Text="Recording" />
                            <SelectorBarItem x:Name="TabTranscribing" Text="Transcribing" IsSelected="True" />
                            <SelectorBarItem x:Name="TabRewriting"    Text="Rewriting" />
                            <SelectorBarItem x:Name="TabConic"        Text="Conic" />
                            <SelectorBarItem x:Name="TabArcMask"      Text="ArcMask" />
                            <SelectorBarItem x:Name="TabCombined"     Text="Combined" />
                        </SelectorBar>
                    </ScrollViewer>

                    <!-- Play/Pause as two mutually-exclusive RadioButton via
                         RadioButtons compound. A label-swap ToggleButton
                         reads its own state ("Playing" / "Paused") which is
                         a UX trap — Louis's rule: a button label names the
                         action it triggers, not the current state. Two
                         buttons, two actions, one selected at a time. -->
                    <RadioButtons Grid.Row="1"
                                  x:Name="PlayPauseGroup"
                                  SelectedIndex="0"
                                  SelectionChanged="OnPlayPauseSelectionChanged"
                                  MaxColumns="2"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,12">
                        <RadioButton Content="Play" />
                        <RadioButton Content="Pause" />
                    </RadioButtons>

                    <!-- Preview surface. HudChrono 272×78 layered over an
                         invisible 300×300 naked host; exactly one is visible
                         at a time (see ApplyTarget). Border gives both a
                         shared Layer substrate so the naked masks read
                         against the same neutral as the HUD card. -->
                    <Border Grid.Row="2"
                            Padding="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            Margin="24">
                        <Grid HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <controls:HudChrono x:Name="ChronoPreview"
                                                Width="272"
                                                Height="78" />
                            <Grid x:Name="NakedPreviewHost"
                                  Width="300"
                                  Height="300"
                                  Visibility="Collapsed">
                                <!-- 272×78 reference outline shows where the
                                     HUD silhouette would fall, so naked masks
                                     can be read against the HUD aperture
                                     the shipping stroke would otherwise
                                     clip. -->
                                <Border Width="272" Height="78"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
