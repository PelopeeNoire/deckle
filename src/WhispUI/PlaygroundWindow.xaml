<Window
    x:Class="WhispUI.PlaygroundWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WhispUI.Controls"
    xmlns:playground="using:WhispUI.Playground"
    Title="WhispUI Playground">

    <!-- RootGrid is hit-testable (Background="Transparent") + focusable
         (IsTabStop) so a tap on empty space can dismiss the focus from a
         NumberBox. Focused input controls in WinUI 3 don't release on
         background click unless something else takes focus — handler
         wired in code-behind. -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          IsTabStop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native TitleBar: icon + title. Matches SettingsWindow / LogWindow.
             ImageIconSource rebuilt wholesale on recording state change. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="WhispUI Playground">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Main content: two panels + draggable sash.
               Col 0 (PreviewCol): sticky preview — target SelectorBar + Play/
                                   Pause + HudChrono / naked host.
               Col 1:              sash (6 dp Thumb with divider-colour fill).
               Col 2 (TuningCol):  single scrollable column of Expanders, one
                                   per concept. Everything fixed and always
                                   visible — no concept-level tabs.

             Both outer columns are pixel-width (not star) so the sash drag
             can mutate PreviewCol.Width directly. The tuning column absorbs
             the remainder (min 360 dip so the slider label + NumberBox
             column survive a narrow window). -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PreviewCol" Width="520" MinWidth="400" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="TuningCol"  Width="*"   MinWidth="360" />
            </Grid.ColumnDefinitions>

            <!-- ── Col 0 — sticky preview ───────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 7 targets: 4 HUD states + 3 naked diagnostic masks.
                     Horizontal scroll when the column is narrowed below the
                     natural SelectorBar width. -->
                <ScrollViewer Grid.Row="0"
                              HorizontalScrollMode="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              Padding="16,24,16,8">
                    <SelectorBar x:Name="TargetSelector"
                                 HorizontalAlignment="Center"
                                 SelectionChanged="OnTargetSelectionChanged">
                        <SelectorBarItem x:Name="TabCharging"     Text="Charging" />
                        <SelectorBarItem x:Name="TabRecording"    Text="Recording" />
                        <SelectorBarItem x:Name="TabTranscribing" Text="Transcribing" IsSelected="True" />
                        <SelectorBarItem x:Name="TabRewriting"    Text="Rewriting" />
                        <SelectorBarItem x:Name="TabConic"        Text="Conic" />
                        <SelectorBarItem x:Name="TabArcMask"      Text="ArcMask" />
                        <SelectorBarItem x:Name="TabCombined"     Text="Combined" />
                    </SelectorBar>
                </ScrollViewer>

                <!-- Play / Pause = two mutually-exclusive RadioButton. Button
                     labels name the action triggered, not the current state —
                     a label-swap ToggleButton (Playing / Paused) is a UX
                     trap Louis wants to avoid. -->
                <RadioButtons Grid.Row="1"
                              x:Name="PlayPauseGroup"
                              SelectedIndex="0"
                              SelectionChanged="OnPlayPauseSelectionChanged"
                              MaxColumns="2"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,12">
                    <RadioButton Content="Play" />
                    <RadioButton Content="Pause" />
                </RadioButtons>

                <!-- Preview surface. HudChrono 272×78 and the naked 300×300
                     host share the same substrate Border so all targets
                     read against identical Layer fill. On Pause BOTH are
                     collapsed so the preview area goes empty — no residual
                     Charging silhouette. -->
                <Border Grid.Row="2"
                        Padding="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Margin="24">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <controls:HudChrono x:Name="ChronoPreview"
                                            Width="272"
                                            Height="78" />
                        <Grid x:Name="NakedPreviewHost"
                              Width="300"
                              Height="300"
                              Visibility="Collapsed">
                            <Border Width="272" Height="78"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Col 1 — resize sash ──────────────────────────────────── -->
            <!-- SashThumb: Thumb subclass that sets ProtectedCursor to
                 SizeWestEast so hovering the 6 dp divider shows the
                 horizontal-resize cursor (universal "drag me" affordance).
                 DragDelta in the code-behind adjusts PreviewCol.Width
                 within the clamp imposed by PreviewCol.MinWidth and
                 TuningCol.MinWidth. -->
            <playground:SashThumb Grid.Column="1"
                                  x:Name="Sash"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  DragDelta="OnSashDragDelta">
                <playground:SashThumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    </ControlTemplate>
                </playground:SashThumb.Template>
            </playground:SashThumb>

            <!-- ── Col 2 — tuning Expanders ─────────────────────────────── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24">
                <StackPanel x:Name="TuningStack" Spacing="6">
                    <TextBlock Text="Tunables"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               Margin="0,0,0,8" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
