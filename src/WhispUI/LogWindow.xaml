<Window
    x:Class="WhispUI.LogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:WhispUI"
    Title="WhispUI Logs">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <!-- Semantic Fluent blue for Info — not the system accent
                         which may be grey / non-blue on the user's machine. -->
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="LogInfoBrush" Color="#005FB7" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="LogInfoBrush" Color="#60CDFF" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>

                <!-- 5 templates per wrap dimension, swapped via DataTemplateSelector
                     on Wrap toggle. Each template binds its Foreground to a
                     ThemeResource: WinUI re-resolves automatically on theme
                     switch, no need to rebuild entries in code. -->
                <DataTemplate x:Key="NoWrap_Verbose">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Info">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource LogInfoBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Step">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Warning">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Error">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>

                <DataTemplate x:Key="Wrap_Verbose">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Info">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource LogInfoBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Step">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Warning">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Error">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>

                <local:LogLevelTemplateSelector x:Key="NoWrapSelector"
                    Verbose="{StaticResource NoWrap_Verbose}"
                    Info="{StaticResource NoWrap_Info}"
                    Step="{StaticResource NoWrap_Step}"
                    Warning="{StaticResource NoWrap_Warning}"
                    Error="{StaticResource NoWrap_Error}" />
                <local:LogLevelTemplateSelector x:Key="WrapSelector"
                    Verbose="{StaticResource Wrap_Verbose}"
                    Info="{StaticResource Wrap_Info}"
                    Step="{StaticResource Wrap_Step}"
                    Warning="{StaticResource Wrap_Warning}"
                    Error="{StaticResource Wrap_Error}" />

                <!-- Compact container for dense log rendering: reduced padding,
                     hover highlight preserved (signals click-to-copy). -->
                <Style x:Key="LogItemContainerStyle" TargetType="ListViewItem">
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Padding" Value="4,1" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ResourceDictionary>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Native title bar (Windows App SDK 1.6+) ────────────────────── -->
        <!-- The TitleBar control handles drag region, themed caption buttons,
             height, and exposes a Content slot where we place the SearchBox. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="WhispUI Logs">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <!-- Single AutoSuggestBox. The TitleBar prioritizes its Content
                     width vs caption buttons, and the AutoSuggestBox shrinks
                     naturally down to MinWidth. No custom icon/field swap
                     — Win11 Settings pattern. -->
                <AutoSuggestBox x:Name="SearchBox"
                                QueryIcon="Find"
                                PlaceholderText="Search logs"
                                MinWidth="140"
                                MaxWidth="760"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                TextChanged="OnSearchTextChanged" />
            </TitleBar.Content>
        </TitleBar>

        <!-- ── Command bar: level selector + actions ─────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:SelectorBar Grid.Column="0"
                                  x:Name="LevelSelector"
                                  Margin="4,0,0,0"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnLevelSelectorChanged">
                <controls:SelectorBarItem x:Name="LevelFull" Text="All" />
                <controls:SelectorBarItem x:Name="LevelFiltered" Text="Activity" />
                <controls:SelectorBarItem x:Name="LevelCritical" Text="Errors" />
            </controls:SelectorBar>

            <!-- Native overflow via IsDynamicOverflowEnabled (true by default)
                 + DynamicOverflowOrder. Higher = migrates first.
                 Group 2 (Copy/Save/Clear/Sep) goes first, then group 1
                 (AutoScroll/Wrap). The CommandBar handles measure, popup
                 and placement itself. -->
            <CommandBar Grid.Column="1"
                        x:Name="MainCommandBar"
                        DefaultLabelPosition="Right"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        IsOpen="False">
                <AppBarButton x:Name="CopyButton" Label="Copy"
                              Click="OnCopyClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8C8;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="SaveButton" Label="Save"
                              Click="OnSaveClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74E;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="ClearButton" Label="Clear"
                              Click="OnClearClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74D;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <CommandBar.SecondaryCommands>
                    <AppBarToggleButton x:Name="AutoScrollToggle"
                                        Label="Auto-scroll"
                                        IsChecked="True">
                        <AppBarToggleButton.Icon>
                            <FontIcon Glyph="&#xEC8F;" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                    <AppBarToggleButton x:Name="WrapToggle"
                                        Label="Word wrap"
                                        IsChecked="False"
                                        Click="OnWrapToggleClick">
                        <AppBarToggleButton.Icon>
                            <FontIcon Glyph="&#xE751;" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Grid>

        <!-- ── Log surface ────────────────────────────────────────────────── -->
        <!-- Native ListView: virtualization, built-in scroll, ItemTemplateSelector
             honored. Left click = copy line, right click = native MenuFlyout.
             Floating "Copy" badge positioned to the right of the hovered item. -->
        <Grid Grid.Row="2" x:Name="LogSurface">
            <ListView x:Name="LogItems"
                      Background="{ThemeResource LayerFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,1,0,0"
                      Padding="12,4"
                      ItemContainerStyle="{StaticResource LogItemContainerStyle}"
                      ItemTemplateSelector="{StaticResource NoWrapSelector}"
                      SelectionMode="Extended"
                      IsItemClickEnabled="False"
                      PointerMoved="OnLogPointerMoved"
                      PointerExited="OnLogPointerExited"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto" />

            <!-- Floating "Copy" / "Copy selection" badge — positioned by code
                 to the right of the hovered item. Fully opaque background
                 (SolidBackgroundFillBase) to completely mask the text and
                 selection highlight underneath. IsHitTestVisible=False to
                 let clicks pass through to the ListView. -->
            <Border x:Name="CopyBadge"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Canvas.ZIndex="1"
                    Padding="8,2"
                    Margin="0,0,18,0"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="CopyBadgeTransform" />
                </Border.RenderTransform>
                <TextBlock x:Name="CopyBadgeText"
                           Text="Copy"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
        </Grid>
    </Grid>
</Window>
