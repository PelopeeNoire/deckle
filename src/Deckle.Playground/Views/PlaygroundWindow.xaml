<!-- Playground window shell. Native TitleBar (icon + title), Mica
     backdrop, NavigationView Auto with three menu items, Frame holding
     the active Page. Each NavigationViewItem.Tag carries the
     fully-qualified type name of the Page to navigate to ; the
     code-behind resolves it via Type.GetType and calls
     PageFrame.Navigate. Same pattern as SettingsWindow. -->
<Window
    x:Class="Deckle.Playground.PlaygroundWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Deckle Playground">

    <!-- RootGrid is hit-testable (Background="Transparent") + focusable
         (IsTabStop) so a tap on empty space can dismiss the focus from a
         NumberBox. Focused input controls in WinUI 3 don't release on
         background click unless something else takes focus — handler
         wired in code-behind, filtered on OriginalSource==RootGrid to
         avoid stealing focus from inside buttons / dropdowns / combo
         flyouts during their first click. -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          IsTabStop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native TitleBar : icon + title. Rebuilt wholesale on
             SetRecordingState() so the recording-state icon swap
             propagates to the TitleBar visual. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  x:Uid="PlaygroundTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- NavigationView LeftCompact + IsPaneOpen=False : the pane
             starts collapsed (48 dip strip) and the user expands it
             only when they want to read the labels. Three items, the
             icons are enough at a glance, no need to dedicate 240 dip
             to a permanently-open pane. Tag = fully-qualified Page
             type name, resolved by Type.GetType in OnNavSelectionChanged. -->
        <NavigationView Grid.Row="1"
                        x:Name="Nav"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneOpen="False"
                        PaneDisplayMode="LeftCompact"
                        SelectionChanged="OnNavSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="PlaygroundNavHome"
                                    Tag="Deckle.Playground.HomePage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Home}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="PlaygroundNavHud"
                                    Tag="Deckle.Playground.HudPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Speaker}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="PlaygroundNavAmbient"
                                    Tag="Deckle.Playground.AmbientPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Lightbulb}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="PageFrame" />
        </NavigationView>
    </Grid>
</Window>
