<Window
    x:Class="Deckle.Playground.PlaygroundWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chrono="using:Deckle.Chrono.Hud"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:ambientControls="using:Deckle.Lighting.Ambient.Controls"
    Title="Deckle Playground">

    <!-- RootGrid is hit-testable (Background="Transparent") + focusable
         (IsTabStop) so a tap on empty space can dismiss the focus from a
         NumberBox. Focused input controls in WinUI 3 don't release on
         background click unless something else takes focus — handler
         wired in code-behind. -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          IsTabStop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native TitleBar: icon + title. Matches SettingsWindow / LogWindow.
             ImageIconSource rebuilt wholesale on recording state change. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="Deckle Playground">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Top-level navigation. Same pattern as SettingsWindow — Auto
             pane mode (Left ≥1008, LeftCompact 640-1008, Minimal <640),
             back button + system Settings entry suppressed. Two sections:
                 • HUD            — existing two-column layout (preview +
                                    tuning) ; selected by default.
                 • Ambient light  — full-width page for the screen capture
                                    pipeline + Hue driver + visualisations.
             Pages are inline (Visibility toggle), not Frame-navigated —
             both surfaces are small enough that loading them lazily would
             add complexity without payoff. -->
        <NavigationView Grid.Row="1"
                        x:Name="PlaygroundNav"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneOpen="False"
                        PaneDisplayMode="LeftCompact"
                        SelectionChanged="OnPlaygroundNavSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavItemHome"
                                    Content="Home"
                                    Tag="home"
                                    IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Home}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavItemHud"
                                    Content="HUD"
                                    Tag="hud">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Speaker}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavItemAmbient"
                                    Content="Ambient lighting"
                                    Tag="ambient">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="{StaticResource Icon.Lightbulb}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid x:Name="PageContent">

                <!-- ── Home page ─────────────────────────────────────────
                     Minimal landing surface : a short hello and a stack
                     of full-width SettingsCard rows pointing at the two
                     other Playground sections. SettingsCard reuses the
                     canonical Windows 11 pattern (icon + header +
                     description + action chevron) and adapts the layout
                     gracefully on narrow widths, instead of fighting
                     viewport size like a fixed-width horizontal pair. -->
                <ScrollViewer x:Name="HomePage"
                              Visibility="Visible"
                              HorizontalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          MaxWidth="720"
                          Margin="32,48,32,32">
                        <StackPanel Spacing="32">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Deckle Playground"
                                           Style="{ThemeResource TitleTextBlockStyle}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Tuning surface for the running pipelines. Pick a section below to start adjusting — values apply live, no restart needed."
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           MaxWidth="560"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <controls:SettingsCard x:Name="HomeHudCard"
                                                       Header="HUD stroke"
                                                       Description="Tune the conic gradient stroke that wraps the chrono. Colour, easing, arc fade, per-state variants."
                                                       HeaderIcon="{ui:FontIcon Glyph={StaticResource Icon.Speaker}}"
                                                       IsClickEnabled="True"
                                                       Click="OnHomeHudCardClick" />
                                <controls:SettingsCard x:Name="HomeAmbientCard"
                                                       Header="Ambient lighting"
                                                       Description="Screen capture, zone sampling, colour processing, Hue REST output. Live preview + per-light swatches."
                                                       HeaderIcon="{ui:FontIcon Glyph={StaticResource Icon.Lightbulb}}"
                                                       IsClickEnabled="True"
                                                       Click="OnHomeAmbientCardClick" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- ── HUD page ──────────────────────────────────────────
                     Existing two-column layout: preview (Col 0) + tuning
                     panel (Col 1). Unchanged from the J0 Playground ; the
                     SelectorBar inside Col 0 still picks the HUD target,
                     and the tuning Expanders in Col 1 still drive the
                     in-memory _tuning state.

                     Col 0 (preview): Width="*" — grows with the window,
                                      absorbs extra horizontal space.
                                      MinWidth=720 so the 7-tab SelectorBar
                                      fits without horizontal scroll.
                                      Preview content centered so HudChrono
                                      stays centered as the column widens.
                     Col 1 (tuning):  Width="Auto" — desired width reported
                                      by the inner ScrollViewer, capped at
                                      MaxWidth=920 (≥900 wastes whitespace,
                                      ≤700 cramps). Col 0 picks up the
                                      slack past the cap. -->
                <Grid x:Name="HudPage" Visibility="Collapsed">
                    <!-- Col 0 has no MinWidth so the preview/cards stage
                         shrinks aggressively when the window narrows ;
                         Tunables (Col 1) keeps its 480-920 dip envelope.
                         Result : the right column stays readable, the
                         preview can collapse down to the HudChrono's
                         272 dip footprint without pushing Tunables
                         off-screen. -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="320" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

            <!-- ── Col 0 — preview (grows, content centered) ───────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Two sections, left-aligned with a small caption above
                     each : "States" (the 4 HUD states that drive the
                     chrono visual) and "Primitive" (the 3 naked masks
                     used for diagnostic inspection). Replaces a flat
                     7-cell strip — the user reads the picker as two
                     distinct concepts instead of an unordered list.
                     Each ItemsRepeater keeps the UniformGridLayout +
                     ToggleButton template from the previous pass so the
                     mutual-exclusion / Target dispatch code-behind
                     keeps working unchanged (OnTargetCardPrepared
                     handles both repeaters' cells). -->
                <StackPanel Grid.Row="0"
                            Spacing="6"
                            HorizontalAlignment="Stretch"
                            Margin="24,24,24,8">
                    <TextBlock Text="States"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Left" />
                    <ItemsRepeater x:Name="TargetStatesRepeater"
                                   ElementPrepared="OnTargetCardPrepared">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="160"
                                               MinItemHeight="44"
                                               MinColumnSpacing="8"
                                               MinRowSpacing="8"
                                               ItemsStretch="None"
                                               ItemsJustification="Start"
                                               Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <ToggleButton Content="{x:Bind}"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Center"
                                              MinHeight="44" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <TextBlock Text="Primitive"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Left"
                               Margin="0,8,0,0" />
                    <ItemsRepeater x:Name="TargetPrimitivesRepeater"
                                   ElementPrepared="OnTargetCardPrepared">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="160"
                                               MinItemHeight="44"
                                               MinColumnSpacing="8"
                                               MinRowSpacing="8"
                                               ItemsStretch="None"
                                               ItemsJustification="Start"
                                               Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <ToggleButton Content="{x:Bind}"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Center"
                                              MinHeight="44" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Play / Pause = single toggle Button with a swapping
                     SymbolIcon. Pattern Microsoft Fluent transport
                     control + NN/G state-switch guidance combined :
                     the icon (and the tooltip / accessible name) names
                     the ACTION the next click will perform, not the
                     current state — paused screens show a Play glyph
                     ("press this to play"), playing screens show a
                     Pause glyph ("press this to pause"). One glyph,
                     one affordance, no "label-swap" trap.
                     References : NN/G "State-Switch Controls" and
                     Microsoft Learn AppBarButton / MediaTransportControls
                     play-pause guidance. -->
                <Button Grid.Row="1"
                        x:Name="PlayPauseButton"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,12"
                        MinWidth="120"
                        Click="OnPlayPauseClick"
                        ToolTipService.ToolTip="Play">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="PlayPauseIcon"
                                  Glyph="{StaticResource Icon.Transport.Play}"
                                  FontSize="14" />
                        <TextBlock x:Name="PlayPauseLabel"
                                   Text="Play" />
                    </StackPanel>
                </Button>

                <!-- Preview surface. The Border is the "playground stage":
                     stretches horizontally to fill Col 0 (width matches
                     the SelectorBar / Play-Pause area above) and fills
                     the remainder of the column vertically, so the
                     whole region below the controls reads as one
                     substrate. HudChrono 272×78 and the naked 300×300
                     host are fixed-size and centered inside the
                     stretching stage — the animation never resizes,
                     only the background does. On Pause BOTH are
                     collapsed so the preview area goes empty — no
                     residual Charging silhouette. -->
                <Border Grid.Row="2"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Margin="24">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <chrono:HudChrono   x:Name="ChronoPreview"
                                            Width="272"
                                            Height="78" />
                        <Grid x:Name="NakedPreviewHost"
                              Width="300"
                              Height="300"
                              Visibility="Collapsed">
                            <Border Width="272" Height="78"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Col 1 — tuning Expanders ─────────────────────────────── -->
            <!--
                Header row above the Expanders: "Tunables" title + a one-line
                description + "Reset all".

                The Playground is intentionally non-persistent. It reads its
                initial values from the running app's defaults, lets the user
                tune them in-memory for the current process, and writes
                nothing to disk. Every relaunch of Deckle returns to the
                compiled defaults — values that look right move into the code
                as the new defaults; the Playground's job is to find them,
                not to remember them.

                Reset all reverts every section to the shipping defaults for
                the current process — useful mid-session to start over.
            -->
            <!-- MinWidth=480 + MaxWidth=920 caps the tuning column between
                 two comfortable sizes: narrow enough to stay legible on
                 a smallest-allowed 1200-wide window, wide enough that the
                 title + description + "Reset all" breathe and the
                 slider+NumberBox pairs don't crowd. Anything wider is
                 wasted whitespace; Col 0 absorbs the surplus instead. -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24"
                          MinWidth="480"
                          MaxWidth="920">
                <StackPanel x:Name="TuningStack" Spacing="6">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0"
                                   Text="Tunables"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   VerticalAlignment="Center" />

                        <!-- Reset all: mirrors the "Reset all" pattern in
                             Settings › Whisper — SubtleButtonStyle + FontIcon
                             E777 (refresh / circular arrow) + label. Always
                             enabled: the Playground keeps no dirty state, so
                             the button is just "snap back to defaults" with
                             no precondition. -->
                        <Button Grid.Column="1" Grid.Row="0"
                                x:Name="ResetAllButton"
                                Style="{ThemeResource SubtleButtonStyle}"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="Reset every section to the shipping defaults"
                                Click="OnResetAllClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="{StaticResource Icon.Reset}" FontSize="14" />
                                <TextBlock Text="Reset all" />
                            </StackPanel>
                        </Button>

                        <!-- Description sits under the title (spans both
                             columns) and tells the user the contract: this
                             is a scratchpad for the current session, nothing
                             is saved, restart resets everything.
                             CaptionTextBlockStyle + Secondary brush so it
                             reads as supporting info, not a primary
                             instruction.

                             MaxWidth=400 caps the natural measure so the
                             outer Grid's "Auto" column on the body cannot
                             grow past the header row's intrinsic width.
                             Without it, TextWrapping=Wrap reports an
                             unbounded natural width, the body Auto column
                             demands ~800 dip, and the tuning panel stops
                             responding to window shrinks. With the cap,
                             the natural width of the header is ~400 +
                             button + padding ≈ 530 dip, well under the
                             ScrollViewer's MaxWidth=920, so the column
                             negotiates normally. -->
                        <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Tweak values live for the current session — nothing is saved. Restart Deckle to reset to defaults."
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   HorizontalAlignment="Left"
                                   Margin="0,4,0,0" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
                </Grid>

                <!-- ── Ambient lighting page ─────────────────────────────
                     Two-column layout mirroring the HUD page convention :
                     preview on the left (the FrameSampler's grid of
                     averaged pixels, mirrors the source screen aspect),
                     controls on the right (Screen capture → Hue →
                     Pipeline, top-down) in a scrollable column.

                     Col 0 (preview) : Width="*" MinWidth=480 — grows
                                       with the window, absorbs the slack
                                       past the controls column cap.
                     Col 1 (controls): Width="Auto" MaxWidth=480 — capped
                                       so the cards stay readable without
                                       dominating wide windows. -->
                <Grid x:Name="AmbientPage" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="480" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Col 0 — preview stage. The toolbar of preview
                         options (Zones toggle + emitted-colour swatches
                         + Lights menu) lives ABOVE the preview frame —
                         mirrors the convention of the HUD page where
                         the State / Primitive picker + Play/Pause sit
                         on top of the preview substrate, not inside it.
                         The cadre below is purely the visual stage. -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <!-- Row 0 : preview options bar. Always
                                 visible (lives outside the preview
                                 frame), so the user can toggle zones /
                                 individual lights even when the
                                 pipeline is off. -->
                            <RowDefinition Height="Auto" />
                            <!-- Row 1 : the preview frame itself,
                                 housing the empty state + Viewbox. -->
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="32,24,16,12"
                                    VerticalAlignment="Center">
                            <!-- Compact ToggleButton, not a ToggleSwitch :
                                 the label stays the static word "Zones"
                                 regardless of state, the checked /
                                 unchecked visual carries the on / off
                                 signal. No leading icon — Louis tested
                                 it and reads cleaner as a plain text
                                 toggle in this dense toolbar. -->
                            <ToggleButton x:Name="ShowZoneOverlaysToggle"
                                          Content="Zones"
                                          MinWidth="0"
                                          IsChecked="True"
                                          Checked="OnShowZoneOverlaysToggled"
                                          Unchecked="OnShowZoneOverlaysToggled"
                                          ToolTipService.ToolTip="Toggle the light-zone overlay on the preview" />

                            <!-- Emitted-colour swatches : square chips
                                 sized to match the toggle's MinHeight
                                 with the same ControlCornerRadius so
                                 they sit as siblings of the button on
                                 the toolbar baseline. No labels under
                                 the squares — each chip carries a
                                 native ToolTip with its fixture name
                                 (built in code-behind, BuildSwatch),
                                 so hover surfaces "which light is this
                                 colour?" without extra controls. -->
                            <StackPanel x:Name="EmittedSwatches"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center" />

                        </StackPanel>

                        <!-- Preview cadre. LayerFill so it reads as a
                             recessed stage. The empty-state stack
                             panel is shown until the pipeline runs ;
                             AmbientPreviewGrid is built and populated
                             in code-behind once the sampler reports
                             its dimensions. -->
                        <Border Grid.Row="1"
                                x:Name="AmbientPreviewBorder"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                Margin="32,0,16,32"
                                Padding="24">
                            <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                                <StackPanel x:Name="AmbientPreviewEmptyState"
                                            Spacing="8"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Capture preview"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Start the pipeline to see the sampled grid of pixels mirroring the screen."
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="440"
                                               TextAlignment="Center" />
                                </StackPanel>

                                <!-- Viewbox wraps the preview grid so the
                                     whole pixel composition scales
                                     uniformly to fill the available area.
                                     The grid keeps a fixed coordinate
                                     space built dynamically in code-behind
                                     from the FrameSampler's dimensions ×
                                     CellSize. Cells are laid out flush
                                     (no margins) so no gap is "visually
                                     thickened" by the Viewbox scale —
                                     gaps that scale read as garbage at
                                     wide windows and disappear at narrow
                                     ones. -->
                                <Viewbox x:Name="AmbientPreviewViewbox"
                                         Stretch="Uniform"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Visibility="Collapsed">
                                    <Grid x:Name="AmbientPreviewGrid" />
                                </Viewbox>

                                <!-- LightZonesOverlay is a sibling of the
                                     Viewbox, not a child : its Stretch=
                                     Uniform parent would scale every
                                     stroke and rectangle dimension with
                                     the window size, which made the
                                     overlay look "broken" on wide
                                     windows. Sized + positioned in
                                     code-behind on the Viewbox's
                                     SizeChanged so it lines up exactly
                                     with the displayed (scaled) grid
                                     footprint. Centered alignment
                                     matches Stretch=Uniform's default
                                     centering. -->
                                <Canvas x:Name="LightZonesOverlay"
                                        IsHitTestVisible="False"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Rectangle x:Name="ZoneTopRect"    Visibility="Collapsed" />
                                    <Rectangle x:Name="ZoneBottomRect" Visibility="Collapsed" />
                                    <Rectangle x:Name="ZoneLeftRect"   Visibility="Collapsed" />
                                    <Rectangle x:Name="ZoneRightRect"  Visibility="Collapsed" />
                                </Canvas>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Col 1 — controls. ScrollViewer keeps the cards
                         reachable on short windows ; MaxWidth caps the
                         column so the preview absorbs the slack at
                         wide widths. Order is Screen capture → Hue →
                         Pipeline, top-down. -->
                    <ScrollViewer Grid.Column="1"
                                  MinWidth="380"
                                  MaxWidth="480"
                                  Padding="0,24,32,32"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="20">

                            <!-- Page title block. TitleLargeTextBlockStyle
                                 matches the H1 in Settings pages. -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Ambient lighting"
                                           Style="{ThemeResource TitleLargeTextBlockStyle}" />
                                <TextBlock Text="Screen capture, Hue bridge, and the analysis pipeline that pushes the averaged screen colour to your lights."
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- Pipeline card. End-to-end chain : Screen
                                 capture → FrameSampler → AmbientEngine
                                 → Hue driver. Start enabled only when
                                 both ends are ready (a group is
                                 selected so we have an ILightOutput to
                                 push to ; the capture service is
                                 created on-demand by the engine itself
                                 if not already running). The Pipeline
                                 mode RadioButtons let the user pick
                                 between a single average pushed to the
                                 group and per-zone sampling driven by
                                 the Light zones card below. -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Padding="24">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Pipeline (capture → analysis → lights)"
                                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                                        <TextBlock Text="Wires the screen capture to the selected Hue group via the AmbientEngine. Per-pixel analysis at 15 Hz (group) or 10 Hz (per-light zones)."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="640" />
                                    </StackPanel>

                                    <!-- Pipeline mode selector. Two
                                         mutually exclusive shapes for
                                         the AmbientEngine. RadioButtons
                                         per the settings-system-design
                                         doctrine : a choice between
                                         two named modes belongs to
                                         RadioButtons, not a Toggle —
                                         both alternatives are visible
                                         and named up front, no "on
                                         content / off content" text
                                         that shifts under the cursor.
                                         Reads / writes
                                         AmbientSettings.UseMultiLight ;
                                         disabled while the pipeline is
                                         running because the engine
                                         resolves the shape once at
                                         StartAsync. -->
                                    <RadioButtons x:Name="PipelineModeRadios"
                                                  Header="Pipeline mode"
                                                  SelectionChanged="OnPipelineModeSelectionChanged">
                                        <x:String>One colour pushed to the whole group</x:String>
                                        <x:String>One colour per border zone (top / bottom / left / right)</x:String>
                                    </RadioButtons>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="16"
                                                VerticalAlignment="Center">
                                        <Button x:Name="PipelineToggleButton"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                MinWidth="180"
                                                IsEnabled="False"
                                                Click="OnPipelineToggleClick">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon x:Name="PipelineToggleIcon"
                                                          Glyph="{StaticResource Icon.Transport.Play}"
                                                          FontSize="14" />
                                                <TextBlock x:Name="PipelineToggleLabel"
                                                           Text="Start pipeline" />
                                            </StackPanel>
                                        </Button>
                                        <Ellipse x:Name="PipelineStatusDot"
                                                 Width="10" Height="10"
                                                 Fill="{ThemeResource SystemFillColorNeutralBrush}"
                                                 VerticalAlignment="Center" />
                                        <TextBlock x:Name="PipelineStatusText"
                                                   Text="Pair a bridge and pick a group first"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Screen capture controls card. AccentButtonStyle
                                 on the toggle so the primary action reads at a
                                 glance ; the icon swaps Play (E768) ↔ Stop
                                 (E71A) on state change. The status dot uses
                                 SystemFillColor* theme brushes so it follows
                                 light/dark/contrast accent without manual
                                 colour management. -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Padding="24">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Screen capture"
                                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                                        <TextBlock Text="Pumps frames from the primary monitor through DXGI Output Duplication. Off by default ; click Start to begin."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="640" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="16"
                                                VerticalAlignment="Center">
                                        <Button x:Name="ScreenCaptureToggleButton"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                MinWidth="140"
                                                Click="OnScreenCaptureToggleClick">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon x:Name="ScreenCaptureToggleIcon"
                                                          Glyph="{StaticResource Icon.Transport.Play}"
                                                          FontSize="14" />
                                                <TextBlock x:Name="ScreenCaptureToggleLabel"
                                                           Text="Start" />
                                            </StackPanel>
                                        </Button>
                                        <Ellipse x:Name="ScreenCaptureStatusDot"
                                                 Width="10" Height="10"
                                                 Fill="{ThemeResource SystemFillColorNeutralBrush}"
                                                 VerticalAlignment="Center" />
                                        <TextBlock x:Name="ScreenCaptureStatusText"
                                                   Text="Stopped"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Metric pair. TitleTextBlockStyle on
                                         the value so the numbers are the
                                         visual anchor of the card. -->
                                    <Grid ColumnSpacing="48">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="2" MinWidth="160">
                                            <TextBlock Text="Frames captured"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock x:Name="ScreenCaptureFramesText"
                                                       Text="0"
                                                       Style="{ThemeResource TitleTextBlockStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="2" MinWidth="160">
                                            <TextBlock Text="FPS (1 s window)"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock x:Name="ScreenCaptureFpsText"
                                                       Text="—"
                                                       Style="{ThemeResource TitleTextBlockStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- HDR tuning (live) card. Same four user-tunable
                                 knobs as Settings → Ambient lighting, surfaced
                                 inline so the user can tune γ / exposure /
                                 saturation / min-brightness while a live
                                 preview grid runs next to them in this same
                                 window. Reads and writes the same
                                 AmbientSettings keys ; the engine hot-reloads
                                 every value at each push tick. The
                                 BrightnessCurveCanvas widget makes the gamma
                                 curve visible alongside the slider — γ is
                                 hard to intuit from a number alone. -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Padding="24">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="HDR tuning (live)"
                                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                                        <TextBlock Text="Tune the ambient knobs live with the preview grid right next to you. Values persist and apply on the next push tick. Touch any slider and the mode automatically switches to Custom — preset values won't overwrite your work."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="640" />
                                    </StackPanel>

                                    <!-- Mode preset selector. Picking
                                         Game / Movie / Ambient applies
                                         the matching AmbientModePresets
                                         snapshot onto every other knob ;
                                         Custom is a no-op marker that
                                         tracks the moment the user
                                         starts tuning by hand. -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Mode"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <ComboBox x:Name="PlaygroundAmbientModeCombo"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="OnPlaygroundAmbientModeChanged">
                                            <ComboBoxItem Content="Game" Tag="Game" />
                                            <ComboBoxItem Content="Movie" Tag="Movie" />
                                            <ComboBoxItem Content="Ambient" Tag="Ambient" />
                                            <ComboBoxItem Content="Custom" Tag="Custom" />
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Brightness curve : type selector
                                         + parameter slider. The visual
                                         preview canvas stays on the left,
                                         the type ComboBox + param slider
                                         on the right. The slider's
                                         interpretation depends on the
                                         selected type (Gamma exponent,
                                         SCurve steepness, ignored for
                                         Linear / Logarithmic). -->
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ambientControls:BrightnessCurveCanvas
                                            x:Name="PlaygroundGammaCanvas"
                                            Grid.Column="0"
                                            VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="6">
                                            <TextBlock Text="Brightness curve"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <ComboBox x:Name="PlaygroundBrightnessCurveCombo"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnPlaygroundBrightnessCurveTypeChanged">
                                                <ComboBoxItem Content="Linear (pass-through)" Tag="Linear" />
                                                <ComboBoxItem Content="Gamma (power law)" Tag="Gamma" />
                                                <ComboBoxItem Content="S-Curve (logistic)" Tag="SCurve" />
                                                <ComboBoxItem Content="Logarithmic" Tag="Logarithmic" />
                                            </ComboBox>
                                            <Grid x:Name="PlaygroundGammaSliderRow"
                                                  ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="PlaygroundGammaSlider"
                                                        Grid.Column="0"
                                                        StepFrequency="0.1"
                                                        SmallChange="0.1" LargeChange="0.5"
                                                        TickFrequency="0.5"
                                                        TickPlacement="Outside"
                                                        ValueChanged="OnPlaygroundGammaSliderChanged" />
                                                <TextBlock x:Name="PlaygroundGammaValueText"
                                                           Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           MinWidth="56"
                                                           TextAlignment="End" />
                                            </Grid>
                                            <TextBlock x:Name="PlaygroundGammaCaption"
                                                       Text="Power-law squash on the bottom of the bri range. Higher γ dims dim scenes harder without touching saturated highlights."
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Smoothing α — temporal EMA factor.
                                         1.0 disables smoothing, lower
                                         values damp small jitter. The
                                         caption is plain-language since
                                         "EMA factor" doesn't read on its
                                         own. -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Smoothing"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Range / Value seeded in code-behind
                                                 (InitPlaygroundAmbientTuning) because the
                                                 WinUI 3 Slider parser rejects a non-zero
                                                 Minimum when the default Value (0) sits
                                                 below it — same constraint as the gamma
                                                 slider above. -->
                                            <Slider x:Name="PlaygroundSmoothingSlider"
                                                    Grid.Column="0"
                                                    StepFrequency="0.05"
                                                    SmallChange="0.05" LargeChange="0.10"
                                                    TickFrequency="0.10"
                                                    TickPlacement="Outside"
                                                    ValueChanged="OnPlaygroundSmoothingSliderChanged" />
                                            <TextBlock x:Name="PlaygroundSmoothingValueText"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       MinWidth="56"
                                                       TextAlignment="End" />
                                        </Grid>
                                        <TextBlock Text="Damps frame-to-frame jitter from small moving reflections in a globally dark scene. 1.0 — instant response · 0.3 — moderate smoothing · 0.1 — heavy smoothing (cinematic)."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Change threshold — gate on the
                                         per-tick delta sum. 0 disables
                                         the gate (every tick pushes),
                                         higher values let smoothing
                                         absorb more before triggering
                                         a push. -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Change threshold"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="PlaygroundChangeThresholdSlider"
                                                    Grid.Column="0"
                                                    Minimum="0" Maximum="30"
                                                    StepFrequency="1"
                                                    SmallChange="1" LargeChange="5"
                                                    TickFrequency="5"
                                                    TickPlacement="Outside"
                                                    ValueChanged="OnPlaygroundChangeThresholdSliderChanged" />
                                            <TextBlock x:Name="PlaygroundChangeThresholdValueText"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       MinWidth="56"
                                                       TextAlignment="End" />
                                        </Grid>
                                        <TextBlock Text="Minimum |ΔR|+|ΔG|+|ΔB| across two ticks for a push to fire. Higher values mute residual jitter, lower values track every change."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Exposure (EV) — single slider row + caption. -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Exposure (EV)"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="PlaygroundExposureSlider"
                                                    Grid.Column="0"
                                                    Minimum="-2.0" Maximum="2.0"
                                                    StepFrequency="0.5"
                                                    SmallChange="0.5" LargeChange="1.0"
                                                    TickFrequency="0.5"
                                                    TickPlacement="Outside"
                                                    ValueChanged="OnPlaygroundExposureSliderChanged" />
                                            <TextBlock x:Name="PlaygroundExposureValueText"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       MinWidth="56"
                                                       TextAlignment="End" />
                                        </Grid>
                                        <TextBlock Text="Brightness bias in stops. +1 EV roughly doubles the lamp ; use it when HDR content tone-maps too dim."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Saturation — stored 0.0–2.0, displayed 0–200 %. -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Saturation"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="PlaygroundSaturationSlider"
                                                    Grid.Column="0"
                                                    Minimum="0" Maximum="200"
                                                    StepFrequency="10"
                                                    SmallChange="10" LargeChange="25"
                                                    TickFrequency="25"
                                                    TickPlacement="Outside"
                                                    ValueChanged="OnPlaygroundSaturationSliderChanged" />
                                            <TextBlock x:Name="PlaygroundSaturationValueText"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       MinWidth="56"
                                                       TextAlignment="End" />
                                        </Grid>
                                        <TextBlock Text="Chroma boost in OKLCh. 100% is neutral, 150–180% restores Hue Sync–like vividness after spatial averaging desaturates the frame."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Min brightness — bridge bri 0–254. -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Minimum brightness"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="PlaygroundMinBrightnessSlider"
                                                    Grid.Column="0"
                                                    Minimum="0" Maximum="254"
                                                    StepFrequency="5"
                                                    SmallChange="5" LargeChange="25"
                                                    TickFrequency="50"
                                                    TickPlacement="Outside"
                                                    ValueChanged="OnPlaygroundMinBrightnessSliderChanged" />
                                            <TextBlock x:Name="PlaygroundMinBrightnessValueText"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       MinWidth="56"
                                                       TextAlignment="End" />
                                        </Grid>
                                        <TextBlock Text="Floor on the bulb brightness when on. Stops the diffuser swallowing mid-tone scenes."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Hue (REST direct) card. J2 test surface for
                                 the bridge driver — Discover + Pair to start,
                                 List groups + Set colour land in follow-ups.
                                 Talks CLIP v1 directly to the bridge ; HA
                                 integration is deferred until Louis has a
                                 Raspberry Pi running it. -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Padding="24">
                                <StackPanel Spacing="20">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Hue (REST direct)"
                                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                                        <TextBlock Text="Talks straight to a Philips Hue bridge over its CLIP v1 REST API. No Home Assistant in the loop, no DTLS — capped at ~10-20 Hz but plenty for an ambient pipeline with smoothing on top."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="640" />
                                    </StackPanel>

                                    <!-- Bridge address row. Discover queries
                                         discovery.meethue.com and autofills
                                         the textbox ; manual entry is the
                                         fallback when the cloud lookup
                                         returns nothing (firewall, offline,
                                         etc.). -->
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="HueBridgeIpTextBox"
                                                 PlaceholderText="192.168.1.5"
                                                 Header="Bridge IP" />
                                        <Button Grid.Column="1"
                                                x:Name="HueDiscoverButton"
                                                VerticalAlignment="Bottom"
                                                Click="OnHueDiscoverClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="{StaticResource Icon.Search}" FontSize="14" />
                                                <TextBlock Text="Discover" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <!-- Pair row. Pressing the button starts
                                         a 30 s polling loop ; the user has
                                         to walk over and press the physical
                                         link button on top of the bridge.
                                         Status dot follows the same colour
                                         scheme as the Screen capture card. -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="16"
                                                VerticalAlignment="Center">
                                        <Button x:Name="HuePairButton"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                MinWidth="200"
                                                Click="OnHuePairClick">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="{StaticResource Icon.Link}" FontSize="14" />
                                                <TextBlock x:Name="HuePairLabel" Text="Pair (press link button)" />
                                            </StackPanel>
                                        </Button>
                                        <Ellipse x:Name="HuePairStatusDot"
                                                 Width="10" Height="10"
                                                 Fill="{ThemeResource SystemFillColorNeutralBrush}"
                                                 VerticalAlignment="Center" />
                                        <TextBlock x:Name="HuePairStatusText"
                                                   Text="Not paired"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Group list + selector. Disabled
                                         until pairing has succeeded ; the
                                         pair handler enables them on
                                         success. Combo shows the group
                                         DisplayLabel (e.g. "Salon (Room,
                                         3 lights)"). -->
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                x:Name="HueListGroupsButton"
                                                IsEnabled="False"
                                                VerticalAlignment="Bottom"
                                                Click="OnHueListGroupsClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="{StaticResource Icon.List}" FontSize="14" />
                                                <TextBlock Text="List groups" />
                                            </StackPanel>
                                        </Button>
                                        <ComboBox Grid.Column="1"
                                                  x:Name="HueGroupComboBox"
                                                  Header="Group"
                                                  IsEnabled="False"
                                                  PlaceholderText="No groups loaded yet"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="OnHueGroupSelectionChanged" />
                                    </Grid>

                                    <!-- Colour test row. Each colour
                                         button sends one PUT to the
                                         selected group ; the rotation
                                         button cycles R → G → B → W →
                                         Off with a 1 s gap, useful for
                                         sanity-checking the pipeline
                                         and watching the lamps respond
                                         in real time. -->
                                    <!-- StackPanel doesn't expose IsEnabled
                                         (it's defined on Control, not on
                                         Panel) ; the colour buttons are
                                         enabled / disabled individually
                                         from code via SetHueColorButtons-
                                         Enabled which iterates Children.
                                         Children start disabled (XAML
                                         IsEnabled="False" on each Button)
                                         until a group is picked. -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                x:Name="HueColorButtonsPanel">
                                        <Button x:Name="HueTestRedButton"
                                                Tag="red"
                                                IsEnabled="False"
                                                Click="OnHueTestColorClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="10" Height="10" Fill="#FF3030" />
                                                <TextBlock Text="Red" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="HueTestGreenButton"
                                                Tag="green"
                                                IsEnabled="False"
                                                Click="OnHueTestColorClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="10" Height="10" Fill="#30C030" />
                                                <TextBlock Text="Green" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="HueTestBlueButton"
                                                Tag="blue"
                                                IsEnabled="False"
                                                Click="OnHueTestColorClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="10" Height="10" Fill="#3070F0" />
                                                <TextBlock Text="Blue" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="HueTestWhiteButton"
                                                Tag="white"
                                                IsEnabled="False"
                                                Click="OnHueTestColorClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="10" Height="10" Fill="#F0F0F0" />
                                                <TextBlock Text="White" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="HueTestOffButton"
                                                Tag="off"
                                                IsEnabled="False"
                                                Click="OnHueTestColorClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="10" Height="10"
                                                         Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                                         StrokeThickness="1"
                                                         Fill="Transparent" />
                                                <TextBlock Text="Off" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="HueTestRotationButton"
                                                IsEnabled="False"
                                                Click="OnHueTestRotationClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="{StaticResource Icon.Refresh}" FontSize="14" />
                                                <TextBlock Text="Rotation" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Light zones card. Visible the moment a
                                 group is selected ; for each light, a
                                 row exposes the lamp name, an [Identify]
                                 button (flashes the lamp 15 s) and a
                                 ComboBox to pick which border zone the
                                 lamp should reflect. The card sits
                                 right under the Pipeline card so the
                                 zone choice is co-located with the mode
                                 selector that consumes it. -->
                            <Border x:Name="LightZonesCard"
                                    Visibility="Collapsed"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Padding="24">
                                <StackPanel Spacing="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Light zones"
                                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="LightZonesSubtitle"
                                                   Text="Assign each lamp to a border zone. The engine samples one colour per zone (top / bottom / left / right band of the screen) and pushes it to every lamp mapped to that zone."
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="440" />
                                    </StackPanel>
                                    <!-- Empty state. Shown when the
                                         selected group has zero
                                         addressable lights (e.g. a
                                         pure Entertainment area whose
                                         lights live only in the v2
                                         configuration, or a freshly
                                         created group). -->
                                    <TextBlock x:Name="LightZonesEmptyState"
                                               Visibility="Collapsed"
                                               Text="No lights returned for this group. If this is an Entertainment Area, try selecting the matching Room/Zone instead, or check the Hue app."
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                               TextWrapping="Wrap"
                                               MaxWidth="440" />
                                    <!-- Per-light rows are injected in
                                         code-behind from the cached
                                         IMultiLightOutput.ListLightsAsync
                                         response. Each row is a
                                         horizontal StackPanel : a
                                         TextBlock with the light name,
                                         an [Identify] button and a
                                         ComboBox bound to the 5
                                         LightZone values. -->
                                    <StackPanel x:Name="LightZonesPanel"
                                                Spacing="8" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
