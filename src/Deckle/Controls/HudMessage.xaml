<UserControl
    x:Class="Deckle.Controls.HudMessage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme-tracking badge brushes. Declared here (not in App.xaml) because
         SystemFillColor* tokens only resolve through {ThemeResource} binding
         — a flat Application.Current.Resources[key] lookup in code returns
         null for themed resources, which the fallback path silently painted
         as Colors.Gray. Keyed by the same names HudPalette.Entry.BrushKey
         returns, so Show() just does Resources[entry.BrushKey]. -->
    <UserControl.Resources>
        <SolidColorBrush x:Key="BadgeSuccessBrush"
                         Color="{ThemeResource SystemFillColorSuccess}" />
        <SolidColorBrush x:Key="BadgeCriticalBrush"
                         Color="{ThemeResource SystemFillColorCritical}" />
        <SolidColorBrush x:Key="BadgeWarningBrush"
                         Color="{ThemeResource SystemFillColorCaution}" />
        <SolidColorBrush x:Key="BadgeInfoBrush"
                         Color="{ThemeResource SystemFillColorAttention}" />
    </UserControl.Resources>

    <!-- Same minimum-element pattern as HudChrono: a Grid root, the
         MessageCard Border (opaque card surface with the rounded corner)
         and the content Grid as sibling on top. The card paints
         LayerFillColorDefaultBrush — opaque, theme-tracked. No Composition
         stroke. The semantic hue lives only on the badge disc (resolved
         from the local themed brushes above). -->
    <Grid x:Name="MessageRoot">
        <Border x:Name="MessageCard"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="{ThemeResource OverlayCornerRadius}" />

        <Grid Padding="16,12,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Spacing="2">
                <TextBlock x:Name="MessageTitle"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="MessageSubtitle"
                           Style="{StaticResource BodyTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Badge disc. 17x17 (odd) + CornerRadius=9 ≥ half-side so the
                 Border clips to a full circle. Odd side means the pastille
                 has a true center pixel at (8, 8) rather than the 4-pixel
                 ambiguity of even sizes — the inner glyph then rasterizes
                 on axis instead of subpixel-blurring. -->
            <Border x:Name="BadgeBackground"
                    Grid.Column="1"
                    Width="17" Height="17"
                    CornerRadius="9"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right">
                <!-- FontIcon with explicit H/V center on both the element
                     and the layout inside the disc. FontSize=11 yields a
                     Segoe Fluent glyph whose em-box fits inside the 17-wide
                     disc with a symmetric ~3 px ring; the explicit alignment
                     overrides the font's baseline-driven default, which
                     otherwise drifts a glyph like E946 downward off-center. -->
                <FontIcon x:Name="BadgeGlyph"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="11"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
