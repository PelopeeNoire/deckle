<UserControl
    x:Class="WhispUI.Controls.HudChrono"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Three elements only: the Grid root, the ChronoCard Border (opaque
         card surface with rounded corner + theme-tracked stroke) and the
         ClockText sibling on top of it. The card paints
         LayerFillColorDefaultBrush (opaque fill) and CardStrokeColorDefaultBrush
         (1 dip stroke, Win11 canonical card stroke token). BorderThickness
         starts at 0 — the stroke is toggled per state from code-behind:
         hidden for Recording, visible for Charging/Transcribing/Rewriting.
         Rounded silhouette produced by this Border alone. -->
    <Grid x:Name="ChronoRoot">
        <Grid.Resources>
            <!-- Shared style for the 8 clock TextBlocks. A shared style is
                 necessary because the 8 characters are now separate UIElements
                 (not Runs inside a single TextBlock) — each needs its own
                 Composition.Visual for the swipe reveal animation. The Runs
                 shared their TextBlock's font metrics through inheritance;
                 the 8 TextBlocks get them here via x:Key to keep them aligned
                 and avoid prop repetition. Foreground is a ThemeResource
                 default — code-behind overrides per TextBlock during the
                 swipe (disabled → primary / critical). -->
            <Style x:Key="ChronoDigitStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/BitcountSingle.ttf#Bitcount Single" />
                <Setter Property="FontWeight" Value="ExtraLight" />
                <Setter Property="FontSize" Value="48" />
                <Setter Property="TextLineBounds" Value="Tight" />
                <!-- CharacterSpacing is a no-op when each TextBlock holds a
                     single glyph — the thousandths-of-em adjustment is
                     applied *between* characters within a Run, and there
                     are no inter-character gaps to shrink here. Kept at
                     -600 for parity with how the Runs-based prior design
                     was tuned, but the actual tightening between the 8
                     TextBlocks now comes from the negative Margin below. -->
                <Setter Property="CharacterSpacing" Value="-600" />
                <!-- Negative horizontal Margin clips into the font's
                     side-bearings on both sides of each glyph. The Bitcount
                     Single "0" at FontSize 48 has ~6 dip of intrinsic
                     side-bearing per side; -1 dip on each side nets ~2 dip
                     of tightening per inter-digit gap — enough to close
                     the optical gap between digits without cropping the
                     glyph body. Tuneable from XAML directly — no rebuild
                     needed because this is a layout-time measurement,
                     not baked into Composition geometry. -->
                <Setter Property="Margin" Value="-1,0,-1,0" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            </Style>
        </Grid.Resources>

        <!-- Opaque card fill only — no XAML stroke. The system frame
             stroke is drawn by DWM at the HWND level (DWMWA_BORDER_COLOR =
             DWMWA_COLOR_DEFAULT in HudWindow.xaml.cs) and is always on for
             every state; the Composition accent stroke (Transcribing /
             Rewriting) adds an inner 1-dip layer, 1 dip inset inside. -->
        <Border x:Name="ChronoCard"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="{ThemeResource OverlayCornerRadius}" />

        <!-- Attach point for Composition strokes (Transcribing / Rewriting).
             Transparent, non-hit-testable — hosts the ShapeVisual via
             ElementCompositionPreview.SetElementChildVisual. Covers the whole
             card so the visual's coordinate space matches ActualWidth/Height. -->
        <Border x:Name="ProcessingSurfaceHost"
                IsHitTestVisible="False" />

        <!-- 8 elements inside a StackPanel: 6 digit Grids (each holding a
             primary TextBlock + an accent overlay) and 2 standalone dot
             TextBlocks.

             Per-digit overlay pattern: each digit Grid stacks two
             TextBlocks with identical text. The primary is always at
             full opacity with the theme Foreground brush; the accent
             sibling uses SystemFillColorCriticalBrush and is hidden by
             default (Opacity=0). The swipe animation code in
             HudChrono.xaml.cs modulates each accent's Opacity each
             vsync so the digit cross-fades from primary to critical red
             and back as the wave passes — rather than snapping the
             Foreground DP between two brushes per frame (which caused
             visible stepping because the swap was instantaneous).

             Dots never flash, so they stay single TextBlocks — no
             overlay sibling, no heat tracking.

             ClockText is preserved as the panel name so HudChrono.xaml.cs
             references still resolve. -->
        <StackPanel x:Name="ClockText"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Grid>
                <TextBlock x:Name="Min1"       Text="0" Style="{StaticResource ChronoDigitStyle}" />
                <TextBlock x:Name="Min1Accent" Text="0" Style="{StaticResource ChronoDigitStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" Opacity="0" />
            </Grid>
            <Grid>
                <TextBlock x:Name="Min2"       Text="0" Style="{StaticResource ChronoDigitStyle}" />
                <TextBlock x:Name="Min2Accent" Text="0" Style="{StaticResource ChronoDigitStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" Opacity="0" />
            </Grid>
            <TextBlock x:Name="DotA" Text="." Style="{StaticResource ChronoDigitStyle}" />
            <Grid>
                <TextBlock x:Name="Sec1"       Text="0" Style="{StaticResource ChronoDigitStyle}" />
                <TextBlock x:Name="Sec1Accent" Text="0" Style="{StaticResource ChronoDigitStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" Opacity="0" />
            </Grid>
            <Grid>
                <TextBlock x:Name="Sec2"       Text="0" Style="{StaticResource ChronoDigitStyle}" />
                <TextBlock x:Name="Sec2Accent" Text="0" Style="{StaticResource ChronoDigitStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" Opacity="0" />
            </Grid>
            <TextBlock x:Name="DotB" Text="." Style="{StaticResource ChronoDigitStyle}" />
            <Grid>
                <TextBlock x:Name="Cs1"       Text="0" Style="{StaticResource ChronoDigitStyle}" />
                <TextBlock x:Name="Cs1Accent" Text="0" Style="{StaticResource ChronoDigitStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" Opacity="0" />
            </Grid>
            <Grid>
                <TextBlock x:Name="Cs2"       Text="0" Style="{StaticResource ChronoDigitStyle}" />
                <TextBlock x:Name="Cs2Accent" Text="0" Style="{StaticResource ChronoDigitStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" Opacity="0" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
