<Window
    x:Class="Deckle.HudWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Deckle.Controls"
    xmlns:chrono="using:Deckle.Chrono.Hud">
    <!-- Window is fixed 272x78. The RootGrid paints the same card fill as
         each hosted control's Border so the sliver between the card's XAML
         CornerRadius and the HWND rectangle is the same color end-to-end —
         nothing visible bleeds through at the edge. DWMWCP_ROUND set in
         code-behind clips the outer HWND silhouette to the Win11 standard
         radius. Theme follows the system. -->
    <Grid x:Name="RootGrid"
          Background="{ThemeResource LayerFillColorDefaultBrush}">
        <chrono:HudChrono    x:Name="Chrono"  Visibility="Visible" />
        <controls:HudMessage x:Name="Message" Visibility="Collapsed" />
    </Grid>
</Window>
