<Window
    x:Class="Deckle.PlaygroundWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Deckle.Controls"
    Title="Deckle Playground">

    <!-- RootGrid is hit-testable (Background="Transparent") + focusable
         (IsTabStop) so a tap on empty space can dismiss the focus from a
         NumberBox. Focused input controls in WinUI 3 don't release on
         background click unless something else takes focus — handler
         wired in code-behind. -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          IsTabStop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native TitleBar: icon + title. Matches SettingsWindow / LogWindow.
             ImageIconSource rebuilt wholesale on recording state change. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="Deckle Playground">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Main content: two panels, both responsive, no sash.
               Col 0 (preview): Width="*" — grows with the window, absorbs
                                all extra horizontal space. MinWidth=720
                                so the 7-tab SelectorBar fits without
                                horizontal scroll. Preview content is
                                center-aligned so the HudChrono stays
                                centered as the column widens.
               Col 1 (tuning):  Width="Auto" — desired width reported by
                                the inner ScrollViewer, which is capped
                                at MaxWidth=840 (~900 is "too much
                                whitespace", ~700 feels cramped). The
                                column never exceeds that cap no matter
                                how wide the window gets; Col 0 picks up
                                the slack.

             The earlier draggable sash was removed: a user-set PreviewCol
             width survived window shrinks, leaving the tuning panel clipped
             off-screen with no way back short of re-enlarging the window.
             Fluid columns with a MaxWidth-capped tuning panel make the
             responsive contract explicit and avoid the stuck-state
             regression. -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="720" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- ── Col 0 — preview (grows, content centered) ───────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 7 targets: 4 HUD states + 3 naked diagnostic masks.
                     Horizontal scroll when the column is narrowed below the
                     natural SelectorBar width. -->
                <ScrollViewer Grid.Row="0"
                              HorizontalScrollMode="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              Padding="16,24,16,8">
                    <SelectorBar x:Name="TargetSelector"
                                 HorizontalAlignment="Center"
                                 SelectionChanged="OnTargetSelectionChanged">
                        <SelectorBarItem x:Name="TabCharging"     Text="Charging" />
                        <SelectorBarItem x:Name="TabRecording"    Text="Recording" />
                        <SelectorBarItem x:Name="TabTranscribing" Text="Transcribing" IsSelected="True" />
                        <SelectorBarItem x:Name="TabRewriting"    Text="Rewriting" />
                        <SelectorBarItem x:Name="TabConic"        Text="Conic" />
                        <SelectorBarItem x:Name="TabArcMask"      Text="ArcMask" />
                        <SelectorBarItem x:Name="TabCombined"     Text="Combined" />
                    </SelectorBar>
                </ScrollViewer>

                <!-- Play / Pause = two mutually-exclusive RadioButton. Button
                     labels name the action triggered, not the current state —
                     a label-swap ToggleButton (Playing / Paused) is a UX
                     trap we want to avoid. -->
                <RadioButtons Grid.Row="1"
                              x:Name="PlayPauseGroup"
                              SelectedIndex="1"
                              SelectionChanged="OnPlayPauseSelectionChanged"
                              MaxColumns="2"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,12">
                    <RadioButton Content="Play" />
                    <RadioButton Content="Pause" />
                </RadioButtons>

                <!-- Preview surface. The Border is the "playground stage":
                     stretches horizontally to fill Col 0 (width matches
                     the SelectorBar / Play-Pause area above) and fills
                     the remainder of the column vertically, so the
                     whole region below the controls reads as one
                     substrate. HudChrono 272×78 and the naked 300×300
                     host are fixed-size and centered inside the
                     stretching stage — the animation never resizes,
                     only the background does. On Pause BOTH are
                     collapsed so the preview area goes empty — no
                     residual Charging silhouette. -->
                <Border Grid.Row="2"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Margin="24">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <controls:HudChrono x:Name="ChronoPreview"
                                            Width="272"
                                            Height="78" />
                        <Grid x:Name="NakedPreviewHost"
                              Width="300"
                              Height="300"
                              Visibility="Collapsed">
                            <Border Width="272" Height="78"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Col 1 — tuning Expanders ─────────────────────────────── -->
            <!--
                Header row above the Expanders: "Tunables" title + a one-line
                description + "Reset all".

                The Playground is intentionally non-persistent. It reads its
                initial values from the running app's defaults, lets the user
                tune them in-memory for the current process, and writes
                nothing to disk. Every relaunch of Deckle returns to the
                compiled defaults — values that look right move into the code
                as the new defaults; the Playground's job is to find them,
                not to remember them.

                Reset all reverts every section to the shipping defaults for
                the current process — useful mid-session to start over.
            -->
            <!-- MinWidth=480 + MaxWidth=920 caps the tuning column between
                 two comfortable sizes: narrow enough to stay legible on
                 a smallest-allowed 1200-wide window, wide enough that the
                 title + description + "Reset all" breathe and the
                 slider+NumberBox pairs don't crowd. Anything wider is
                 wasted whitespace; Col 0 absorbs the surplus instead. -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24"
                          MinWidth="480"
                          MaxWidth="920">
                <StackPanel x:Name="TuningStack" Spacing="6">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0"
                                   Text="Tunables"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   VerticalAlignment="Center" />

                        <!-- Reset all: mirrors the "Reset all" pattern in
                             Settings › Whisper — SubtleButtonStyle + FontIcon
                             E777 (refresh / circular arrow) + label. Always
                             enabled: the Playground keeps no dirty state, so
                             the button is just "snap back to defaults" with
                             no precondition. -->
                        <Button Grid.Column="1" Grid.Row="0"
                                x:Name="ResetAllButton"
                                Style="{ThemeResource SubtleButtonStyle}"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="Reset every section to the shipping defaults"
                                Click="OnResetAllClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE777;" FontSize="14" />
                                <TextBlock Text="Reset all" />
                            </StackPanel>
                        </Button>

                        <!-- Description sits under the title (spans both
                             columns) and tells the user the contract: this
                             is a scratchpad for the current session, nothing
                             is saved, restart resets everything.
                             CaptionTextBlockStyle + Secondary brush so it
                             reads as supporting info, not a primary
                             instruction.

                             MaxWidth=400 caps the natural measure so the
                             outer Grid's "Auto" column on the body cannot
                             grow past the header row's intrinsic width.
                             Without it, TextWrapping=Wrap reports an
                             unbounded natural width, the body Auto column
                             demands ~800 dip, and the tuning panel stops
                             responding to window shrinks. With the cap,
                             the natural width of the header is ~400 +
                             button + padding ≈ 530 dip, well under the
                             ScrollViewer's MaxWidth=920, so the column
                             negotiates normally. -->
                        <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="Tweak values live for the current session — nothing is saved. Restart Deckle to reset to defaults."
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   HorizontalAlignment="Left"
                                   Margin="0,4,0,0" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
