<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WhispUI.Shell.Setup.InstallingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="20" MaxWidth="640" HorizontalAlignment="Stretch">

        <StackPanel Spacing="6">
            <ProgressBar x:Name="GlobalProgress"
                         Minimum="0"
                         Maximum="2" />
            <TextBlock x:Name="GlobalStatusText"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Whisper model -->
        <Grid ColumnSpacing="12" RowSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <FontIcon x:Name="WhisperIcon"
                      Grid.Column="0" Grid.Row="0"
                      Glyph="&#xE7C3;"
                      VerticalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="WhisperLabel"
                       Grid.Column="1" Grid.Row="0"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <ProgressBar x:Name="WhisperProgress"
                         Grid.Column="1" Grid.Row="1" />
            <TextBlock x:Name="WhisperStatus"
                       Grid.Column="1" Grid.Row="2"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <!-- Silero VAD -->
        <Grid ColumnSpacing="12" RowSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <FontIcon x:Name="VadIcon"
                      Grid.Column="0" Grid.Row="0"
                      Glyph="&#xE7C3;"
                      VerticalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="VadLabel"
                       Grid.Column="1" Grid.Row="0"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="Silero VAD" />
            <ProgressBar x:Name="VadProgress"
                         Grid.Column="1" Grid.Row="1" />
            <TextBlock x:Name="VadStatus"
                       Grid.Column="1" Grid.Row="2"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <Button x:Name="CancelDownloadButton"
                x:Uid="SetupCancelInstallButton"
                HorizontalAlignment="Left"
                Click="OnCancelDownloadClick" />
    </StackPanel>
</Page>
