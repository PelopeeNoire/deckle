<UserControl
    x:Class="WhispUI.Settings.Llm.LlmProfilesSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:WhispUI.Settings.ViewModels"
    x:Name="Root">

    <UserControl.Resources>
        <vm:CtxTooltipConverter x:Key="CtxTooltipConverter" />
        <vm:TempTooltipConverter x:Key="TempTooltipConverter" />
    </UserControl.Resources>

    <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Uid="LlmProfilesHeader"
                       Grid.Column="0"
                       Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
            <HyperlinkButton x:Uid="Settings_SectionResetLink"
                             Grid.Column="1"
                             VerticalAlignment="Bottom"
                             Margin="0,0,0,2"
                             Click="ResetSection_Click" />
        </Grid>

        <TextBlock x:Uid="LlmProfilesBody"
                   Style="{StaticResource BodyTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="1,0,0,8" />

        <ItemsRepeater ItemsSource="{x:Bind Profiles}">
            <ItemsRepeater.Layout>
                <StackLayout Spacing="4" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="vm:ProfileViewModel">
                    <controls:SettingsExpander
                        Header="{x:Bind Name, Mode=OneWay}"
                        Description="{x:Bind Summary, Mode=OneWay}"
                        IsExpanded="{x:Bind IsNew, Mode=OneWay}">

                        <!-- Delete button in the header area -->
                        <Button Tag="{x:Bind}"
                                Click="DeleteProfile_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="Remove" />
                            </StackPanel>
                        </Button>

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                                   HorizontalContentAlignment="Stretch">
                                <StackPanel Spacing="12"
                                            HorizontalAlignment="Stretch">
                                    <TextBox Header="Name"
                                             Text="{x:Bind Name, Mode=TwoWay}"
                                             Tag="{x:Bind}"
                                             TextChanged="NameBox_TextChanged"
                                             PlaceholderText="Profile name"
                                             HorizontalAlignment="Stretch" />

                                    <AutoSuggestBox Header="Model"
                                                    PlaceholderText="Ollama model name"
                                                    Tag="{x:Bind}"
                                                    Text="{x:Bind Model, Mode=OneWay}"
                                                    GotFocus="ModelSuggest_GotFocus"
                                                    TextChanged="ModelSuggest_TextChanged"
                                                    SuggestionChosen="ModelSuggest_SuggestionChosen"
                                                    QuerySubmitted="ModelSuggest_QuerySubmitted"
                                                    HorizontalAlignment="Stretch" />

                                    <TextBox Header="System prompt"
                                             Text="{x:Bind SystemPrompt, Mode=TwoWay}"
                                             Tag="{x:Bind}"
                                             TextChanged="SystemPromptBox_TextChanged"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="100"
                                             MaxHeight="300"
                                             PlaceholderText="System prompt sent with every rewrite request..."
                                             HorizontalAlignment="Stretch" />

                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,-4,0,0"
                                               Text="Instructions sent with every request to define the model's behavior and rewriting style." />

                                    <!-- Temperature -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12"
                                                VerticalAlignment="Bottom">
                                        <Slider Header="Temperature"
                                                Minimum="0" Maximum="2"
                                                StepFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                MinWidth="280"
                                                Value="{x:Bind Temperature, Mode=TwoWay}"
                                                ThumbToolTipValueConverter="{StaticResource TempTooltipConverter}" />
                                        <TextBlock Text="{x:Bind TempDisplay, Mode=OneWay}"
                                                   VerticalAlignment="Center"
                                                   MinWidth="40"
                                                   Style="{StaticResource BodyTextBlockStyle}" />
                                    </StackPanel>

                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,-4,0,0"
                                               Text="Controls randomness. Lower values produce more focused, deterministic output. Higher values increase creativity and variation." />

                                    <!-- Context size -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12"
                                                VerticalAlignment="Bottom">
                                        <Slider Header="Context size"
                                                Minimum="0" Maximum="8"
                                                StepFrequency="1"
                                                SnapsTo="StepValues"
                                                MinWidth="280"
                                                Value="{x:Bind CtxIndex, Mode=TwoWay}"
                                                ThumbToolTipValueConverter="{StaticResource CtxTooltipConverter}" />
                                        <TextBlock Text="{x:Bind CtxDisplay, Mode=OneWay}"
                                                   VerticalAlignment="Center"
                                                   MinWidth="40"
                                                   Style="{StaticResource BodyTextBlockStyle}" />
                                    </StackPanel>

                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,-4,0,0"
                                               Text="Maximum tokens the model considers at once. Larger context uses more memory and is slower." />

                                    <!-- Advanced parameters -->
                                    <Expander Header="Advanced parameters"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch">
                                        <StackPanel Spacing="12">
                                            <NumberBox Header="Top P"
                                                       Minimum="0" Maximum="1"
                                                       SmallChange="0.05" LargeChange="0.1"
                                                       SpinButtonPlacementMode="Compact"
                                                       PlaceholderText="Default (0.9)"
                                                       Value="{x:Bind TopP, Mode=TwoWay}"
                                                       MinWidth="160" />
                                            <NumberBox Header="Repeat penalty"
                                                       Minimum="0.5" Maximum="2"
                                                       SmallChange="0.05" LargeChange="0.1"
                                                       SpinButtonPlacementMode="Compact"
                                                       PlaceholderText="Default (1.1)"
                                                       Value="{x:Bind RepeatPenalty, Mode=TwoWay}"
                                                       MinWidth="160" />
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <Button x:Uid="LlmAddProfileButton"
                Click="AddProfile_Click"
                Margin="0,4,0,0" />
    </StackPanel>
</UserControl>
