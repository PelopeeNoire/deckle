<Page
    x:Class="Deckle.Lighting.Ambient.AmbientPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:ambientControls="using:Deckle.Lighting.Ambient.Controls">

    <!-- Pattern canonique Microsoft Learn (SettingsExpander sample
         "Settings page example") : StackPanel max 1000 dans un Grid,
         Spacing=4 entre cards, Margin="1,30,0,6" sur les headers de
         section. Calque exact de GeneralPage / WhisperPage. -->
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>

        <!-- Slider value text + reset button styles. The slider itself
             is plain WinUI 3 (Width inline so the four sliders in the
             section line up visually) — no shared style needed beyond
             value + reset which appear next to every slider. -->
        <Style x:Key="SliderValueTextStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- Per-setting reset button. Opacity 0 by default, lifted to 1
             on PointerEntered of the parent SettingsCard (code-behind
             WireHover helper). -->
        <Style x:Key="ResetButtonStyle"
               BasedOn="{StaticResource SubtleButtonStyle}"
               TargetType="Button">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.ToolTip" Value="Reset to default" />
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <TextBlock x:Uid="AmbientPageTitleLabel"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,8" />

                <TextBlock x:Uid="AmbientPageSubtitleLabel"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- ── State ──────────────────────────────────────────────── -->
                <TextBlock x:Uid="AmbientStateSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <!-- Surfaced when the persisted Hue bridge state is
                     incomplete (no IP / no username / no group). The
                     toggle stays usable but a click will immediately
                     revert. The action button expands the Hue bridge
                     expander in the Configuration section below and
                     scrolls to it. Tied to the Loaded / Changed
                     observer in code-behind. -->
                <InfoBar x:Name="NotPairedInfoBar"
                         x:Uid="AmbientNotPairedInfoBar"
                         IsClosable="False"
                         IsOpen="False"
                         Severity="Warning"
                         Margin="0,0,0,8">
                    <InfoBar.ActionButton>
                        <Button x:Name="ConfigureBridgeButton"
                                x:Uid="AmbientNotPairedActionButton"
                                Click="ConfigureBridgeButton_Click" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <controls:SettingsCard x:Uid="AmbientEnabledCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE781;}">
                    <ToggleSwitch x:Name="EnabledToggle"
                                  Toggled="EnabledToggle_Toggled" />
                </controls:SettingsCard>

                <!-- ── Behaviour ──────────────────────────────────────────── -->
                <TextBlock x:Uid="AmbientBehaviourSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsCard x:Uid="AmbientModeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:Name="ModeCombo"
                              MinWidth="160"
                              SelectionChanged="ModeCombo_SelectionChanged">
                        <ComboBoxItem x:Uid="AmbientModeGame" Tag="Game" />
                        <ComboBoxItem x:Uid="AmbientModeMovie" Tag="Movie" />
                        <ComboBoxItem x:Uid="AmbientModeAmbient" Tag="Ambient" />
                        <ComboBoxItem x:Uid="AmbientModeCustom" Tag="Custom" />
                    </ComboBox>
                </controls:SettingsCard>

                <!-- ── HDR tuning ─────────────────────────────────────────── -->
                <!--
                    Four user-tunable sliders applied live on the next push
                    tick (no engine restart). Flat SettingsCards instead of
                    a SettingsExpander so the values are visible at a glance
                    (Louis preference : less click-to-reveal on knobs the
                    user touches often). Descriptions are intentionally
                    short — the dense per-knob rationale lives in the
                    Playground HDR tuning card where the live preview
                    makes experimentation cheap.
                -->
                <!-- Tuning lives in the Playground now. The Settings
                     page keeps only the mode preset selector (above)
                     and a clear pointer to the Playground for fine
                     calibration — moving four near-identical slider
                     cards into a single place where the live preview
                     sits next to the user. -->
                <TextBlock x:Uid="AmbientTuningSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsCard x:Uid="AmbientOpenPlaygroundCard"
                                       IsClickEnabled="True"
                                       ActionIcon="{ui:FontIcon Glyph=&#xEA80;}"
                                       Click="OpenPlaygroundCard_Click" />

                <!-- ── Configuration ──────────────────────────────────────── -->
                <!--
                    Hue bridge pairing now lives in this page (was in the
                    Playground in V0). The bridge state is owned by the
                    process-wide HuePairingService — the same instance the
                    Playground and the AmbientEngine consume — so re-pairing
                    or forgetting from either surface takes effect everywhere.
                    Per-light zone assignment and per-light brightness still
                    live in the Playground for now (richer UI tied to the
                    preview grid).
                -->
                <TextBlock x:Uid="AmbientConfigSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsExpander x:Uid="HueBridgeExpander"
                                           x:Name="HueBridgeExpander"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE839;}">
                    <!-- Header right-side : compact status text + dot. The
                         expander shows / hides the per-section cards below
                         on click. -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse x:Name="HueBridgeStatusDot"
                                 Width="10" Height="10"
                                 Fill="{ThemeResource SystemFillColorNeutralBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="HueBridgeStatusText"
                                   x:Uid="HueBridgeStatusText"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <controls:SettingsExpander.Items>
                        <!-- Bridge address row. SettingsCard default
                             layout : Header on the left, content on the
                             right, mirrors the HDR tuning cards above.
                             Discover queries discovery.meethue.com and
                             autofills the textbox ; manual entry is the
                             fallback when the cloud lookup returns
                             nothing (firewall, offline, etc.). Pair
                             launches the 30 s link-button countdown via
                             HuePairingService.PairAsync. Transient
                             status text lives below the card (separate
                             TextBlock) so the card itself stays clean. -->
                        <controls:SettingsCard x:Uid="HueBridgeAddressCard">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="HueBridgeIpTextBox"
                                         Width="160"
                                         PlaceholderText="192.168.1.5" />
                                <Button x:Name="HueDiscoverButton"
                                        x:Uid="HueDiscoverButton"
                                        Click="OnHueDiscoverClick" />
                                <Button x:Name="HuePairButton"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="OnHuePairClick">
                                    <TextBlock x:Name="HuePairLabel"
                                               x:Uid="HuePairLabel" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <!-- Transient pair status (countdown / errors /
                             paired confirmation). Plain TextBlock inside
                             a borderless card slot — collapsed when
                             empty so the row disappears entirely instead
                             of leaving a hollow card behind. -->
                        <TextBlock x:Name="HuePairStatusText"
                                   Text=""
                                   Visibility="Collapsed"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="16,4,16,8" />

                        <!-- Entertainment group / room. -->
                        <controls:SettingsCard x:Uid="HueBridgeGroupCard">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ComboBox x:Name="HueGroupComboBox"
                                          Width="240"
                                          IsEnabled="False"
                                          SelectionChanged="OnHueGroupSelectionChanged" />
                                <Button x:Name="HueListGroupsButton"
                                        x:Uid="HueListGroupsButton"
                                        IsEnabled="False"
                                        Click="OnHueListGroupsClick" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <!-- Forget : DefaultButtonStyle (no custom red).
                             The destructive signal is carried by the
                             ContentDialog confirmation that opens at
                             click, following Microsoft's official
                             Settings pattern (confirm-then-act, not
                             red-button-then-act). -->
                        <controls:SettingsCard x:Uid="HueBridgeForgetCard">
                            <Button x:Name="HueForgetButton"
                                    x:Uid="HueForgetButton"
                                    IsEnabled="False"
                                    Click="OnHueForgetClick" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
