<Page
    x:Class="Deckle.Lighting.Ambient.AmbientPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:ambientControls="using:Deckle.Lighting.Ambient.Controls">

    <!-- Pattern canonique Microsoft Learn (SettingsExpander sample
         "Settings page example") : StackPanel max 1000 dans un Grid,
         Spacing=4 entre cards, Margin="1,30,0,6" sur les headers de
         section. Calque exact de GeneralPage. -->
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <TextBlock x:Uid="AmbientPageTitleLabel"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,8" />

                <TextBlock x:Uid="AmbientPageSubtitleLabel"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- ── State ──────────────────────────────────────────────── -->
                <TextBlock x:Uid="AmbientStateSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <!-- Surfaced when the persisted Hue bridge state is
                     incomplete (no IP / no username / no group). The
                     toggle stays usable but a click will immediately
                     revert. The action button expands the Hue bridge
                     expander in the Configuration section below and
                     scrolls to it. Tied to the Loaded / Changed
                     observer in code-behind. -->
                <InfoBar x:Name="NotPairedInfoBar"
                         x:Uid="AmbientNotPairedInfoBar"
                         IsClosable="False"
                         IsOpen="False"
                         Severity="Warning"
                         Margin="0,0,0,8">
                    <InfoBar.ActionButton>
                        <Button x:Name="ConfigureBridgeButton"
                                x:Uid="AmbientNotPairedActionButton"
                                Click="ConfigureBridgeButton_Click" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <controls:SettingsCard x:Uid="AmbientEnabledCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE781;}">
                    <ToggleSwitch x:Name="EnabledToggle"
                                  Toggled="EnabledToggle_Toggled" />
                </controls:SettingsCard>

                <!-- ── Behaviour ──────────────────────────────────────────── -->
                <TextBlock x:Uid="AmbientBehaviourSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsCard x:Uid="AmbientModeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:Name="ModeCombo"
                              MinWidth="160"
                              SelectionChanged="ModeCombo_SelectionChanged">
                        <ComboBoxItem x:Uid="AmbientModeGame" Tag="Game" />
                        <ComboBoxItem x:Uid="AmbientModeRealistic" Tag="Realistic" />
                    </ComboBox>
                </controls:SettingsCard>

                <!-- ── HDR tuning ─────────────────────────────────────────── -->
                <!--
                    Three user-tunable sliders applied live on the next push
                    tick (no engine restart). Defaults aim at a "Hue Sync
                    presence" out of the box on HDR displays ; the user dials
                    back if it's too aggressive. See AmbientSettings for the
                    underlying field semantics.
                -->
                <TextBlock x:Uid="AmbientTuningSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsExpander x:Uid="AmbientTuningExpander"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE793;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard x:Uid="AmbientExposureCard"
                                               ContentAlignment="Vertical">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="ExposureSlider"
                                        Grid.Column="0"
                                        Minimum="-2.0" Maximum="2.0"
                                        StepFrequency="0.1"
                                        SmallChange="0.1" LargeChange="0.5"
                                        TickFrequency="0.5"
                                        TickPlacement="Outside"
                                        ValueChanged="ExposureSlider_ValueChanged" />
                                <TextBlock x:Name="ExposureValueText"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MinWidth="48"
                                           TextAlignment="End" />
                            </Grid>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Uid="AmbientSaturationCard"
                                               ContentAlignment="Vertical">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SaturationSlider"
                                        Grid.Column="0"
                                        Minimum="0" Maximum="200"
                                        StepFrequency="5"
                                        SmallChange="5" LargeChange="25"
                                        TickFrequency="25"
                                        TickPlacement="Outside"
                                        ValueChanged="SaturationSlider_ValueChanged" />
                                <TextBlock x:Name="SaturationValueText"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MinWidth="48"
                                           TextAlignment="End" />
                            </Grid>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Uid="AmbientMinBrightnessCard"
                                               ContentAlignment="Vertical">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="MinBrightnessSlider"
                                        Grid.Column="0"
                                        Minimum="0" Maximum="254"
                                        StepFrequency="2"
                                        SmallChange="2" LargeChange="20"
                                        TickFrequency="50"
                                        TickPlacement="Outside"
                                        ValueChanged="MinBrightnessSlider_ValueChanged" />
                                <TextBlock x:Name="MinBrightnessValueText"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MinWidth="48"
                                           TextAlignment="End" />
                            </Grid>
                        </controls:SettingsCard>

                        <!-- Brightness response curve : the only HDR
                             knob that benefits from a visual reference,
                             because intuition breaks down on power-law
                             curves. The widget lives left of the slider
                             so the eye reads "this is what the curve
                             looks like" before "this is where the slider
                             sits". Caption summarises the practical
                             range so the user knows what's reasonable
                             without trial-and-error. -->
                        <controls:SettingsCard x:Uid="AmbientGammaCard"
                                               ContentAlignment="Vertical">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ambientControls:BrightnessCurveCanvas
                                    x:Name="GammaCurveCanvas"
                                    Grid.Column="0"
                                    VerticalAlignment="Top" />
                                <Grid Grid.Column="1"
                                      VerticalAlignment="Center"
                                      RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="GammaSlider"
                                                Grid.Column="0"
                                                Minimum="1.0" Maximum="3.0"
                                                StepFrequency="0.05"
                                                SmallChange="0.05" LargeChange="0.25"
                                                TickFrequency="0.5"
                                                TickPlacement="Outside"
                                                ValueChanged="GammaSlider_ValueChanged" />
                                        <TextBlock x:Name="GammaValueText"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   MinWidth="48"
                                                   TextAlignment="End" />
                                    </Grid>
                                    <TextBlock x:Uid="AmbientGammaCaption"
                                               Grid.Row="1"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Grid>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- ── Configuration ──────────────────────────────────────── -->
                <!--
                    Hue bridge pairing now lives in this page (was in the
                    Playground in V0). The bridge state is owned by the
                    process-wide HuePairingService — the same instance the
                    Playground and the AmbientEngine consume — so re-pairing
                    or forgetting from either surface takes effect everywhere.
                    Per-light zone assignment and per-light brightness still
                    live in the Playground for now (richer UI tied to the
                    preview grid).
                -->
                <TextBlock x:Uid="AmbientConfigSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsExpander x:Uid="HueBridgeExpander"
                                           x:Name="HueBridgeExpander"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE839;}">
                    <!-- Header right-side : compact status text + dot. The
                         expander shows / hides the per-section cards below
                         on click. -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse x:Name="HueBridgeStatusDot"
                                 Width="10" Height="10"
                                 Fill="{ThemeResource SystemFillColorNeutralBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="HueBridgeStatusText"
                                   Text="Not paired"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <controls:SettingsExpander.Items>
                        <!-- Bridge address row. Discover queries
                             discovery.meethue.com and autofills the textbox ;
                             manual entry is the fallback when the cloud lookup
                             returns nothing (firewall, offline, etc.). Pair
                             launches the 30 s link-button countdown via
                             HuePairingService.PairAsync. -->
                        <controls:SettingsCard x:Uid="HueBridgeAddressCard"
                                               ContentAlignment="Vertical">
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="HueBridgeIpTextBox"
                                         Grid.Row="0" Grid.Column="0"
                                         PlaceholderText="192.168.1.5" />
                                <Button x:Name="HueDiscoverButton"
                                        x:Uid="HueDiscoverButton"
                                        Grid.Row="0" Grid.Column="1"
                                        Click="OnHueDiscoverClick" />
                                <Button x:Name="HuePairButton"
                                        Grid.Row="0" Grid.Column="2"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="OnHuePairClick">
                                    <TextBlock x:Name="HuePairLabel"
                                               Text="Pair (press link button)" />
                                </Button>
                                <TextBlock x:Name="HuePairStatusText"
                                           Grid.Row="1" Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Text=""
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </controls:SettingsCard>

                        <!-- Entertainment group / room. Populated by clicking
                             "List groups" once paired. The combo writes
                             HueLastGroupId on selection — same key the
                             AmbientEngine reads on Start. -->
                        <controls:SettingsCard x:Uid="HueBridgeGroupCard"
                                               ContentAlignment="Vertical">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="HueGroupComboBox"
                                          Grid.Column="0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          SelectionChanged="OnHueGroupSelectionChanged" />
                                <Button x:Name="HueListGroupsButton"
                                        x:Uid="HueListGroupsButton"
                                        Grid.Column="1"
                                        IsEnabled="False"
                                        Click="OnHueListGroupsClick" />
                            </Grid>
                        </controls:SettingsCard>

                        <!-- Forget : clears the persisted credentials and
                             disposes the bridge client via the service. The
                             username on the bridge itself is NOT revoked —
                             the user pairs again later without re-pressing
                             the link button if the bridge still recognises
                             the username. -->
                        <controls:SettingsCard x:Uid="HueBridgeForgetCard">
                            <Button x:Name="HueForgetButton"
                                    x:Uid="HueForgetButton"
                                    IsEnabled="False"
                                    Click="OnHueForgetClick" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
