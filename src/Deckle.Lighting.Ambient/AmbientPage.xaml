<Page
    x:Class="Deckle.Lighting.Ambient.AmbientPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:ambientControls="using:Deckle.Lighting.Ambient.Controls">

    <!-- Pattern canonique Microsoft Learn (SettingsExpander sample
         "Settings page example") : StackPanel max 1000 dans un Grid,
         Spacing=4 entre cards, Margin="1,30,0,6" sur les headers de
         section. Calque exact de GeneralPage / WhisperPage. -->
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>

        <!-- Slider / value / reset triplet styles — calque exact de
             WhisperPage.xaml so the HDR tuning cards read identical to
             the Whisper decoding cards (compact slider, value text
             right, subtle reset button that fades in at hover). -->
        <Style x:Key="SettingSliderStyle"
               TargetType="Slider">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsThumbToolTipEnabled" Value="True" />
        </Style>

        <Style x:Key="SliderValueTextStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- Per-setting reset button. Opacity 0 by default, lifted to 1
             on PointerEntered of the parent SettingsCard (code-behind
             WireHover helper). -->
        <Style x:Key="ResetButtonStyle"
               BasedOn="{StaticResource SubtleButtonStyle}"
               TargetType="Button">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.ToolTip" Value="Reset to default" />
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <TextBlock x:Uid="AmbientPageTitleLabel"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,8" />

                <TextBlock x:Uid="AmbientPageSubtitleLabel"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- ── State ──────────────────────────────────────────────── -->
                <TextBlock x:Uid="AmbientStateSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <!-- Surfaced when the persisted Hue bridge state is
                     incomplete (no IP / no username / no group). The
                     toggle stays usable but a click will immediately
                     revert. The action button expands the Hue bridge
                     expander in the Configuration section below and
                     scrolls to it. Tied to the Loaded / Changed
                     observer in code-behind. -->
                <InfoBar x:Name="NotPairedInfoBar"
                         x:Uid="AmbientNotPairedInfoBar"
                         IsClosable="False"
                         IsOpen="False"
                         Severity="Warning"
                         Margin="0,0,0,8">
                    <InfoBar.ActionButton>
                        <Button x:Name="ConfigureBridgeButton"
                                x:Uid="AmbientNotPairedActionButton"
                                Click="ConfigureBridgeButton_Click" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <controls:SettingsCard x:Uid="AmbientEnabledCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE781;}">
                    <ToggleSwitch x:Name="EnabledToggle"
                                  Toggled="EnabledToggle_Toggled" />
                </controls:SettingsCard>

                <!-- ── Behaviour ──────────────────────────────────────────── -->
                <TextBlock x:Uid="AmbientBehaviourSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsCard x:Uid="AmbientModeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:Name="ModeCombo"
                              MinWidth="160"
                              SelectionChanged="ModeCombo_SelectionChanged">
                        <ComboBoxItem x:Uid="AmbientModeGame" Tag="Game" />
                        <ComboBoxItem x:Uid="AmbientModeRealistic" Tag="Realistic" />
                    </ComboBox>
                </controls:SettingsCard>

                <!-- ── HDR tuning ─────────────────────────────────────────── -->
                <!--
                    Four user-tunable sliders applied live on the next push
                    tick (no engine restart). Flat SettingsCards instead of
                    a SettingsExpander so the values are visible at a glance
                    (Louis preference : less click-to-reveal on knobs the
                    user touches often). Descriptions are intentionally
                    short — the dense per-knob rationale lives in the
                    Playground HDR tuning card where the live preview
                    makes experimentation cheap.
                -->
                <!-- Section header with the HyperlinkButton-style reset
                     to the right — calque exact de GeneralPage /
                     WhisperPage. The HyperlinkButton reverts every knob
                     in the section to its documented default ; the per-
                     knob reset (icon at the right of each slider) lives
                     inside each SettingsCard below. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="AmbientTuningSectionHeader"
                               Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <HyperlinkButton x:Uid="Settings_SectionResetLink"
                                     Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Click="ResetTuningSection_Click" />
                </Grid>

                <!-- HDR slider cards. Pattern Whisper :
                     ContentAlignment="Vertical" so the slider full-width
                     can breathe under the description, slider + value +
                     reset triplet inside the card. Reset opacity 0 at
                     rest, lifted to 1 on PointerEntered of the card
                     (WireHover in code-behind). -->
                <controls:SettingsCard x:Name="ExposureCard"
                                       x:Uid="AmbientExposureCard"
                                       ContentAlignment="Vertical">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="ExposureSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="-2.0" Maximum="2.0"
                                StepFrequency="0.1"
                                SmallChange="0.1" LargeChange="0.5"
                                TickFrequency="0.5"
                                TickPlacement="Outside"
                                ValueChanged="ExposureSlider_ValueChanged" />
                        <TextBlock x:Name="ExposureValueText"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="ExposureReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="ExposureReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="SaturationCard"
                                       x:Uid="AmbientSaturationCard"
                                       ContentAlignment="Vertical">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="SaturationSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0" Maximum="200"
                                StepFrequency="5"
                                SmallChange="5" LargeChange="25"
                                TickFrequency="25"
                                TickPlacement="Outside"
                                ValueChanged="SaturationSlider_ValueChanged" />
                        <TextBlock x:Name="SaturationValueText"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="SaturationReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="SaturationReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="MinBrightnessCard"
                                       x:Uid="AmbientMinBrightnessCard"
                                       ContentAlignment="Vertical">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="MinBrightnessSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0" Maximum="254"
                                StepFrequency="2"
                                SmallChange="2" LargeChange="20"
                                TickFrequency="50"
                                TickPlacement="Outside"
                                ValueChanged="MinBrightnessSlider_ValueChanged" />
                        <TextBlock x:Name="MinBrightnessValueText"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="MinBrightnessReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="MinBrightnessReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <!-- Brightness curve : same slider triplet in the
                     Expander header, canvas viz reveals on expand. -->
                <controls:SettingsExpander x:Name="GammaExpander"
                                           x:Uid="AmbientGammaExpander">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="GammaSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                StepFrequency="0.05"
                                SmallChange="0.05" LargeChange="0.25"
                                TickFrequency="0.5"
                                TickPlacement="Outside"
                                ValueChanged="GammaSlider_ValueChanged" />
                        <TextBlock x:Name="GammaValueText"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="GammaReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="GammaReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard>
                            <ambientControls:BrightnessCurveCanvas
                                x:Name="GammaCurveCanvas"
                                HorizontalAlignment="Center" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- Pointer to the Playground — empirical tuning sits
                     better there next to the live preview. -->
                <TextBlock x:Uid="AmbientTuningPlaygroundHint"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Margin="0,4,0,12"
                           TextWrapping="Wrap" />

                <!-- ── Configuration ──────────────────────────────────────── -->
                <!--
                    Hue bridge pairing now lives in this page (was in the
                    Playground in V0). The bridge state is owned by the
                    process-wide HuePairingService — the same instance the
                    Playground and the AmbientEngine consume — so re-pairing
                    or forgetting from either surface takes effect everywhere.
                    Per-light zone assignment and per-light brightness still
                    live in the Playground for now (richer UI tied to the
                    preview grid).
                -->
                <TextBlock x:Uid="AmbientConfigSectionHeader"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsExpander x:Uid="HueBridgeExpander"
                                           x:Name="HueBridgeExpander"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE839;}">
                    <!-- Header right-side : compact status text + dot. The
                         expander shows / hides the per-section cards below
                         on click. -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse x:Name="HueBridgeStatusDot"
                                 Width="10" Height="10"
                                 Fill="{ThemeResource SystemFillColorNeutralBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="HueBridgeStatusText"
                                   Text="Not paired"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <controls:SettingsExpander.Items>
                        <!-- Bridge address row. SettingsCard default
                             layout : Header on the left, content on the
                             right, mirrors the HDR tuning cards above.
                             Discover queries discovery.meethue.com and
                             autofills the textbox ; manual entry is the
                             fallback when the cloud lookup returns
                             nothing (firewall, offline, etc.). Pair
                             launches the 30 s link-button countdown via
                             HuePairingService.PairAsync. Transient
                             status text lives below the card (separate
                             TextBlock) so the card itself stays clean. -->
                        <controls:SettingsCard x:Uid="HueBridgeAddressCard">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="HueBridgeIpTextBox"
                                         Width="160"
                                         PlaceholderText="192.168.1.5" />
                                <Button x:Name="HueDiscoverButton"
                                        x:Uid="HueDiscoverButton"
                                        Click="OnHueDiscoverClick" />
                                <Button x:Name="HuePairButton"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="OnHuePairClick">
                                    <TextBlock x:Name="HuePairLabel"
                                               Text="Pair (press link button)" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <!-- Transient pair status (countdown / errors /
                             paired confirmation). Plain TextBlock inside
                             a borderless card slot — collapsed when
                             empty so the row disappears entirely instead
                             of leaving a hollow card behind. -->
                        <TextBlock x:Name="HuePairStatusText"
                                   Text=""
                                   Visibility="Collapsed"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="16,4,16,8" />

                        <!-- Entertainment group / room. -->
                        <controls:SettingsCard x:Uid="HueBridgeGroupCard">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ComboBox x:Name="HueGroupComboBox"
                                          Width="240"
                                          IsEnabled="False"
                                          SelectionChanged="OnHueGroupSelectionChanged" />
                                <Button x:Name="HueListGroupsButton"
                                        x:Uid="HueListGroupsButton"
                                        IsEnabled="False"
                                        Click="OnHueListGroupsClick" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <!-- Forget : destructive action using the
                             shared CriticalAccentButtonStyle (App.xaml).
                             Full ControlTemplate with VisualStates
                             pinned to the SystemFillColorCritical*
                             family — hover / pressed don't fall back to
                             the standard accent. -->
                        <controls:SettingsCard x:Uid="HueBridgeForgetCard">
                            <Button x:Name="HueForgetButton"
                                    x:Uid="HueForgetButton"
                                    Style="{StaticResource CriticalAccentButtonStyle}"
                                    IsEnabled="False"
                                    Click="OnHueForgetClick" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
