    <value>Configure bridge</value>
  </data>

  <!-- ── Behaviour ─────────────────────────────────────────── -->
  <data name="AmbientBehaviourSectionHeader.Text" xml:space="preserve">
    <value>Behaviour</value>
  </data>
  <data name="AmbientModeCard.Header" xml:space="preserve">
    <value>Mode</value>
  </data>
  <data name="AmbientModeCard.Description" xml:space="preserve">
    <value>Game is vivid and quick. Movie smooths colour changes for cinematic content. Ambient stays soft and slow as room mood lighting. Custom is what the Playground tunes when you touch a slider.</value>
  </data>
  <data name="AmbientModeGame.Content" xml:space="preserve">
    <value>Game</value>
  </data>
  <data name="AmbientModeMovie.Content" xml:space="preserve">
    <value>Movie</value>
  </data>
  <data name="AmbientModeAmbient.Content" xml:space="preserve">
    <value>Ambient</value>
  </data>
  <data name="AmbientModeCustom.Content" xml:space="preserve">
    <value>Custom</value>
  </data>

  <!-- ── HDR tuning ────────────────────────────────────────── -->
  <!-- Flat SettingsCards (no SettingsExpander wrapper) for the
       three classic knobs ; Brightness curve hosts its viz in an
       Expander. Descriptions kept short — the dense per-knob
       rationale lives in the Playground HDR tuning card where a
       live preview makes experimentation cheap. -->
  <data name="AmbientTuningSectionHeader.Text" xml:space="preserve">
    <value>HDR tuning</value>
  </data>
  <data name="AmbientExposureCard.Header" xml:space="preserve">
    <value>Exposure</value>
  </data>
  <data name="AmbientExposureCard.Description" xml:space="preserve">
    <value>Boost or dim the lamp overall. +1 doubles brightness — useful for dim HDR content.</value>
  </data>
  <data name="AmbientSaturationCard.Header" xml:space="preserve">
    <value>Saturation</value>
  </data>
  <data name="AmbientSaturationCard.Description" xml:space="preserve">
    <value>Colour intensity. 100% is neutral; 150–180% gives Hue Sync–like vividness.</value>
  </data>
  <data name="AmbientMinBrightnessCard.Header" xml:space="preserve">
    <value>Minimum brightness</value>
  </data>
  <data name="AmbientMinBrightnessCard.Description" xml:space="preserve">
    <value>Lowest brightness the lamp drops to. Prevents mid-tone scenes from looking washed out.</value>
  </data>
  <data name="AmbientGammaExpander.Header" xml:space="preserve">
    <value>Brightness curve</value>
  </data>
  <data name="AmbientGammaExpander.Description" xml:space="preserve">
    <value>Shapes how dim scenes map to the lamp. Higher values darken shadows without affecting bright areas. Expand to see the curve.</value>
  </data>
  <data name="AmbientTuningPlaygroundHint.Text" xml:space="preserve">
    <value>Open the Playground to tune these values with a live preview.</value>
  </data>
  <data name="Settings_SectionResetLink.Content" xml:space="preserve">
    <value>Reset</value>
  </data>
  <data name="Settings_SectionResetLink.ToolTipService.ToolTip" xml:space="preserve">
    <value>Reset this section to defaults</value>
  </data>

