    <value>When on, your Hue lights follow what's on screen. Capture runs locally on your primary monitor — nothing leaves your machine.</value>
  </data>
  <data name="AmbientNotPairedInfoBar.Title" xml:space="preserve">
    <value>Hue bridge not configured</value>
  </data>
