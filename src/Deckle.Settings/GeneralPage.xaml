<Page
    x:Class="Deckle.Settings.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:settings="using:Deckle.Settings"
    xmlns:vm="using:Deckle.Settings.ViewModels">

    <!-- Pattern canonique Microsoft Learn (SettingsExpander sample "Settings page
         example") : StackPanel max 1000 dans un Grid, Spacing=4 entre cards,
         Margin="1,30,0,6" sur les headers de section. -->
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <!-- Titre de page — pattern Win11 Settings : le H1 vit dans la
                     Page, pas dans le chrome de la fenêtre. -->
                <TextBlock x:Uid="GeneralPageTitleLabel"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,8" />

                <TextBlock x:Uid="GeneralPageSubtitleLabel"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- ── Shortcuts ───────────────────────────────────────────── -->
                <TextBlock x:Uid="GeneralPageShortcutsHeaderLabel"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsCard x:Uid="GeneralTranscribeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE765;}">
                    <TextBlock x:Uid="GeneralShortcutTranscribeKey"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="GeneralPrimaryRewriteCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE765;}">
                    <TextBlock x:Uid="GeneralShortcutPrimaryRewriteKey"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="GeneralSecondaryRewriteCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE765;}">
                    <TextBlock x:Uid="GeneralShortcutSecondaryRewriteKey"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </controls:SettingsCard>

                <!-- ── Appearance ──────────────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="GeneralPageAppearanceHeaderLabel"
                               Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <HyperlinkButton x:Uid="Settings_SectionResetLink"
                                     Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Click="ResetAppearance_Click" />
                </Grid>

                <controls:SettingsCard x:Uid="GeneralAppThemeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:Name="ThemeCombo"
                              MinWidth="160"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem x:Uid="GeneralThemeSystem" Tag="System" />
                        <ComboBoxItem x:Uid="GeneralThemeLight" Tag="Light" />
                        <ComboBoxItem x:Uid="GeneralThemeDark" Tag="Dark" />
                    </ComboBox>
                </controls:SettingsCard>

                <!-- ── Startup ─────────────────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="GeneralPageStartupHeaderLabel"
                               Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <HyperlinkButton x:Uid="Settings_SectionResetLink"
                                     Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Click="ResetStartup_Click" />
                </Grid>

                <controls:SettingsCard x:Uid="GeneralAutostartCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE7E8;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.AutostartEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="GeneralWarmupCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE945;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.WarmupOnLaunch, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- ── Back up & restore ───────────────────────────────────── -->
                <!--
                    Pattern PowerToys (Settings → General → "Back up & restore"):
                    a single SettingsExpander with the Back up / Restore actions
                    in the header and the body revealing Location + the latest
                    snapshot info. Restore targets the most recent snapshot;
                    older snapshots are accessible by opening the folder.
                -->
                <TextBlock x:Uid="GeneralPageBackupRestoreHeaderLabel"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsExpander x:Uid="GeneralBackupExpander"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE777;}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="CreateBackupButton"
                                x:Uid="GeneralBackupCreateButton"
                                Click="CreateBackupButton_Click" />
                        <Button x:Name="RestoreBackupButton"
                                x:Uid="GeneralBackupRestoreButton"
                                Click="RestoreBackupButton_Click"
                                IsEnabled="{x:Bind ViewModel.HasBackup, Mode=OneWay}" />
                    </StackPanel>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard x:Uid="GeneralBackupLocationCard"
                                               ContentAlignment="Vertical">
                            <settings:FolderPickerCard x:Name="BackupFolderPicker"
                                                       Path="{x:Bind ViewModel.BackupDirectory, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Uid="GeneralBackupInfoCard"
                                               ContentAlignment="Vertical">
                            <Grid ColumnSpacing="16" RowSpacing="4" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Uid="GeneralBackupFileNameLabel"
                                           Grid.Row="0" Grid.Column="0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{x:Bind ViewModel.LatestBackupFileName, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Uid="GeneralBackupCreatedAtLabel"
                                           Grid.Row="1" Grid.Column="0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{x:Bind ViewModel.LatestBackupCreatedAt, Mode=OneWay}" />
                            </Grid>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- ── Application data ────────────────────────────────────── -->
                <TextBlock x:Uid="GeneralPageApplicationDataHeaderLabel"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                <controls:SettingsCard x:Uid="GeneralDataFolderCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}"
                                       ContentAlignment="Vertical">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DataFolderPathText"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   IsTextSelectionEnabled="True"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <Button Grid.Column="1"
                                x:Name="OpenDataFolderButton"
                                x:Uid="GeneralDataFolderOpenButton"
                                Click="OpenDataFolderButton_Click" />
                    </Grid>
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="GeneralRerunSetupCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9F5;}">
                    <Button x:Name="ReRunSetupButton"
                            x:Uid="GeneralRerunSetupButton"
                            Click="ReRunSetupButton_Click" />
                </controls:SettingsCard>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
