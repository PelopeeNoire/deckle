<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Deckle.Settings.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:settings="using:Deckle.Settings"
    xmlns:vm="using:Deckle.Settings.ViewModels">

    <!-- Same layout pattern as GeneralPage / WhisperPage: Grid wrapper +
         StackPanel MaxWidth=1000 + SettingsCardSpacing=4 + section
         headers in BodyStrong + Margin 1,30,0,6. Page extracted from
         GeneralPage in slice S2 ; J4 polish added the Logging section
         to host runtime emission filters (Verbose toggle today, more
         per-source filters / minimum-level overrides to come), so the
         page now reads as two parallel groups : Logging on top
         (controls what's emitted) and Telemetry below (controls what's
         persisted to disk). -->
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <TextBlock x:Uid="DiagnosticsPageTitleLabel"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,8" />

                <TextBlock x:Uid="DiagnosticsPageSubtitleLabel"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- ── Logging ─────────────────────────────────────────────────
                     Runtime emission filters. Distinct from Telemetry below :
                     this section controls what the in-app log surface (and
                     the JSONL pipeline downstream) actually emit, while
                     Telemetry controls which of those streams are persisted
                     to disk. The two sections are structured identically so
                     the page reads as two parallel groups of opt-ins. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="DiagnosticsPageLoggingHeaderLabel"
                               Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <HyperlinkButton x:Uid="Settings_SectionResetLink"
                                     Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Click="ResetLogging_Click" />
                </Grid>

                <controls:SettingsCard x:Uid="LoggingAmbientCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE781;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.LogAmbientCaptureActivity, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- ── Telemetry ───────────────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="DiagnosticsPageTelemetryHeaderLabel"
                               Grid.Column="0"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                    <HyperlinkButton x:Uid="Settings_SectionResetLink"
                                     Grid.Column="1"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,2"
                                     Click="ResetTelemetry_Click" />
                </Grid>

                <!-- Application log first (user request : the most asked-for
                     diagnostic when troubleshooting). -->
                <controls:SettingsCard x:Uid="GeneralAppLogCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9A4;}">
                    <ToggleSwitch x:Name="ApplicationLogToggle"
                                  IsOn="{x:Bind ViewModel.ApplicationLogToDisk, Mode=TwoWay}"
                                  Toggled="ApplicationLogToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="GeneralLogMicrophoneCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE720;}">
                    <ToggleSwitch x:Name="MicrophoneTelemetryToggle"
                                  IsOn="{x:Bind ViewModel.MicrophoneTelemetry, Mode=TwoWay}"
                                  Toggled="MicrophoneTelemetryToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="GeneralLatencyCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE916;}">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.TelemetryLatencyEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <controls:SettingsExpander x:Uid="GeneralCorpusExpander"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xEFA9;}">
                    <ToggleSwitch x:Name="CorpusLoggingToggle"
                                  IsOn="{x:Bind ViewModel.TelemetryCorpusEnabled, Mode=TwoWay}"
                                  Toggled="CorpusLoggingToggle_Toggled" />
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard x:Name="AudioCorpusCard"
                                               x:Uid="GeneralAudioCorpusCard"
                                               IsEnabled="{x:Bind ViewModel.TelemetryCorpusEnabled, Mode=OneWay}">
                            <ToggleSwitch x:Name="AudioCorpusToggle"
                                          IsOn="{x:Bind ViewModel.RecordAudioCorpus, Mode=TwoWay}"
                                          Toggled="AudioCorpusToggle_Toggled" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <controls:SettingsCard x:Uid="GeneralStorageFolderCard"
                                       ContentAlignment="Vertical">
                    <settings:FolderPickerCard x:Name="TelemetryFolderPicker"
                                               Path="{x:Bind ViewModel.TelemetryStorageDirectory, Mode=TwoWay}" />
                </controls:SettingsCard>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
