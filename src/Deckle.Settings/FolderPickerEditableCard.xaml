<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Deckle.Settings.FolderPickerEditableCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Editable variant : TextBox (typeable) + Set + Open text-only
         buttons + an inline RightContent slot for callers that need to
         attach extra controls (Whisper's per-setting Reset button is
         the canonical example). The consumer wraps this in a
         controls:SettingsCard (ContentAlignment = Vertical). -->
    <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="PathBox"
                 Grid.Column="0"
                 PlaceholderText="{x:Bind DefaultPath, Mode=OneWay}"
                 Text="{x:Bind Path, Mode=TwoWay}" />

        <Button Grid.Column="1"
                x:Uid="FolderPickerCard_PickButton"
                Click="PickButton_Click" />

        <Button Grid.Column="2"
                x:Uid="FolderPickerCard_OpenButton"
                Click="OpenButton_Click" />

        <ContentPresenter Grid.Column="3"
                          Content="{x:Bind RightContent, Mode=OneWay}"
                          VerticalAlignment="Center" />
    </Grid>
</UserControl>
