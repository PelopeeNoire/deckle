<Window
    x:Class="Deckle.Settings.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Deckle Settings">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TitleBar natif : icône + titre uniquement. La recherche vit dans
             NavigationView.AutoSuggestBox (pattern canonique Microsoft Learn
             "NavigationView → Pane" : slot dédié AutoSuggestBox). -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  x:Uid="SettingsTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- NavigationView. PaneDisplayMode=Auto (défaut) → Left ≥1008,
             LeftCompact 641-1007, LeftMinimal ≤640 (valeurs système, doc
             Microsoft Learn "Default adaptive behavior"). Tag = nom complet
             du type de Page, résolu via Type.GetType dans le handler (pattern
             du sample officiel Microsoft Learn §"Code example"). -->
        <NavigationView Grid.Row="1"
                        x:Name="Nav"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        SelectionChanged="OnNavSelectionChanged"
                        ItemInvoked="OnNavItemInvoked">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="SettingsNavGeneral"
                                    Tag="Deckle.Settings.GeneralPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsNavTranscription"
                                    Tag="Deckle.Whisp.WhisperPage, Deckle.Whisp">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF61F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsNavRewriting"
                                    Tag="Deckle.Llm.LlmPage, Deckle.Llm">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF6C7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="SettingsNavDiagnostics"
                                    Tag="Deckle.Settings.DiagnosticsPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <!-- Logs : ouvre la LogWindow partagée via callback App.
                     SelectsOnInvoked=False → pas de sélection persistante,
                     pas de navigation Frame, on récupère le clic via
                     ItemInvoked. -->
                <NavigationViewItem x:Uid="SettingsNavLogs"
                                    Tag="logs"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEC7A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Content area : le NavigationView pose déjà sa surface Layer
                 avec coin supérieur-gauche arrondi DWM. Pas de Border wrapper,
                 pas de CornerRadius custom, pas de sticky header/footer.
                 Chaque Page gère son propre titre H1 et son ScrollViewer
                 (pattern Win11 Settings). Auto-save partout → pas de
                 Cancel/Save global. -->
            <Frame x:Name="PageFrame" />
        </NavigationView>
    </Grid>
</Window>
