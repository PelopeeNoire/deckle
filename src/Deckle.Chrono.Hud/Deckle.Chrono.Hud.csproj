<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>Deckle.Chrono.Hud</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Platforms>x64</Platforms>
    <!-- WinUI 3 XAML compilation in a class library : nécessaire pour
         que le compilateur génère HudChrono.g.cs (InitializeComponent +
         champs x:Name) à partir de HudChrono.xaml. -->
    <UseWinUI>true</UseWinUI>
    <!-- Assure la génération du .pri de la lib. Le hôte (Deckle.exe) charge
         le .pri principal ; les keys consommées par HudChrono.xaml sont des
         ThemeResource Win11 standard, résolues contre le MainResourceMap au
         runtime. Mirror du flag mis sur Deckle.csproj (cf. WindowsAppSDK#3451). -->
    <EnableMsixTooling>true</EnableMsixTooling>
  </PropertyGroup>

  <ItemGroup>
    <!-- Versions strictement alignées sur Deckle.csproj : un seul runtime
         WinAppSDK chargé par process. Bump synchrone obligatoire. -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260317003" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.4654" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Deckle.Capture\Deckle.Capture.csproj" />
    <ProjectReference Include="..\Deckle.Chrono\Deckle.Chrono.csproj" />
    <ProjectReference Include="..\Deckle.Composition\Deckle.Composition.csproj" />
    <ProjectReference Include="..\Deckle.Core\Deckle.Core.csproj" />
    <ProjectReference Include="..\Deckle.Logging\Deckle.Logging.csproj" />
  </ItemGroup>
</Project>
