    <!-- ─── Lightbulb variants ──────────────────────────────────── -->
    <!-- E7E8 is Lightbulb (filled) ; used as autostart card glyph
         (Icon.Launch alias) and as the Hue "Identify lamp" button. -->
    <x:String x:Key="Icon.LightbulbFilled">&#xE7E8;</x:String>

    <!-- ─── Transport cluster (Playground HUD page) ──────────────── -->
    <x:String x:Key="Icon.Transport.Play">&#xE768;</x:String>
    <x:String x:Key="Icon.Transport.Pause">&#xE769;</x:String>
    <x:String x:Key="Icon.Transport.Stop">&#xE71A;</x:String>

    <!-- ─── Badge cluster (HudPalette mirror, MessageKind) ───────── -->
