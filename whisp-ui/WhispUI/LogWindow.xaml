<Window
    x:Class="WhispUI.LogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:WhispUI"
    Title="WhispUI Logs">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <!-- Bleu sémantique Fluent pour Info — pas l'accent système
                         qui peut être gris / non-bleu chez l'utilisateur. -->
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="LogInfoBrush" Color="#005FB7" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="LogInfoBrush" Color="#60CDFF" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>

                <!-- 5 templates par dimension wrap, swap via DataTemplateSelector
                     au toggle Wrap. Chaque template fige son Foreground sur un
                     ThemeResource : WinUI re-résout automatiquement au theme
                     switch, plus besoin de rebuilder les entrées en code. -->
                <DataTemplate x:Key="NoWrap_Verbose">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Info">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource LogInfoBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Step">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Warning">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Error">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" IsTextSelectionEnabled="True" />
                </DataTemplate>

                <DataTemplate x:Key="Wrap_Verbose">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Info">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource LogInfoBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Step">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Warning">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Error">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </DataTemplate>

                <local:LogLevelTemplateSelector x:Key="NoWrapSelector"
                    Verbose="{StaticResource NoWrap_Verbose}"
                    Info="{StaticResource NoWrap_Info}"
                    Step="{StaticResource NoWrap_Step}"
                    Warning="{StaticResource NoWrap_Warning}"
                    Error="{StaticResource NoWrap_Error}" />
                <local:LogLevelTemplateSelector x:Key="WrapSelector"
                    Verbose="{StaticResource Wrap_Verbose}"
                    Info="{StaticResource Wrap_Info}"
                    Step="{StaticResource Wrap_Step}"
                    Warning="{StaticResource Wrap_Warning}"
                    Error="{StaticResource Wrap_Error}" />

                <!-- Wrappers appliqués via ItemsControl.ItemTemplate : un
                     ContentControl dont le ContentTemplateSelector pointe sur
                     notre selector. Raison : ItemsControl expose bien
                     ItemTemplateSelector mais WinUI 3 ne l'honore pas à
                     l'exécution (seul ListViewBase le respecte). Le swap
                     Wrap/NoWrap change donc ItemTemplate entre ces deux
                     wrappers. -->
                <DataTemplate x:Key="NoWrapRoot">
                    <ContentControl Content="{Binding}"
                                    HorizontalContentAlignment="Stretch"
                                    ContentTemplateSelector="{StaticResource NoWrapSelector}" />
                </DataTemplate>
                <DataTemplate x:Key="WrapRoot">
                    <ContentControl Content="{Binding}"
                                    HorizontalContentAlignment="Stretch"
                                    ContentTemplateSelector="{StaticResource WrapSelector}" />
                </DataTemplate>
            </ResourceDictionary>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Title bar natif (Windows App SDK 1.6+) ─────────────────────── -->
        <!-- Le contrôle TitleBar gère drag region, caption buttons themés,
             hauteur, et expose un slot Content où on place la SearchBox. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="WhispUI Logs">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <AutoSuggestBox x:Name="SearchBox"
                                QueryIcon="Find"
                                PlaceholderText="Rechercher"
                                MaxWidth="320"
                                VerticalAlignment="Center"
                                TextChanged="OnSearchTextChanged" />
            </TitleBar.Content>
        </TitleBar>

        <!-- ── Command bar : selector niveau + actions ──────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:SelectorBar Grid.Column="0"
                                  x:Name="LevelSelector"
                                  Margin="4,0,0,0"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnLevelSelectorChanged">
                <controls:SelectorBarItem x:Name="LevelFull" Text="Full" />
                <controls:SelectorBarItem x:Name="LevelFiltered" Text="Filtered" />
                <controls:SelectorBarItem x:Name="LevelCritical" Text="Critical" />
            </controls:SelectorBar>

            <!-- Migration native via IsDynamicOverflowEnabled (true par défaut)
                 + DynamicOverflowOrder. Plus haut = migre en premier.
                 Groupe 2 (Copy/Save/Clear/Sep) part en premier, puis groupe 1
                 (AutoScroll/Wrap). La CommandBar gère elle-même mesure, popup
                 et placement. -->
            <CommandBar Grid.Column="1"
                        x:Name="MainCommandBar"
                        DefaultLabelPosition="Right"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        IsOpen="False">
                <AppBarButton x:Name="CopyButton" Label="Copy"
                              DynamicOverflowOrder="2" Click="OnCopyClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8C8;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="SaveButton" Label="Save"
                              DynamicOverflowOrder="2" Click="OnSaveClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74E;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="ClearButton" Label="Clear"
                              DynamicOverflowOrder="2" Click="OnClearClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74D;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator DynamicOverflowOrder="2" />
                <AppBarToggleButton x:Name="AutoScrollToggle"
                                    Label="Auto scroll"
                                    DynamicOverflowOrder="1"
                                    IsChecked="True">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xE70D;" />
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton x:Name="WrapToggle"
                                    Label="Wrap"
                                    DynamicOverflowOrder="1"
                                    IsChecked="False"
                                    Click="OnWrapToggleClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xE751;" />
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
            </CommandBar>
        </Grid>

        <!-- ── Surface logs ─────────────────────────────────────────────── -->
        <!-- Layer Fill distinct du fond Mica + divider en haut, pour matcher
             la hiérarchie de surfaces Figma (App Base → App Layer). -->
        <Border Grid.Row="2"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <ScrollViewer x:Name="LogScrollViewer"
                          Padding="12,8"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalContentAlignment="Left"
                          HorizontalScrollMode="Enabled">
                <ItemsControl x:Name="LogItems" HorizontalAlignment="Left" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
