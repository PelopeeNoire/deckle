<Window
    x:Class="WhispUI.LogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Whisp — Logs">

    <Grid x:Name="RootGrid" Background="#1E1E1E" RequestedTheme="Dark">
        <Grid.Resources>
            <!-- Deux templates distincts : swap au toggle Retour ligne.
                 Plus simple que bind dynamique sur TextWrapping dans un ItemsControl. -->
            <DataTemplate x:Key="NoWrapTemplate">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Color}"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextWrapping="NoWrap"
                           IsTextSelectionEnabled="True" />
            </DataTemplate>
            <DataTemplate x:Key="WrapTemplate">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Color}"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Barre d'outils -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Padding="10,8"
                    Spacing="8"
                    Background="#2A2A2A"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
            <Button Content="Effacer"      Click="OnClearClick" />
            <Button Content="Copier tout"  Click="OnCopyClick" />
            <Button Content="Enregistrer…" Click="OnSaveClick" />
            <ToggleButton x:Name="AutoScrollToggle"
                          Content="Auto-scroll"
                          IsChecked="True" />
            <ToggleButton x:Name="WrapToggle"
                          Content="Retour ligne"
                          IsChecked="False"
                          Click="OnWrapToggleClick" />
        </StackPanel>

        <!-- Flux de logs -->
        <ScrollViewer x:Name="LogScrollViewer"
                      Grid.Row="1"
                      Padding="12,8"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="LogItems" />
        </ScrollViewer>
    </Grid>
</Window>
