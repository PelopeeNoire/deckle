<Window
    x:Class="WhispUI.LogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="WhispUI Logs">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <!-- Deux templates distincts : swap au toggle Wrap.
                 Plus simple que bind dynamique sur TextWrapping. -->
            <DataTemplate x:Key="NoWrapTemplate">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Color}"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextWrapping="NoWrap"
                           IsTextSelectionEnabled="True" />
            </DataTemplate>
            <DataTemplate x:Key="WrapTemplate">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Color}"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Title bar custom (extended into client area) ──────────────── -->
        <!-- Layout 3 colonnes : drag (icône+titre) | search centrée | réserve caption btns.
             Seule la colonne 0 est marquée comme drag region (SetTitleBar) pour
             que l'AutoSuggestBox au centre puisse recevoir les clics. -->
        <Grid Grid.Row="0" x:Name="AppTitleBar" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="138" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Padding="16,0,8,0"
                        Spacing="16"
                        VerticalAlignment="Stretch">
                <!-- Icône de l'application — même asset que le tray et que
                     l'icône de fenêtre (taskbar/alt-tab). Source swappée
                     idle/recording dans ApplyRecordingState. -->
                <Image x:Name="AppIconBeacon"
                       Width="16"
                       Height="16"
                       VerticalAlignment="Center" />
                <TextBlock Text="WhispUI Logs"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <AutoSuggestBox x:Name="SearchBox"
                            Grid.Column="1"
                            QueryIcon="Find"
                            PlaceholderText="Rechercher"
                            MaxWidth="320"
                            VerticalAlignment="Center"
                            TextChanged="OnSearchTextChanged" />
        </Grid>

        <!-- ── Command bar : selector niveau + actions ──────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:SelectorBar Grid.Column="0"
                                  x:Name="LevelSelector"
                                  Margin="4,0,0,0"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnLevelSelectorChanged">
                <controls:SelectorBarItem x:Name="LevelFull" Text="Full" />
                <controls:SelectorBarItem x:Name="LevelFiltered" Text="Filtered" />
                <controls:SelectorBarItem x:Name="LevelCritical" Text="Critical" />
            </controls:SelectorBar>

            <CommandBar Grid.Column="1"
                        DefaultLabelPosition="Right"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        IsOpen="False"
                        OverflowButtonVisibility="Collapsed">
                <AppBarButton Label="Copy" Click="OnCopyClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8C8;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Save" Click="OnSaveClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74E;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Clear" Click="OnClearClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74D;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarToggleButton x:Name="AutoScrollToggle"
                                    Label="Auto scroll"
                                    IsChecked="True">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xE70D;" />
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton x:Name="WrapToggle"
                                    Label="Wrap"
                                    IsChecked="True"
                                    Click="OnWrapToggleClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xE751;" />
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
            </CommandBar>
        </Grid>

        <!-- ── Surface logs ─────────────────────────────────────────────── -->
        <!-- Layer Fill distinct du fond Mica + divider en haut, pour matcher
             la hiérarchie de surfaces Figma (App Base → App Layer). -->
        <Border Grid.Row="2"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <ScrollViewer x:Name="LogScrollViewer"
                          Padding="12,8"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LogItems" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
