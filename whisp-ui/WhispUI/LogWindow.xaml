<Window
    x:Class="WhispUI.LogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:WhispUI"
    Title="WhispUI Logs">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <!-- Bleu sémantique Fluent pour Info — pas l'accent système
                         qui peut être gris / non-bleu chez l'utilisateur. -->
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="LogInfoBrush" Color="#005FB7" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="LogInfoBrush" Color="#60CDFF" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>

                <!-- 5 templates par dimension wrap, swap via DataTemplateSelector
                     au toggle Wrap. Chaque template fige son Foreground sur un
                     ThemeResource : WinUI re-résout automatiquement au theme
                     switch, plus besoin de rebuilder les entrées en code. -->
                <DataTemplate x:Key="NoWrap_Verbose">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Info">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource LogInfoBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Step">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Warning">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>
                <DataTemplate x:Key="NoWrap_Error">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="NoWrap" />
                </DataTemplate>

                <DataTemplate x:Key="Wrap_Verbose">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Info">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource LogInfoBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Step">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Warning">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>
                <DataTemplate x:Key="Wrap_Error">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               FontFamily="Consolas" FontSize="12"
                               TextWrapping="Wrap" />
                </DataTemplate>

                <local:LogLevelTemplateSelector x:Key="NoWrapSelector"
                    Verbose="{StaticResource NoWrap_Verbose}"
                    Info="{StaticResource NoWrap_Info}"
                    Step="{StaticResource NoWrap_Step}"
                    Warning="{StaticResource NoWrap_Warning}"
                    Error="{StaticResource NoWrap_Error}" />
                <local:LogLevelTemplateSelector x:Key="WrapSelector"
                    Verbose="{StaticResource Wrap_Verbose}"
                    Info="{StaticResource Wrap_Info}"
                    Step="{StaticResource Wrap_Step}"
                    Warning="{StaticResource Wrap_Warning}"
                    Error="{StaticResource Wrap_Error}" />

                <!-- Container compact pour un rendu log dense : padding réduit,
                     hover highlight conservé (signale le clic-to-copy). -->
                <Style x:Key="LogItemContainerStyle" TargetType="ListViewItem">
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Padding" Value="4,1" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ResourceDictionary>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Title bar natif (Windows App SDK 1.6+) ─────────────────────── -->
        <!-- Le contrôle TitleBar gère drag region, caption buttons themés,
             hauteur, et expose un slot Content où on place la SearchBox. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="WhispUI Logs">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <!-- AutoSuggestBox unique. Le TitleBar priorise la largeur de
                     son Content vs caption buttons, et l'AutoSuggestBox
                     rétrécit naturellement jusqu'à MinWidth. Pas de swap
                     icône/field custom — pattern Win11 Settings. -->
                <AutoSuggestBox x:Name="SearchBox"
                                QueryIcon="Find"
                                PlaceholderText="Search logs"
                                MinWidth="240"
                                MaxWidth="760"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                TextChanged="OnSearchTextChanged" />
            </TitleBar.Content>
        </TitleBar>

        <!-- ── Command bar : selector niveau + actions ──────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:SelectorBar Grid.Column="0"
                                  x:Name="LevelSelector"
                                  Margin="4,0,0,0"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnLevelSelectorChanged">
                <controls:SelectorBarItem x:Name="LevelFull" Text="All" />
                <controls:SelectorBarItem x:Name="LevelFiltered" Text="Activity" />
                <controls:SelectorBarItem x:Name="LevelCritical" Text="Errors" />
            </controls:SelectorBar>

            <!-- Migration native via IsDynamicOverflowEnabled (true par défaut)
                 + DynamicOverflowOrder. Plus haut = migre en premier.
                 Groupe 2 (Copy/Save/Clear/Sep) part en premier, puis groupe 1
                 (AutoScroll/Wrap). La CommandBar gère elle-même mesure, popup
                 et placement. -->
            <CommandBar Grid.Column="1"
                        x:Name="MainCommandBar"
                        DefaultLabelPosition="Right"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        IsOpen="False">
                <AppBarButton x:Name="CopyButton" Label="Copy"
                              DynamicOverflowOrder="2" Click="OnCopyClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8C8;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="SaveButton" Label="Save"
                              DynamicOverflowOrder="2" Click="OnSaveClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74E;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="ClearButton" Label="Clear"
                              DynamicOverflowOrder="2" Click="OnClearClick">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE74D;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator DynamicOverflowOrder="2" />
                <AppBarToggleButton x:Name="AutoScrollToggle"
                                    Label="Auto-scroll"
                                    DynamicOverflowOrder="1"
                                    IsChecked="True">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xEC8F;" />
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton x:Name="WrapToggle"
                                    Label="Word wrap"
                                    DynamicOverflowOrder="1"
                                    IsChecked="False"
                                    Click="OnWrapToggleClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xE751;" />
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
            </CommandBar>
        </Grid>

        <!-- ── Surface logs ─────────────────────────────────────────────── -->
        <!-- ListView natif : virtualisation, scroll intégré, ItemTemplateSelector
             honoré. Clic gauche = copie la ligne, clic droit = MenuFlyout natif.
             Badge flottant "Copy" positionné à droite de l'item survolé. -->
        <Grid Grid.Row="2" x:Name="LogSurface">
            <ListView x:Name="LogItems"
                      Background="{ThemeResource LayerFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,1,0,0"
                      Padding="12,4"
                      ItemContainerStyle="{StaticResource LogItemContainerStyle}"
                      ItemTemplateSelector="{StaticResource NoWrapSelector}"
                      SelectionMode="Extended"
                      IsItemClickEnabled="False"
                      PointerMoved="OnLogPointerMoved"
                      PointerExited="OnLogPointerExited"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto" />

            <!-- Badge flottant "Copy" — positionné par code à droite de l'item
                 survolé. IsHitTestVisible=False pour laisser le clic passer au
                 ListView. Theme resources uniquement, zéro valeur magique. -->
            <!-- Badge flottant "Copy" / "Copy selection" — positionné par code
                 à droite de l'item survolé. Fond opaque (LayerFill) pour
                 couvrir le texte derrière. IsHitTestVisible=False pour
                 laisser les clics passer au ListView. -->
            <Border x:Name="CopyBadge"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Canvas.ZIndex="1"
                    Padding="8,2"
                    Margin="0,0,18,0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="CopyBadgeTransform" />
                </Border.RenderTransform>
                <TextBlock x:Name="CopyBadgeText"
                           Text="Copy"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
        </Grid>
    </Grid>
</Window>
