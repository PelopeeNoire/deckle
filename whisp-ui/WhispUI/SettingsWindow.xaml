<Window
    x:Class="WhispUI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="WhispUI Settings">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Title bar natif — pas de hamburger : en PaneDisplayMode=Left
             le NavigationView tient son pane toujours visible et inline,
             donc aucun toggle n'est nécessaire. -->
        <!-- TitleBar natif. Hamburger, titre et zone Content basculent via
             OnRootSizeChanged selon 3 breakpoints : 960, 580, 390. -->
        <TitleBar Grid.Row="0"
                  x:Name="AppTitleBar"
                  Title="WhispUI Settings"
                  PaneToggleRequested="OnPaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource x:Name="AppTitleBarIcon" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <Grid VerticalAlignment="Center">
                    <AutoSuggestBox x:Name="SearchBox"
                                    QueryIcon="Find"
                                    PlaceholderText="Rechercher un paramètre"
                                    MinWidth="280"
                                    MaxWidth="560"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                    <Button x:Name="SearchIconButton"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnSearchIconClick"
                            ToolTipService.ToolTip="Rechercher un paramètre">
                        <FontIcon Glyph="&#xE721;" FontSize="16" />
                    </Button>
                </Grid>
            </TitleBar.Content>
        </TitleBar>

        <!-- ── NavigationView — PaneDisplayMode=Left : pane toujours
             inline (push content, jamais d'overlay). Pattern canonique
             recommandé par Microsoft Learn pour un Settings à nav fixe. -->
        <NavigationView Grid.Row="1"
                        x:Name="Nav"
                        PaneDisplayMode="Left"
                        OpenPaneLength="240"
                        CompactPaneLength="48"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsSettingsVisible="False"
                        SelectionChanged="OnNavSelectionChanged"
                        ItemInvoked="OnNavItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavGeneral" Content="General" Tag="general">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavWhisper" Content="Whisper configuration" Tag="whisper">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF61F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavLlm" Content="LLM Rewriting" Tag="llm">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF6C7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <!-- Item "Logs" : ouvre la LogWindow partagée via callback App.
                     SelectsOnInvoked=False pour que le clic ne le marque pas
                     comme page sélectionnée (ce n'est pas une page interne). -->
                <NavigationViewItem x:Name="NavLogs"
                                    Content="Logs"
                                    Tag="logs"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEC7A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Layer Fill comme LogWindow pour la hiérarchie de surfaces -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,1,0,0"
                    CornerRadius="7,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Sticky header : H1 + Set to defaults global -->
                    <Grid Grid.Row="0" Padding="32,24,32,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PageTitle"
                                   Grid.Column="0"
                                   Text="General"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="OnResetAllClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE10E;" FontSize="14" />
                                <TextBlock Text="Set to defaults" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Zone scrollable : chaque Page porte son propre ScrollViewer
                         et son padding interne (pattern canonique Microsoft Learn).
                         Le Frame gère le cycle de vie et les transitions natives. -->
                    <Frame Grid.Row="1" x:Name="PageFrame" />

                    <!-- Sticky footer : séparateur + Cancel / Save -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="12"
                                    Padding="32,16,32,16">
                            <Button Content="Cancel" Click="OnCancelClick" MinWidth="96" />
                            <Button Content="Save" Style="{StaticResource AccentButtonStyle}"
                                    Click="OnSaveClick" MinWidth="96" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </NavigationView>
    </Grid>
</Window>
