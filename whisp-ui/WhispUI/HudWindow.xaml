<Window
    x:Class="WhispUI.HudWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <!-- Stroke Figma : #757575 @ 40% (identique light/dark dans la maquette). -->
            <SolidColorBrush x:Key="HudStrokeBrush" Color="#66757575" />
        </Grid.Resources>

        <!-- Bordure arrondie seule (pas de contenu enfant) : un Border CornerRadius
             clippe son contenu, donc on le garde vide et on superpose le contenu
             en frère dans la Grid racine. Comme ca le glyphe Bitcount peut deborder
             librement sans etre rogne. -->
        <Border CornerRadius="7"
                BorderBrush="{StaticResource HudStrokeBrush}"
                BorderThickness="1" />

        <!-- Contenu superpose, frere du Border : paddings Figma exacts. -->
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- container clock : padding Figma 32 / 24 / 12 / 24 (l/t/r/b). -->
            <Border Grid.Column="0" Padding="0">
                <TextBlock x:Name="ClockText"
                           FontFamily="ms-appx:///Assets/Fonts/BitcountSingle.ttf#Bitcount Single"
                           FontWeight="ExtraLight"
                           FontSize="48"
                           TextLineBounds="Tight"
                           CharacterSpacing="-325"
                           Margin="24,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                    <Run Text="0" />
                    <Run Text="0" />
                    <Run Text="." />
                    <Run Text="0" />
                    <Run Text="0" />
                    <Run Text="." />
                    <Run Text="0" />
                    <Run Text="0" />
                </TextBlock>
            </Border>

            <!-- container indicator : padding Figma 12 uniforme, sous-grille 32x32. -->
            <Border Grid.Column="1" Padding="12,12,12,12">
                <Grid Width="32" Height="32">
                    <Ellipse x:Name="StatusDot"
                             Width="4" Height="4"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Fill="{ThemeResource SystemFillColorCriticalBrush}" />
                    <ProgressRing x:Name="TranscribeRing"
                                  Width="32" Height="32"
                                  IsActive="False"
                                  Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
