<Page
    x:Class="WhispUI.Settings.LlmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32,24,32,24"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch">
            <TextBlock Text="LLM Rewriting"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,16" />
            <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                       TextWrapping="Wrap"
                       Text="Réécriture LLM à venir (provider, modèle, prompt système, hotkey)." />
        </StackPanel>
    </ScrollViewer>
</Page>
