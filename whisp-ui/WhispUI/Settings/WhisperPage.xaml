<Page
    x:Class="WhispUI.Settings.WhisperPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>

        <!-- Slider compact pour valeurs bornées continues — pattern Settings
             Windows 11 (sensibilité souris, volume, etc.). Pas de spinner,
             pas de layout shift, valeur affichée à droite via ValueTextBlock. -->
        <Style x:Key="SettingSliderStyle"
               TargetType="Slider">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsThumbToolTipEnabled" Value="True" />
        </Style>

        <Style x:Key="SliderValueTextStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- Bouton reset per-setting. Opacity 0 par défaut, passée à 1 au
             PointerEntered de la SettingsCard parente (code-behind). -->
        <Style x:Key="ResetButtonStyle"
               BasedOn="{StaticResource SubtleButtonStyle}"
               TargetType="Button">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.ToolTip" Value="Reset to default" />
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="32,0,32,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">

                <!-- ── Transcription ───────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Transcription" />

                <InfoBar x:Name="RestartPendingInfoBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Informational"
                         Title="Restart required"
                         Message="Le modèle et l'usage du GPU sont appliqués au démarrage. Ferme et rouvre WhispUI pour que les changements prennent effet." />

                <controls:SettingsExpander x:Name="PathsCard"
                                           Header="Chemins (avancé)"
                                           Description="Dossier où sont stockés les modèles Whisper et le modèle VAD Silero."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Vertical"
                                               Header="Dossier des modèles"
                                               Description="Vide = résolution automatique vers ../../shared relatif à l'exécutable.">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="ModelsDirectoryBox"
                                         MinWidth="400"
                                         PlaceholderText="(auto)"
                                         TextChanged="ModelsDirectoryBox_TextChanged" />
                                <Button x:Name="ModelsDirectoryReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="ModelsDirectoryReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <controls:SettingsCard x:Name="ModelCard"
                                       Header="Modèle Whisper"
                                       Description="Fichier .bin utilisé pour la transcription. Le modèle est chargé au démarrage de l'application."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE7F4;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ComboBox x:Name="ModelCombo"
                                  MinWidth="240"
                                  SelectionChanged="ModelCombo_SelectionChanged" />
                        <Button x:Name="ModelReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="ModelReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="UseGpuCard"
                                       Header="Utiliser le GPU"
                                       Description="Active l'accélération GPU via Vulkan. À couper si instabilité."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE950;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="UseGpuToggle"
                                      Toggled="UseGpuToggle_Toggled" />
                        <Button x:Name="UseGpuReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="UseGpuReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="LanguageCard"
                                       Header="Langue"
                                       Description="Code ISO à deux lettres (fr, en, es…) ou 'auto' pour la détection automatique."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xF2B7;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ComboBox x:Name="LanguageCombo"
                                  MinWidth="160"
                                  IsEditable="True"
                                  SelectionChanged="LanguageCombo_SelectionChanged">
                            <ComboBoxItem Content="auto" />
                            <ComboBoxItem Content="fr" />
                            <ComboBoxItem Content="en" />
                            <ComboBoxItem Content="es" />
                            <ComboBoxItem Content="de" />
                            <ComboBoxItem Content="it" />
                            <ComboBoxItem Content="pt" />
                            <ComboBoxItem Content="nl" />
                            <ComboBoxItem Content="ja" />
                            <ComboBoxItem Content="zh" />
                        </ComboBox>
                        <Button x:Name="LanguageReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="LanguageReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="InitialPromptCard"
                                       ContentAlignment="Vertical"
                                       Header="Prompt initial"
                                       Description="Texte injecté avant la transcription pour orienter le vocabulaire et la ponctuation."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE932;}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="InitialPromptBox"
                                 MinWidth="400"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 PlaceholderText="Transcription en français."
                                 TextChanged="InitialPromptBox_TextChanged" />
                        <Button x:Name="InitialPromptReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="InitialPromptReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <!-- ── Filtrage de la parole (VAD) ─────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Filtrage de la parole (VAD)" />

                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="1,0,0,8"
                           Text="Silero VAD pré-filtre l'audio pour ne transcrire que les segments contenant de la parole. Réduit les hallucinations sur les silences." />

                <controls:SettingsExpander x:Name="VadEnabledCard"
                                           Header="Activer le VAD"
                                           Description="Nécessite le modèle ggml-silero-v6.2.0.bin dans le dossier des modèles."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE720;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="VadEnabledToggle"
                                      Toggled="VadEnabledToggle_Toggled" />
                        <Button x:Name="VadEnabledReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="VadEnabledReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <controls:SettingsExpander.Items>

                        <controls:SettingsCard x:Name="VadThresholdCard"
                                               Header="Seuil de détection"
                                               Description="Probabilité minimale pour considérer un segment comme de la parole.">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Slider x:Name="VadThresholdSlider"
                                        Style="{StaticResource SettingSliderStyle}"
                                        Minimum="0"
                                        Maximum="1"
                                        StepFrequency="0.05"
                                        TickFrequency="0.1"
                                        ValueChanged="VadThresholdSlider_ValueChanged" />
                                <TextBlock x:Name="VadThresholdValue"
                                           Style="{StaticResource SliderValueTextStyle}" />
                                <Button x:Name="VadThresholdReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadThresholdReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadMinSpeechCard"
                                               Header="Durée minimum de parole"
                                               Description="En millisecondes. Les segments plus courts sont ignorés.">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <NumberBox x:Name="VadMinSpeechBox"
                                           Minimum="0"
                                           Maximum="5000"
                                           SmallChange="50"
                                           LargeChange="250"
                                           SpinButtonPlacementMode="Hidden"
                                           MinWidth="100"
                                           ValueChanged="VadMinSpeechBox_ValueChanged" />
                                <Button x:Name="VadMinSpeechReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadMinSpeechReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadMinSilenceCard"
                                               Header="Durée minimum de silence"
                                               Description="En millisecondes. Silence plus court = segments fusionnés.">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <NumberBox x:Name="VadMinSilenceBox"
                                           Minimum="0"
                                           Maximum="5000"
                                           SmallChange="50"
                                           LargeChange="250"
                                           SpinButtonPlacementMode="Hidden"
                                           MinWidth="100"
                                           ValueChanged="VadMinSilenceBox_ValueChanged" />
                                <Button x:Name="VadMinSilenceReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadMinSilenceReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadMaxSpeechCard"
                                               Header="Durée maximum d'un segment"
                                               Description="En secondes. Plafond avant découpe forcée.">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Slider x:Name="VadMaxSpeechSlider"
                                        Style="{StaticResource SettingSliderStyle}"
                                        Minimum="5"
                                        Maximum="60"
                                        StepFrequency="1"
                                        TickFrequency="5"
                                        ValueChanged="VadMaxSpeechSlider_ValueChanged" />
                                <TextBlock x:Name="VadMaxSpeechValue"
                                           Style="{StaticResource SliderValueTextStyle}" />
                                <Button x:Name="VadMaxSpeechReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadMaxSpeechReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadSpeechPadCard"
                                               Header="Padding autour de la parole"
                                               Description="En millisecondes. Marge ajoutée avant et après chaque segment détecté.">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <NumberBox x:Name="VadSpeechPadBox"
                                           Minimum="0"
                                           Maximum="2000"
                                           SmallChange="25"
                                           LargeChange="100"
                                           SpinButtonPlacementMode="Hidden"
                                           MinWidth="100"
                                           ValueChanged="VadSpeechPadBox_ValueChanged" />
                                <Button x:Name="VadSpeechPadReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadSpeechPadReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Name="VadOverlapCard"
                                               Header="Recouvrement des fenêtres"
                                               Description="Fraction de recouvrement entre fenêtres d'analyse consécutives.">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Slider x:Name="VadOverlapSlider"
                                        Style="{StaticResource SettingSliderStyle}"
                                        Minimum="0"
                                        Maximum="0.5"
                                        StepFrequency="0.05"
                                        TickFrequency="0.1"
                                        ValueChanged="VadOverlapSlider_ValueChanged" />
                                <TextBlock x:Name="VadOverlapValue"
                                           Style="{StaticResource SliderValueTextStyle}" />
                                <Button x:Name="VadOverlapReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="VadOverlapReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>

                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- ── Décodage ────────────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Décodage" />

                <controls:SettingsCard x:Name="TemperatureCard"
                                       Header="Température"
                                       Description="Randomisation de l'échantillonnage. 0 = déterministe (recommandé)."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9CA;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="TemperatureSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0"
                                Maximum="1"
                                StepFrequency="0.1"
                                TickFrequency="0.1"
                                ValueChanged="TemperatureSlider_ValueChanged" />
                        <TextBlock x:Name="TemperatureValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="TemperatureReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="TemperatureReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="TemperatureIncrementCard"
                                       Header="Temperature fallback step"
                                       Description="Pas du fallback automatique quand la confiance est trop basse. 0 désactive le fallback."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9CE;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="TemperatureIncrementSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0"
                                Maximum="1"
                                StepFrequency="0.1"
                                TickFrequency="0.1"
                                ValueChanged="TemperatureIncrementSlider_ValueChanged" />
                        <TextBlock x:Name="TemperatureIncrementValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="TemperatureIncrementReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="TemperatureIncrementReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <InfoBar x:Name="TemperatureIncrementWarning"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Fallback disabled"
                         Message="Avec un incrément à 0, Whisper ne retentera pas un segment mal transcrit. Laisser à 0.2 sauf cas précis." />

                <!-- ── Seuils de confiance ─────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Seuils de confiance" />

                <controls:SettingsCard x:Name="EntropyCard"
                                       Header="Seuil d'entropie"
                                       Description="Au-dessus de ce seuil, Whisper considère la sortie incertaine et déclenche le fallback température."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="EntropySlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0"
                                Maximum="5"
                                StepFrequency="0.1"
                                TickFrequency="0.5"
                                ValueChanged="EntropySlider_ValueChanged" />
                        <TextBlock x:Name="EntropyValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="EntropyReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="EntropyReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="LogprobCard"
                                       Header="Seuil de log-probabilité"
                                       Description="Log-probabilité moyenne minimale acceptée par segment. Négatif, plus c'est bas, plus on accepte d'incertitude."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="LogprobSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="-5"
                                Maximum="0"
                                StepFrequency="0.1"
                                TickFrequency="0.5"
                                ValueChanged="LogprobSlider_ValueChanged" />
                        <TextBlock x:Name="LogprobValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="LogprobReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="LogprobReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="NoSpeechCard"
                                       Header="Seuil 'pas de parole'"
                                       Description="Au-dessus, un segment est considéré silencieux et supprimé. Augmenter pour filtrer plus de silence."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Slider x:Name="NoSpeechSlider"
                                Style="{StaticResource SettingSliderStyle}"
                                Minimum="0"
                                Maximum="1"
                                StepFrequency="0.05"
                                TickFrequency="0.1"
                                ValueChanged="NoSpeechSlider_ValueChanged" />
                        <TextBlock x:Name="NoSpeechValue"
                                   Style="{StaticResource SliderValueTextStyle}" />
                        <Button x:Name="NoSpeechReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="NoSpeechReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <!-- ── Filtres de sortie ───────────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Filtres de sortie" />

                <controls:SettingsCard x:Name="SuppressNstCard"
                                       Header="Supprimer les tokens non-parole"
                                       Description="Retire les marqueurs type [Musique], (rires) générés par Whisper."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE74F;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="SuppressNstToggle"
                                      Toggled="SuppressNstToggle_Toggled" />
                        <Button x:Name="SuppressNstReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="SuppressNstReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="SuppressBlankCard"
                                       Header="Supprimer les segments vides"
                                       Description="Retire les segments qui ne contiennent que des blancs ou de la ponctuation."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE74F;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="SuppressBlankToggle"
                                      Toggled="SuppressBlankToggle_Toggled" />
                        <Button x:Name="SuppressBlankReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="SuppressBlankReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsExpander x:Name="SuppressRegexCard"
                                           Header="Regex de suppression (avancé)"
                                           Description="Expression régulière appliquée à chaque segment. Les tokens qui matchent sont retirés."
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE8AF;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Vertical">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="SuppressRegexBox"
                                         MinWidth="400"
                                         PlaceholderText="(ex: ^\s*\[.*\]\s*$)"
                                         TextChanged="SuppressRegexBox_TextChanged" />
                                <Button x:Name="SuppressRegexReset"
                                        Style="{StaticResource ResetButtonStyle}"
                                        Click="SuppressRegexReset_Click">
                                    <FontIcon Glyph="&#xE777;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- ── Contexte et segmentation ────────────────────────────── -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="Contexte et segmentation" />

                <controls:SettingsCard x:Name="UseContextCard"
                                       Header="Utiliser le contexte précédent"
                                       Description="Propage les tokens du segment précédent comme amorce du suivant. À couper si le modèle part en boucle."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8A5;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleSwitch x:Name="UseContextToggle"
                                      Toggled="UseContextToggle_Toggled" />
                        <Button x:Name="UseContextReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="UseContextReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard x:Name="MaxTokensCard"
                                       Header="Nombre maximum de tokens par segment"
                                       Description="Plafond de tokens générés par segment. -1 = automatique (recommandé)."
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8A5;}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <!-- SpinButtonPlacementMode=Hidden : pas de flyout qui pousse
                             le layout ; saisie clavier + molette. -->
                        <NumberBox x:Name="MaxTokensBox"
                                   Minimum="-1"
                                   Maximum="448"
                                   SmallChange="1"
                                   LargeChange="10"
                                   SpinButtonPlacementMode="Hidden"
                                   MinWidth="100"
                                   ValueChanged="MaxTokensBox_ValueChanged" />
                        <Button x:Name="MaxTokensReset"
                                Style="{StaticResource ResetButtonStyle}"
                                Click="MaxTokensReset_Click">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
