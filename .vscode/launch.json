{
    // WhispUI build profiles. Select from the Run and Debug panel (Ctrl+Shift+D),
    // then F5. Uses the PowerShell extension (ms-vscode.powershell).
    //
    // Le profil "Pick" ouvre un menu flèches dans le terminal et liste tous
    // les worktrees. VSCodium reste ouvert sur main, on choisit la branche
    // à builder sans switcher.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build: pick worktree (arrow keys)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/scripts/build-run.ps1",
            "args": [ "-Pick" ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Build: main",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/scripts/build-run.ps1",
            "args": [ "-Target", "D:\\projects\\ai\\transcription" ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Build: main (Restore)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/scripts/build-run.ps1",
            "args": [ "-Target", "D:\\projects\\ai\\transcription", "-Restore" ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Build: main (Debug config)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/scripts/build-run.ps1",
            "args": [ "-Target", "D:\\projects\\ai\\transcription", "-Configuration", "Debug" ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Build: pick (no run)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/scripts/build-run.ps1",
            "args": [ "-Pick", "-NoRun" ],
            "cwd": "${workspaceFolder}"
        }
    ]
}
